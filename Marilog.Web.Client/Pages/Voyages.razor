@page "/voyages"
@using Marilog.Contracts.DTOs.Requests.VoyageDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Shared.UI.Pages.Voyages
@using Marilog.Shared.UI.Pages.BillOfLading
@using Marilog.Contracts.DTOs.Requests.BillOfLadingDTOs
@* VoyagePageHost.razor *@
@inject IVoyageService VoyageService
@inject IVesselService VesselService
@inject IBillOfLadingService BillOfLadingService
@inject IDialogService DialogService
@inject IPortService PortService
@inject ISnackbar Snackbar
@inject IDocumentService DocumentService
@inject ICompanyService CompanyService
<VoyagePage Voyages="_voyages"
            IsLoading="_loading"
            SelectedVoyage="_selectedVoyage"
            BillsOfLading="_bills"
            IsBillsLoading="_billsLoading"
            OnAddClicked="OpenAddDialog"
            OnViewClicked="SelectVoyage"
            OnEditClicked="OpenEditDialog"
            OnDeleteClicked="ConfirmDelete"
            OnAddStopClicked="OpenAddStopDialog"
            OnAddBillClicked="OpenAddBillDialog"
            OnViewBillClicked="OpenViewBillDialog"
            OnEditBillClicked="OpenEditBillDialog"
            OnDeleteBillClicked="ConfirmDeleteBill"
            OnBackClicked="HandleBack"
            OnVesselSelected="LoadByVessel"
            Vessels="_vessels"
            Docs="_docs"
            ByVessel="_byVessel" />  @* <- تأكد من تمرير هذه الخاصية *@
@code {


    private IReadOnlyList<VoyageResponse> _voyages = [];
    private IReadOnlyList<BillOfLadingResponse> _bills = [];
    private IReadOnlyList<VoyageResponse> _byVessel = [];
    private IReadOnlyList<VesselResponse> _vessels = [];
    private IReadOnlyList<DocumentResponse> _docs = [];
    private VoyageResponse? _selectedVoyage;
    private bool _loading;
    private bool _billsLoading;
    private int? _selectedVesselId;

    // lookup data
    private async Task<IReadOnlyList<VesselResponse>> Vessels()
    {
        return await VesselService.GetActiveAsync();
    }
    private async Task<IReadOnlyList<PortResponse>> Ports()
    {
        return await PortService.GetActiveAsync();
    }

    private async Task<IReadOnlyList<CompanyResponse>> Companies()
    {
        return await CompanyService.GetActiveAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _voyages = await VoyageService.GetActiveVoyagesAsync();
        _vessels = await VesselService.GetActiveAsync();
        _loading = false;
    }

    // ── Select / navigate ─────────────────────────────────────────────────────
    private async Task SelectVoyage(VoyageResponse voyage)
    {

        _selectedVoyage = voyage;
        _billsLoading = true;
        _docs = await DocumentService.GetByVoyageAsync(voyage.VoyageId, true);
        _bills = await BillOfLadingService.GetByVoyageAsync(voyage.VoyageId);
        _billsLoading = false;
    }

    // ── Voyage CRUD ───────────────────────────────────────────────────────────
    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            [nameof(VoyageDialog.Voyage)] = null,
            [nameof(VoyageDialog.Vessels)] = await Vessels(),
            [nameof(VoyageDialog.Ports)] = await Ports()
        };

        var dialog = await DialogService.ShowAsync<VoyageDialog>("New Voyage", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: CreateVoyageRequest r })
        {
            await VoyageService.CreateAsync(
                r.VesselId, r.VoyageNumber, r.VoyageMonth,
                departurePortId: r.DeparturePortId,
                arrivalPortId: r.ArrivalPortId,
                departureDate: r.DepartureDate,
                arrivalDate: r.ArrivalDate,
                cargoType: r.CargoType,
                cargoQuantityMt: r.CargoQuantityMt,
                notes: r.Notes);

            _voyages = await VoyageService.GetActiveVoyagesAsync();
            Snackbar.Add("Voyage created", Severity.Success);
        }
    }

    private async Task OpenEditDialog(VoyageResponse voyage)
    {
        var parameters = new DialogParameters
        {
            [nameof(VoyageDialog.Voyage)] = voyage,
            [nameof(VoyageDialog.Vessels)] = await Vessels(),
            [nameof(VoyageDialog.Ports)] = await Ports()
        };

        var dialog = await DialogService.ShowAsync<VoyageDialog>("Edit Voyage", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: UpdateVoyageRequest r })
        {
            await VoyageService.UpdateAsync(
                voyage.VoyageId,
                r.DeparturePortId, r.ArrivalPortId,
                r.DepartureDate, r.ArrivalDate,
                r.CargoType, r.CargoQuantityMt,
                r.Notes);

            _voyages = await VoyageService.GetActiveVoyagesAsync();
            if (_selectedVoyage?.VoyageId == voyage.VoyageId)
                _selectedVoyage = await VoyageService.GetWithStopsAsync(voyage.VoyageId);

            Snackbar.Add("Voyage updated", Severity.Success);
        }
    }

    private async Task ConfirmDelete(VoyageResponse voyage)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Voyage",
            $"Delete voyage {voyage.VoyageNumber}?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed is true)
        {
            await VoyageService.DeleteAsync(voyage.VoyageId);
            if (_selectedVoyage?.VoyageId == voyage.VoyageId) _selectedVoyage = null;
            _voyages = await VoyageService.GetActiveVoyagesAsync();
            Snackbar.Add("Voyage deleted", Severity.Success);
        }
    }

    private async Task LoadByVessel(int? vesselId)
    {
        _selectedVesselId = vesselId;


        if (vesselId == 0 || vesselId == null)
        {
            _byVessel = _voyages;
        }
        else
        {
            var result = await VoyageService.GetByVesselAsync(vesselId.Value);
            _byVessel = result.ToList(); // new reference, forces Blazor diff to detect change    
        }
        StateHasChanged();
    }

    // ── Stop ──────────────────────────────────────────────────────────────────
    private async Task OpenAddStopDialog()
    {
        // نفس pattern الـ dialog — تبنيه لاحقاً لما تحتاجه
    }

    // ── BL CRUD ───────────────────────────────────────────────────────────────
    private async Task OpenAddBillDialog()
    {
        var parameters = new DialogParameters
        {
            [nameof(BillOfLadingDialog.Companies)] = await Companies(),

            [nameof(BillOfLadingDialog.Ports)] = await Ports(),

            [nameof(BillOfLadingDialog.VoyageId)] = _selectedVoyage?.VoyageId
        };

        var dialog = await DialogService.ShowAsync<BillOfLadingDialog>("New Bill of Lading", parameters);
        var result = await dialog.Result;
        if (result is {Canceled : false, Data : CreateBillOfLadingRequest bill})
        {
            var create = await BillOfLadingService.CreateAsync(bill);
            _bills = await BillOfLadingService.GetByVoyageAsync(bill.VoyageId);
            Snackbar.Add("Bill Off Lading created", Severity.Success);
        }
    }

    private async Task OpenEditBillDialog(BillOfLadingResponse bl)
    {

    }

    private async Task OpenViewBillDialog(BillOfLadingResponse bl)
    {
        var parameters = new DialogParameters
        {

        };

        await DialogService.ShowAsync<BillOfLadingDialog>("Bill of Lading", parameters);
    }

    private async Task ConfirmDeleteBill(BillOfLadingResponse bl)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete B/L",
            $"Delete BL {bl.BlNumber}?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed is true)
        {
            await BillOfLadingService.DeleteAsync(bl.Id!.Value);
            _bills = await BillOfLadingService.GetByVoyageAsync(_selectedVoyage!.VoyageId);
            Snackbar.Add("Bill of Lading deleted", Severity.Success);
        }
    }


    private void HandleBack()
    {
        _selectedVoyage = null;
        _bills = [];
    }
}