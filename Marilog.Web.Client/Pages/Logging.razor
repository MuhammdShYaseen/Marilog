@page "/admin/logs"
@using MudBlazor
@using Contracts.Models
@using Marilog.Contracts.DTOs.LogDTOs
@namespace Marilog.Web.Client

@inject Marilog.Contracts.Interfaces.LogService.ILogReaderService LogService

@* ── Stats Bar ─────────────────────────────────────────────────────────────── *@
@if (_stats is not null)
{
    <MudGrid Spacing="2" Class="mb-4">

        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1" Style="border-left: 4px solid var(--mud-palette-error)">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Errors</MudText>
                <MudText Typo="Typo.h5" Color="Color.Error" Style="font-weight:700">
                    @_stats.Errors.ToString("N0")
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1" Style="border-left: 4px solid var(--mud-palette-warning)">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Warnings</MudText>
                <MudText Typo="Typo.h5" Color="Color.Warning" Style="font-weight:700">
                    @_stats.Warnings.ToString("N0")
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1" Style="border-left: 4px solid var(--mud-palette-info)">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Info</MudText>
                <MudText Typo="Typo.h5" Color="Color.Info" Style="font-weight:700">
                    @_stats.Info.ToString("N0")
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1" Style="border-left: 4px solid var(--mud-palette-default)">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Debug</MudText>
                <MudText Typo="Typo.h5" Style="font-weight:700">
                    @_stats.Debug.ToString("N0")
                </MudText>
            </MudPaper>
        </MudItem>

    </MudGrid>
}

@* ── Filters ───────────────────────────────────────────────────────────────── *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid Spacing="2" AlignItems="AlignItems.Center">

        @* File selector *@
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string"
                       Value="_selectedFile"
                       ValueChanged="OnFileChanged"
                       Label="Log File"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Clearable="true">
                @foreach (var f in _files)
                {
                    <MudSelectItem Value="@f">@f</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @* Level filter *@
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string"
                       @bind-Value="_selectedLevels"
                       Label="Level"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Clearable="true">
                <MudSelectItem Value="@("ERR")">
                    <MudChip T="string" Color="Color.Error"    Size="Size.Small">ERR</MudChip>
                </MudSelectItem>
                <MudSelectItem Value="@("WRN")">
                    <MudChip T="string" Color="Color.Warning"  Size="Size.Small">WRN</MudChip>
                </MudSelectItem>
                <MudSelectItem Value="@("INF")">
                    <MudChip T="string" Color="Color.Info"     Size="Size.Small">INF</MudChip>
                </MudSelectItem>
                <MudSelectItem Value="@("DBG")">
                    <MudChip T="string" Color="Color.Default"  Size="Size.Small">DBG</MudChip>
                </MudSelectItem>
            </MudSelect>
        </MudItem>

        @* Free search *@
        <MudItem xs="12" sm="6" md="3">
            <MudTextField T="string"
                          @bind-Value="_search"
                          Label="Search"
                          Placeholder="message, exception, path..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true" />
        </MudItem>

        @* HTTP path filter *@
        <MudItem xs="12" sm="6" md="2">
            <MudTextField T="string"
                          @bind-Value="_httpPath"
                          Label="HTTP Path"
                          Placeholder="/api/..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true" />
        </MudItem>

        @* HTTP status filter *@
        <MudItem xs="6" sm="3" md="1">
            <MudNumericField T="int?"
                             @bind-Value="_httpStatus"
                             Label="Status"
                             Placeholder="500"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Min="100"
                             Max="599" />
        </MudItem>

        @* Actions *@
        <MudItem xs="12">
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.FilterList"
                           OnClick="ApplyFilters">
                    Apply
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearFilters">
                    Clear
                </MudButton>
                <MudSpacer />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="align-self:center">
                    @_totalCount.ToString("N0") entries
                </MudText>
            </MudStack>
        </MudItem>

    </MudGrid>
</MudPaper>

@* ── Table ─────────────────────────────────────────────────────────────────── *@
<MudPaper Elevation="2">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    <MudDataGrid T="LogEntry"
                 Items="_entries"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 RowClick="OnRowClick"
                 RowStyle="cursor:pointer"
                 Breakpoint="Breakpoint.Sm">
        <Columns>

            <TemplateColumn Title="Level" CellStyle="width:70px">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@GetLevelColor(context.Item.Level)"
                             Size="Size.Small"
                             Variant="Variant.Filled"
                             Style="min-width:48px; justify-content:center">
                        @context.Item.Level
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Time" CellStyle="width:140px" SortBy="x => x.Timestamp">
                <CellTemplate>
                    <MudText Typo="Typo.caption" Style="white-space:nowrap">
                        @context.Item.Timestamp.ToString("HH:mm:ss")
                        <br />
                        <span style="opacity:0.6">@context.Item.Timestamp.ToString("dd MMM")</span>
                    </MudText>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Message" SortBy="x => x.Message">
                <CellTemplate>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2"
                                 Style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:420px">
                            @context.Item.Message
                        </MudText>
                        @if (context.Item.ExceptionType is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">
                                @context.Item.ExceptionType: @context.Item.ExceptionMessage
                            </MudText>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="HTTP" CellStyle="width:200px">
                <CellTemplate>
                    @if (context.Item.HttpMethod is not null)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     Style="font-size:10px; min-width:40px">
                                @context.Item.HttpMethod
                            </MudChip>
                            <MudText Typo="Typo.caption"
                                     Color="@GetStatusColor(context.Item.HttpStatus)"
                                     Style="font-weight:600">
                                @context.Item.HttpStatus
                            </MudText>
                            @if (context.Item.DurationMs.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @context.Item.DurationMs.Value.ToString("N0")ms
                                </MudText>
                            }
                        </MudStack>
                        <MudText Typo="Typo.caption"
                                 Color="Color.Secondary"
                                 Style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:180px">
                            @context.Item.HttpPath
                        </MudText>
                    }
                    else if (context.Item.HttpPath is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.Item.HttpPath
                        </MudText>
                    }
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Error ID" CellStyle="width:120px">
                <CellTemplate>
                    @if (context.Item.ErrorId is not null)
                    {
                        <MudText Typo="Typo.caption"
                                 Style="font-family:monospace; font-size:10px; opacity:0.7">
                            @context.Item.ErrorId[..8]…
                        </MudText>
                    }
                </CellTemplate>
            </TemplateColumn>

        </Columns>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                No log entries found.
            </MudText>
        </NoRecordsContent>

    </MudDataGrid>

    @* ── Pagination ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="pa-3" Justify="Justify.SpaceBetween">
        <MudSelect T="int"
                   @bind-Value="_pageSize"
                   Label="Per page"
                   Variant="Variant.Text"
                   Margin="Margin.Dense"
                   Style="width:80px">
            <MudSelectItem Value="25">25</MudSelectItem>
            <MudSelectItem Value="50">50</MudSelectItem>
            <MudSelectItem Value="100">100</MudSelectItem>
            <MudSelectItem Value="200">200</MudSelectItem>
        </MudSelect>

        <MudPagination Count="_totalPages"
                       Selected="_currentPage"
                       SelectedChanged="OnPageChanged"
                       ShowFirstButton="true"
                       ShowLastButton="true"
                       BoundaryCount="1"
                       MiddleCount="3" />
    </MudStack>
</MudPaper>

@* ── Detail Drawer ─────────────────────────────────────────────────────────── *@
<MudDrawer @bind-Open="_drawerOpen"
           Anchor="Anchor.End"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Width="520px"
           ClipMode="DrawerClipMode.Never">

    @if (_selected is not null)
    {
        <MudDrawerHeader>
            <MudStack Row="true" AlignItems="AlignItems.Center" Style="width:100%">
                <MudChip T="string"
                         Color="@GetLevelColor(_selected.Level)"
                         Variant="Variant.Filled">
                    @_selected.Level
                </MudChip>
                <MudText Typo="Typo.subtitle1" Style="font-weight:600">
                    @_selected.Timestamp.ToString("dd MMM yyyy  HH:mm:ss")
                </MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               OnClick="() => _drawerOpen = false" />
            </MudStack>
        </MudDrawerHeader>

        <MudDivider />

        <div class="pa-4" style="overflow-y:auto; height:calc(100vh - 80px)">
            <MudStack Spacing="3">

                @* Message *@
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">MESSAGE</MudText>
                    <MudPaper Class="pa-3" Elevation="0"
                              Style="background:var(--mud-palette-background-grey); border-radius:8px">
                        <MudText Typo="Typo.body2" Style="word-break:break-word">
                            @_selected.Message
                        </MudText>
                    </MudPaper>
                </div>

                @* HTTP Info *@
                @if (_selected.HttpMethod is not null || _selected.HttpPath is not null)
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">HTTP</MudText>
                        <MudPaper Class="pa-3" Elevation="0"
                                  Style="background:var(--mud-palette-background-grey); border-radius:8px">
                            <MudGrid Spacing="1">
                                @if (_selected.HttpMethod is not null)
                                {
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Method</MudText>
                                        <MudText Typo="Typo.body2" Style="font-weight:600">@_selected.HttpMethod</MudText>
                                    </MudItem>
                                }
                                @if (_selected.HttpStatus.HasValue)
                                {
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                                        <MudText Typo="Typo.body2"
                                                 Color="@GetStatusColor(_selected.HttpStatus)"
                                                 Style="font-weight:700">
                                            @_selected.HttpStatus
                                        </MudText>
                                    </MudItem>
                                }
                                @if (_selected.DurationMs.HasValue)
                                {
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Duration</MudText>
                                        <MudText Typo="Typo.body2">@_selected.DurationMs.Value.ToString("N1")ms</MudText>
                                    </MudItem>
                                }
                                @if (_selected.HttpPath is not null)
                                {
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Path</MudText>
                                        <MudText Typo="Typo.body2"
                                                 Style="font-family:monospace; word-break:break-all">
                                            @_selected.HttpPath
                                        </MudText>
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudPaper>
                    </div>
                }

                @* Exception *@
                @if (_selected.ExceptionType is not null)
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">EXCEPTION</MudText>
                        <MudPaper Class="pa-3" Elevation="0"
                                  Style="background:var(--mud-palette-error-lighten); border-radius:8px">
                            <MudText Typo="Typo.body2" Color="Color.Error" Style="font-weight:600">
                                @_selected.ExceptionType
                            </MudText>
                            <MudText Typo="Typo.body2" Style="word-break:break-word">
                                @_selected.ExceptionMessage
                            </MudText>
                        </MudPaper>
                    </div>
                }

                @* Stack Trace *@
                @if (_selected.StackTrace is not null)
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">STACK TRACE</MudText>
                        <MudPaper Class="pa-3" Elevation="0"
                                  Style="background:var(--mud-palette-background-grey); border-radius:8px; overflow-x:auto">
                            <pre style="font-size:11px; margin:0; white-space:pre-wrap; word-break:break-word; opacity:0.85">@_selected.StackTrace</pre>
                        </MudPaper>
                    </div>
                }

                @* Error ID *@
                @if (_selected.ErrorId is not null)
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">ERROR ID</MudText>
                        <MudText Typo="Typo.body2"
                                 Style="font-family:monospace; opacity:0.7">
                            @_selected.ErrorId
                        </MudText>
                    </div>
                }

                @* Line Number *@
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Line @_selected.LineNumber
                    </MudText>
                </div>

            </MudStack>
        </div>
    }
</MudDrawer>

    @code {

    // ── State ─────────────────────────────────────────────────────────────────
    private IReadOnlyList<LogEntry> _entries   = [];
    private IReadOnlyList<string>   _files     = [];
    private LogStats?               _stats;
    private bool                    _loading;
    private bool                    _drawerOpen;
    private LogEntry?               _selected;

    // ── Filters ───────────────────────────────────────────────────────────────
    private string? _selectedFile;
    private string? _selectedLevels;
    private string? _search;
    private string? _httpPath;
    private int?    _httpStatus;

    // ── Pagination ────────────────────────────────────────────────────────────
    private int _currentPage = 1;
    private int _pageSize    = 50;
    private int _totalCount;
    private int _totalPages  => (int)Math.Ceiling(_totalCount / (double)_pageSize);

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _files = await LogService.GetAvailableFilesAsync();
        await LoadAsync();
    }

    // ── Load ──────────────────────────────────────────────────────────────────
    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var query = BuildQuery();
            var result = await LogService.QueryAsync(query);

            _entries    = result.Items;
            _totalCount = result.TotalCount;
            _stats      = result.Stats;
        }
        finally
        {
            _loading = false;
        }
    }

    private LogQuery BuildQuery() => new()
    {
        FileName   = _selectedFile,
        Levels     = _selectedLevels,
        Search     = _search,
        HttpPath   = _httpPath,
        HttpStatus = _httpStatus,
        Page       = _currentPage,
        PageSize   = _pageSize,
        Descending = true,
    };

    // ── Events ────────────────────────────────────────────────────────────────
    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task ClearFilters()
    {
        _selectedLevels = null;
        _search         = null;
        _httpPath       = null;
        _httpStatus     = null;
        _currentPage    = 1;
        await LoadAsync();
    }

    private async Task OnFileChanged(string? file)
    {
        _selectedFile = file;
        _currentPage  = 1;
        await LoadAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadAsync();
    }

    private void OnRowClick(DataGridRowClickEventArgs<LogEntry> args)
    {
        _selected    = args.Item;
        _drawerOpen  = true;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private static Color GetLevelColor(string level) => level switch
    {
        "ERR" => Color.Error,
        "WRN" => Color.Warning,
        "INF" => Color.Info,
        "DBG" => Color.Default,
        _     => Color.Default
    };

    private static Color GetStatusColor(int? status) => status switch
    {
        >= 500 => Color.Error,
        >= 400 => Color.Warning,
        >= 200 => Color.Success,
        _      => Color.Default
    };
}
