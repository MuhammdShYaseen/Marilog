@page "/contracts"
@using Marilog.Contracts.Common
@using Marilog.Contracts.DTOs.Reports.Contract
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Shared.UI.Pages.Contracts
@using Marilog.Contracts.DTOs.Requests.ContractDTOs
@using Shared.UI.Pages.Contracts.Dialogs
@using MudBlazor

@inject IContractService ContractService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


@inject IContractService ContractService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICompanyService CompanyService
@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <SharedContractsPage @ref="_sharedPage"
                         Paged="_paged"
                         GetContractDetail="GetContractDetail"
                         Companies="AllCompanies"
                         OnAddClicked="OpenAddDialog"
                         OnEditClicked="OpenEditDialog"
                         OnActivateClicked="Activate"
                         OnSuspendClicked="Suspend"
                         OnTerminateClicked="Terminate"
                         OnMarkExpiredClicked="MarkExpired"
                         OnPrevPage="PrevPage"
                         OnNextPage="NextPage"
                         OnAddPartyClicked="OpenAddPartyDialog"
                         OnRemovePartyClicked="OpenRemovePartyDialog"
                         OnRecordAmendmentClicked="OpenRecordAmendmentDialog"
                         OnChangeExpiryClicked="OpenChangeExpiryDialog"
                         OnAttachFileClicked="OpenAttachFileDialog" />
}
@code{

    private const int PageSize = 15;
    private IReadOnlyList<CompanyResponse> AllCompanies = [];
    private SharedContractsPage _sharedPage = default!;
    private PagedResponse<ContractSummary>? _paged;
    private bool _loading = true;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    // ─── Load ──────────────────────────────────────────────────────────────

    private async Task LoadAsync()
    {
        _loading = true;
        _paged = await ContractService.GetPagedAsync(new ContractFilter
        {
            Page = _page,
            PageSize = PageSize
        });
        //AllCompanies = await CompanyService.GetAllAsync();
        _loading = false;
    }

    private async Task RefreshSelected(int id)
    {
        var updated = await ContractService.GetByIdAsync(id);
        if (updated is not null)
            _sharedPage?.UpdateSelected(updated);
    }

    private async Task PrevPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadAsync();
        }
    }

    private async Task NextPage()
    {
        if (_paged?.HasNext == true)
        {
            _page++;
            await LoadAsync();
        }
    }

    // ─── Dialogs ───────────────────────────────────────────────────────────

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<ContractFormDialog>("New Contract");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var data = (CreateContractRequest)result.Data!;
        var outcome = await ContractService.CreateAsync(
            data.ContractNumber,
            data.Type,
            data.EffectiveDate,
            data.ExpiryDate,
            data.Notes
        );

        if (outcome.IsSuccess)
        {
            Snackbar.Add("Contract created.", Severity.Success);
            await LoadAsync();
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    private async Task OpenEditDialog(ContractSummary contract)
    {
        var parameters = new DialogParameters { ["ContractId"] = contract.Id };
        var dialog = await DialogService.ShowAsync<ContractFormDialog>("Edit Contract", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var data = (CreateContractRequest)result.Data!;
        var outcome = await ContractService.UpdateAsync(
            contract.Id,
            data.ContractNumber,
            data.Type,
            data.EffectiveDate,
            data.ExpiryDate,
            data.Notes
        );

        if (outcome.IsSuccess)
        {
            Snackbar.Add("Contract updated.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(contract.Id);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    // ─── Status Actions ────────────────────────────────────────────────────

    private async Task Activate(int id)
    {
        var result = await ContractService.ActivateAsync(id);
        if (result.IsSuccess)
        {
            Snackbar.Add("Contract activated.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(id);
        }
        else
            Snackbar.Add(result.Error!, Severity.Error);
    }

    private async Task Suspend(int id)
    {
        var result = await ContractService.SuspendAsync(id, "Suspended by user");
        if (result.IsSuccess)
        {
            Snackbar.Add("Contract suspended.", Severity.Warning);
            await LoadAsync();
            await RefreshSelected(id);
        }
        else
            Snackbar.Add(result.Error!, Severity.Error);
    }

    private async Task Terminate(int id)
    {
        var dialog = await DialogService.ShowAsync<TerminateContractDialog>("Terminate Contract");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var outcome = await ContractService.TerminateAsync(id, "Terminated by user");
        if (outcome.IsSuccess)
        {
            Snackbar.Add("Contract terminated.", Severity.Error);
            await LoadAsync();
            await RefreshSelected(id);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    private async Task MarkExpired(int id)
    {
        var result = await ContractService.MarkExpiredAsync(id);
        if (result.IsSuccess)
        {
            Snackbar.Add("Contract marked as expired.", Severity.Info);
            await LoadAsync();
            await RefreshSelected(id);
        }
        else
            Snackbar.Add(result.Error!, Severity.Error);
    }

    // ─── Parties ───────────────────────────────────────────────────────────

    private async Task OpenAddPartyDialog(int contractId)
    {
        AllCompanies = await CompanyService.GetActiveAsync();
        var parameters = new DialogParameters
        {
            [nameof(AddPartyDialog.Companies)] = AllCompanies
        };
        var dialog = await DialogService.ShowAsync<AddPartyDialog>("Add Party", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var data = (PartyRequest)result.Data!;
        var outcome = await ContractService.AddPartyAsync(contractId, data.CompanyId, data.Role);
        if (outcome.IsSuccess)
        {
            Snackbar.Add("Party added.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(contractId);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    private async Task OpenRemovePartyDialog((int ContractId, ContractPartyResponse Party) args)
    {
        var parameters = new DialogParameters
        {
            ["CompanyName"] = args.Party.CompanyName,
            ["Role"] = args.Party.Role
        };

        var dialog = await DialogService.ShowAsync<Shared.UI.Pages.Contracts.Dialogs.RemovePartyDialog>("Remove Party", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var outcome = await ContractService.RemovePartyAsync(args.ContractId, args.Party.CompanyId, args.Party.Role);
        if (outcome.IsSuccess)
        {
            Snackbar.Add("Party removed.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(args.ContractId);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    // ─── Amendments ────────────────────────────────────────────────────────

    private async Task OpenRecordAmendmentDialog(int contractId)
    {
        var dialog = await DialogService.ShowAsync<Shared.UI.Pages.Contracts.Dialogs.RecordAmendmentDialog>("Record Amendment");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var data = (Marilog.Contracts.DTOs.Requests.ContractDTOs.AmendmentRequest)result.Data!;
        var outcome = await ContractService.RecordAmendmentAsync(
            contractId,
            data.Description,
            data.EffectiveDate,
            data.ChangedBy
        );

        if (outcome.IsSuccess)
        {
            Snackbar.Add("Amendment recorded.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(contractId);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    private async Task OpenChangeExpiryDialog((int ContractId, DateOnly CorrentExpiryDate)arg)
    {

        var parameters = new DialogParameters
        {
            [nameof(ChangeExpiryDialog._ExpiryDate)] = arg.CorrentExpiryDate.ToDateTime(TimeOnly.MinValue)
        };

        var dialog = await DialogService.ShowAsync<ChangeExpiryDialog>("Change Expiry", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var data = (ChangeExpiryRequest)result.Data!;
        var outcome = await ContractService.ChangeExpiryAsync(arg.ContractId, data.NewExpiryDate, data.ChangedBy);
        if (outcome.IsSuccess)
        {
            Snackbar.Add("Expiry extended.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(arg.ContractId);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    // ─── Documents ─────────────────────────────────────────────────────────

    private async Task OpenAttachFileDialog(int contractId)
    {
        var dialog = await DialogService.ShowAsync<AttachFileDialog>("Attach File");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var data = (AttachFileRequest)result.Data!;
        var outcome = await ContractService.AttachFileAsync(contractId, data.FileUrl, data.FileName);
        if (outcome.IsSuccess)
        {
            Snackbar.Add("File attached.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(contractId);
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    private async Task<ContractDetailResponse> GetContractDetail(int arg)
    {
        var response = await ContractService.GetByIdAsync(arg);
        return response ?? new();
    }



}