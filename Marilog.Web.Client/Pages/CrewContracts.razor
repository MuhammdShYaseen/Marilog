@page "/crew-contracts"
@using Marilog.Contracts.DTOs.Requests.CrewDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Shared.UI.Pages.CrewContracts
@using MudBlazor

@inject ICrewContractService CrewContractService
@inject IVesselService       VesselService
@inject IPersonService       PersonService
@inject IRankService         RankService
@inject IPortService         PortService
@inject ISnackbar            Snackbar
@inject IDialogService       DialogService

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <SharedCrewContractsPage Contracts="@_contracts"
                      ExpiringContracts="@_expiring"
                      Vessels="@_vessels"
                      OnAddClicked="OpenAddDialog"
                      OnEditClicked="OpenEditDialog"
                      OnDeleteClicked="ConfirmDelete"
                      OnSignOffClicked="OpenSignOffDialog" />
}

@code {
    private IReadOnlyList<CrewContractResponse> _contracts = [];
    private IReadOnlyList<CrewContractResponse> _expiring  = [];
    private IReadOnlyList<VesselResponse>       _vessels   = [];
    private IReadOnlyList<PersonResponse>       _persons   = [];
    private IReadOnlyList<RankResponse>         _ranks     = [];
    private IReadOnlyList<PortResponse>         _ports     = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    // ─── Load ──────────────────────────────────────────────────────────────

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var t1 = CrewContractService.GetAllAsync();
            var t2 = CrewContractService.GetAboutExpireAsync();
            var t3 = VesselService.GetActiveAsync();
            var t4 = PersonService.GetActiveAsync();
            var t5 = RankService.GetActiveAsync();
            var t6 = PortService.GetAllAsync();

            await Task.WhenAll(t1, t2, t3, t4, t5, t6);

            _contracts = t1.Result;
            _expiring  = t2.Result;
            _vessels   = t3.Result;
            _persons   = t4.Result;
            _ranks     = t5.Result;
            _ports     = t6.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    // ─── Dialogs ───────────────────────────────────────────────────────────

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            [nameof(CrewContractFormDialog.Persons)] = _persons,
            [nameof(CrewContractFormDialog.Vessels)] = _vessels,
            [nameof(CrewContractFormDialog.Ranks)] = _ranks,
            [nameof(CrewContractFormDialog.Ports)] = _ports,
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CrewContractFormDialog>("New Contract", parameters, options);
        var result  = await dialog.Result;
        if (result is null || result.Canceled) return;

        var req = (CreateCrewContractRequest)result.Data!;
        try
        {
            await CrewContractService.CreateAsync(
                req.DurationInMonth,
                req.PersonId,
                req.VesselId,
                req.RankId,
                req.MonthlyWage,
                req.SignOnDate,
                req.SignOnPort,
                req.Notes);

            Snackbar.Add("Contract created.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenEditDialog(CrewContractResponse contract)
    {
        var parameters = new DialogParameters
        {
            [nameof(CrewContractFormDialog.Contract)] = contract,
            [nameof(CrewContractFormDialog.Persons)] = _persons,
            [nameof(CrewContractFormDialog.Vessels)] = _vessels,
            [nameof(CrewContractFormDialog.Ranks)] = _ranks,
            [nameof(CrewContractFormDialog.Ports)] = _ports,
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CrewContractFormDialog>("Edit Contract", parameters, options);
        var result  = await dialog.Result;
        if (result is null || result.Canceled) return;

        var req     = (UpdateCrewContractRequest)result.Data!;
        var outcome = await CrewContractService.UpdateAsync(
            req.Id,
            req.DurationInMonth,
            req.PersonId,
            req.VesselId,
            req.RankId,
            req.MonthlyWage,
            req.SignOnDate,
            req.SignOnPort,
            req.Notes);

        if (outcome.IsSuccess)
        {
            Snackbar.Add("Contract updated.", Severity.Success);
            await LoadAsync();
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    private async Task OpenSignOffDialog(CrewContractResponse contract)
    {
        var parameters = new DialogParameters
        {
            [nameof(SignOffDialog.Contract)] = contract,
            [nameof(SignOffDialog.Ports)]    = _ports,
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<SignOffDialog>("Sign Off", parameters, options);
        var result  = await dialog.Result;
        if (result is null || result.Canceled) return;

        var req     = (SignOffCrewContractRequest)result.Data!;
        var outcome = await CrewContractService.SignOffAsync(
            contract.ContractId,
            req.SignOffDate,
            req.SignOffPort);

        if (outcome.IsSuccess)
        {
            Snackbar.Add("Signed off successfully.", Severity.Success);
            await LoadAsync();
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }

    // ─── Delete ────────────────────────────────────────────────────────────

    private async Task ConfirmDelete(CrewContractResponse contract)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Contract",
            $"Delete contract for '{contract.PersonFullName}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        var outcome = await CrewContractService.DeleteAsync(contract.ContractId);
        if (outcome.IsSuccess)
        {
            Snackbar.Add("Contract deleted.", Severity.Success);
            await LoadAsync();
        }
        else
            Snackbar.Add(outcome.Error!, Severity.Error);
    }
}