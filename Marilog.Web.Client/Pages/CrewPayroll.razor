@page "/payroll"
@using Marilog.Contracts.DTOs.Requests.CrewPayrollDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Kernel.Enums
@using Marilog.Shared.UI.Pages.CrewPayroll
@using MudBlazor

@inject ICrewPayrollService PayrollService
@inject ICrewContractService CrewContractService
@inject IVoyageService VoyageService
@inject IOfficeService OfficeService
@inject ISwiftTransferService SwiftTransferService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <SharedCrewPayrollPage PayrollByMonth="_byMonth"
                           PayrollByStatus="_byStatus"
                           Outstanding="_outstanding"
                           OnAddClicked="OpenAddDialog"
                           OnEditClicked="OpenEditDialog"
                           OnDeleteClicked="ConfirmDelete"
                           OnApproveClicked="Approve"
                           OnCancelClicked="Cancel"
                           OnPayClicked="OpenPayDialog"
                           OnMonthSelected="LoadByMonth"
                           OnStatusChanged="LoadByStatus" />
}

@code {
    private IReadOnlyList<CrewPayrollResponse> _byMonth = [];
    private IReadOnlyList<CrewPayrollResponse> _byStatus = [];
    private IReadOnlyList<CrewPayrollResponse> _outstanding = [];
    private IReadOnlyList<CrewContractResponse> _contracts = [];
    private IReadOnlyList<VoyageResponse> _voyages = [];
    private IReadOnlyList<OfficeResponse> _offices = [];
    private IReadOnlyList<SwiftTransferResponse> _swifts = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            var t1 = PayrollService.GetByMonthAsync(today);
            var t2 = PayrollService.GetByStatusAsync(PayrollStatus.Draft);
            var t3 = PayrollService.GetOutstandingAsync();
            var t4 = CrewContractService.GetAllAsync();
            var t5 = VoyageService.GetActiveVoyagesAsync();
            var t6 = OfficeService.GetActiveAsync();
            var t7 = SwiftTransferService.GetUnallocatedAsync();
            await Task.WhenAll(t1, t2, t3, t4, t5, t6, t7);

            _byMonth = t1.Result;
            _byStatus = t2.Result;
            _outstanding = t3.Result;
            _contracts = t4.Result;
            _voyages = t5.Result;
            _offices = t6.Result;
            _swifts = t7.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadByMonth(DateOnly month)
    {
        _byMonth = await PayrollService.GetByMonthAsync(month);
        StateHasChanged();
    }

    private async Task LoadByStatus(PayrollStatus? status)
    {
        _byStatus = status is null
            ? await PayrollService.GetByStatusAsync(PayrollStatus.Draft)
            : await PayrollService.GetByStatusAsync(status.Value);
        StateHasChanged();
    }


    //----PAYROLL DIALOGS--------------------------------------------------

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            ["Contracts"] = _contracts
        };
        var dialog = await DialogService.ShowAsync<CrewPayrollFormDialog>("New Payroll", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
            return;

        if (result.Data is CreateCrewPayrollRequest request)
        {
            await PayrollService.CreateAsync
            (
                request.ContractId,
                request.PayrollMonth,
                request.Allowances,
                request.Deductions,
                request.Notes
            );
            Snackbar.Add("Payroll Added.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task OpenEditDialog(CrewPayrollResponse payroll)
    {
        var parameters = new DialogParameters
        {
            ["Payroll"] = payroll,
            ["Contracts"] = _contracts
        };

        var dialog = await DialogService.ShowAsync<CrewPayrollFormDialog>("Edit Payroll", parameters);

        var result = await dialog.Result;

        if (result is null || result.Canceled)
            return;

        if (result.Data is UpdateCrewPayrollRequest request)
        {
            await PayrollService.UpdateAsync
            (
                payroll.Id,
                request.ContractId,
                request.Allowances,
                request.Deductions,
                request.Notes
            );
            Snackbar.Add("Payroll Updated.", Severity.Success);
            await LoadAsync();
        }
    }

    // ─── Payroll Actions ───────────────────────────────────────────────────
    private async Task Approve(CrewPayrollResponse payroll)
    {
        await PayrollService.ApproveAsync(payroll.Id);
        Snackbar.Add("Payroll approved.", Severity.Success);
        await LoadAsync();
    }

    private async Task Cancel(CrewPayrollResponse payroll)
    {
        await PayrollService.CancelAsync(payroll.Id, "Cancelled by user");
        Snackbar.Add("Payroll cancelled.", Severity.Warning);
        await LoadAsync();
    }

    private async Task ConfirmDelete(CrewPayrollResponse payroll)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Payroll",
            $"Delete payroll for '{payroll.PersonFullName}' — {payroll.PayrollMonth:MMM yyyy}?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        await PayrollService.DeleteAsync(payroll.Id);
        Snackbar.Add("Payroll deleted.", Severity.Success);
        await LoadAsync();
    }

    // ─── Disbursement ──────────────────────────────────────────────────────

    private async Task OpenPayDialog(CrewPayrollResponse payroll)
    {
        var parameters = new DialogParameters
        {
            ["Voyages"] = _voyages,
            ["Offices"] = _offices,
            ["SwiftTransfers"] = _swifts
        };

        var dialog = await DialogService.ShowAsync<PaymentDialog>("Record Payment", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var (method, data) = ((PaymentMethod, object))result.Data!;

        var outcome = method switch
        {
            PaymentMethod.CashOnBoard => await HandlePayCash(payroll.Id, (PayCashRequest)data),
            PaymentMethod.CashAtOffice => await HandlePayAtOffice(payroll.Id, (PayAtOfficeRequest)data),
            PaymentMethod.BankTransfer => await HandlePayByBankTransfer(payroll.Id, (PayByBankTransferRequest)data),
            _ => throw new InvalidOperationException()
        };

        if (outcome.Id > 0)
        {
            Snackbar.Add("Payment recorded.", Severity.Success);
            await LoadAsync();
        }
    }

    private Task<DisbursementResponse> HandlePayCash(int payrollId, PayCashRequest r) =>
        PayrollService.PayCashAsync(payrollId, r.VoyageId, r.Amount, r.PaidOn, r.Notes);

    private Task<DisbursementResponse> HandlePayAtOffice(int payrollId, PayAtOfficeRequest r) =>
        PayrollService.PayAtOfficeAsync(payrollId, r.OfficeId, r.Amount, r.PaidOn,
                                        r.RecipientName, r.RecipientIdNumber, r.Notes);

    private Task<DisbursementResponse> HandlePayByBankTransfer(int payrollId, PayByBankTransferRequest r) =>
        PayrollService.PayByBankTransferAsync(payrollId, r.SwiftTransferId, r.Amount, r.PaidOn, r.Notes);

    // ─── Disbursement Actions ──────────────────────────────────────────────

    public async Task ConfirmDisbursement(int payrollId, DisbursementResponse disbursement)
    {
        await PayrollService.ConfirmDisbursementAsync(payrollId, disbursement.Id);
        Snackbar.Add("Disbursement confirmed.", Severity.Success);
        await LoadAsync();
    }

    public async Task CancelDisbursement(int payrollId, DisbursementResponse disbursement)
    {
        var parameters = new DialogParameters
        {
            ["Message"] = $"Cancel disbursement of {disbursement.Amount:N2} via {disbursement.Method}?"
        };

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Cancel Disbursement",
            $"Cancel disbursement of {disbursement.Amount:N2} via {disbursement.Method}?",
            yesText: "Cancel Disbursement",
            cancelText: "Back");

        if (confirmed != true) return;

        await PayrollService.CancelDisbursementAsync(payrollId, disbursement.Id, "Cancelled by user");
        Snackbar.Add("Disbursement cancelled.", Severity.Warning);
        await LoadAsync();
    }
}