    // =========================
    // FILTERED VIEW
    // =========================

    private IEnumerable<VesselModel> FilteredVessels =>
        string.IsNullOrWhiteSpace(SearchText)
            ? Vesselss
            : Vesselss.Where(v =>
                v.Name.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
                || v.ImoNumber.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

    // =========================
    // EVENTS
    // =========================

    private void OnSearchChanged(string? text)
    {
        SearchText = text;
    }

    private void OnSelectedChanged(VesselModel vessel)
    {
        SelectedVessel = vessel;
    }

    private void OpenAddDialog()
    {
        var vessel = new VesselModel();

        EditVessel(vessel);
    }

    private void EditVessel(VesselModel vessel)
    {
        EditingVessel = vessel;
        IsEditMode = true;
    }

    private void DeleteVessel(VesselModel vessel)
    {
        Vesselss.Remove(vessel);
    }

    // =========================
    // EDIT MODE
    // =========================

    private bool IsEditMode;

    private VesselModel EditingVessel = new();

    public class VesselModel
    {
        public Guid Id { get; set; } = Guid.NewGuid();

        public string Name { get; set; } = "";

        public string ImoNumber { get; set; } = "";

        public string Type { get; set; } = "";

        public string Flag { get; set; } = "";
    }

}