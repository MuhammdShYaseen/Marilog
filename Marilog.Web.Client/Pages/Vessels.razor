@page "/vessels"
@using Marilog.Shared.UI.Framework.Components.Inputs
@using Marilog.Shared.UI.Framework.Components.Collections
<StackPanel Spacing="16">

    <!-- Header -->

    <TextBlock Text="Vessels"
               FontSize="FontSize.Display"
               Bold="true"
               Foreground="ThemeColor.Primary" />

    <!-- Search + Add -->

    <Grid ColumnDefinitions="* Auto"
          ColumnGap="12">

        <GridCell Column="0">

            <TextBox TValue="string"
                     Text="@SearchText"
                     TextChanged="OnSearchChanged"
                     Placeholder="Search vessels..."
                     LeadingIcon="@Icons.Material.Filled.Search" />

        </GridCell>

        <GridCell Column="1">

            <Button Content="Add Vessel"
                    StartIcon="@Icons.Material.Filled.Add"
                    ButtonVariant="ButtonVariant.Filled"
                    Click="OpenAddDialog" />

        </GridCell>

    </Grid>

    <!-- List -->

    <CollectionView TItem="VesselModel"
                    Items="@FilteredVessels"
                    SelectionMode="Marilog.Shared.UI.Framework.Enums.SelectionMode.Single"
                    SelectedItem="@SelectedVessel"
                    SelectedItemChanged="OnSelectedChanged"
                    ItemSpacing="12">

        <DataTemplate Context="vessel">

            <Card Title="@vessel.Name"
                  Subtitle="@vessel.ImoNumber"
                  Elevation="ElevationLevel.Low">

                <StackPanel Spacing="8" >
                    <StackPanel Spacing="5" Orientation="Marilog.Shared.UI.Framework.Enums.Orientation.Horizontal">

                        <TextBlock Text="Flag:" Bold="true" />
                        <TextBlock Text="@vessel.Flag" />

                    </StackPanel>
                   
                    <StackPanel Spacing="5" Orientation="Marilog.Shared.UI.Framework.Enums.Orientation.Horizontal">

                        <TextBlock Text="Type:" Bold="true" />

                        <TextBlock Text="@vessel.Type" />

                    </StackPanel>
                    

                    <StackPanel Orientation="Marilog.Shared.UI.Framework.Enums.Orientation.Horizontal"
                                Spacing="8"
                                ChildJustify="HAlign.Right">

                        <Button Content="Edit"
                                ButtonVariant="ButtonVariant.Outlined"
                                StartIcon="@Icons.Material.Filled.Edit"
                                Click="() => EditVessel(vessel)" />

                        <Button Content="Delete"
                                ButtonVariant="ButtonVariant.Text"
                                StartIcon="@Icons.Material.Filled.Delete"
                                Click="() => DeleteVessel(vessel)" />

                    </StackPanel>

                </StackPanel>

            </Card>

        </DataTemplate>

    </CollectionView>

</StackPanel>

