@* VesselsPageHost.razor *@
@page "/vessels"
@using Marilog.Contracts.DTOs.Requests.Common
@using Marilog.Contracts.DTOs.Requests.VesselDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Kernel.Enums
@using Marilog.Shared.UI.Components.SharedDialogs
@using Marilog.Shared.UI.Pages.Vessels
@using Marilog.Web.Client.Services.Interfaces
@using MudBlazor

@inject IVesselService  VesselService
@inject ICompanyService CompanyService
@inject ICountryService CountryService
@inject ISnackbar       Snackbar
@inject IDialogService  DialogService
@inject IManageStoredFiles ManageStoredFiles

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <SharedVesselPage @ref="_sharedPage"
                Vessels="@_vessels"
                OnAddClicked="OpenAddDialog"
                OnEditClicked="OpenEditDialog"
                OnDeleteClicked="ConfirmDelete"
                OnToggleActiveClicked="ToggleActive"
                OnManageAttachedFilesClicked="ManageStoredFiles.OpenManageStoredFilesDialogAsync" 
                OnAddCertificateClicked="OpenAddCertificateDialog"
                OnEditCertificateClicked="OpenEditCertificateDialog"
                OnRemoveCertificateClicked  = "ConfirmRemoveCertificate"/>
}

@code {
    private IReadOnlyList<VesselResponse>  _vessels   = [];
    private IReadOnlyList<CompanyResponse> _companies = [];
    private IReadOnlyList<CountryResponse> _countries = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var t1 = VesselService.GetAllAsync();
            var t2 = CompanyService.GetActiveAsync();
            var t3 = CountryService.GetAllAsync();

            await Task.WhenAll(t1, t2, t3);

            _vessels   = t1.Result;
            _companies = t2.Result;
            _countries = t3.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            [nameof(VesselDialog.Companies)] = _companies,
            [nameof(VesselDialog.Countries)] = _countries,
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<VesselDialog>("New Vessel", parameters, options);
        var result  = await dialog.Result;
        if (result is null || result.Canceled) return;

        var req = (CreateVesselRequest)result.Data!;
        try
        {
            await VesselService.CreateAsync(
                req.CompanyId,
                req.VesselName,
                req.ImoNumber,
                req.GrossTonnage,
                req.FlagCountryId,
                req.Notes);

            Snackbar.Add("Vessel created.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenEditDialog(VesselResponse vessel)
    {
        var parameters = new DialogParameters
        {
            [nameof(VesselDialog.Vessel)]    = vessel,
            [nameof(VesselDialog.Companies)] = _companies,
            [nameof(VesselDialog.Countries)] = _countries,
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<VesselDialog>("Edit Vessel", parameters, options);
        var result  = await dialog.Result;
        if (result is null || result.Canceled) return;

        var req = (UpdateVesselRequest)result.Data!;
        try
        {
            await VesselService.UpdateAsync(
                vessel.Id,
                req.VesselName,
                req.ImoNumber,
                req.GrossTonnage,
                req.FlagCountryId,
                req.Notes);

            Snackbar.Add("Vessel updated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ToggleActive(VesselResponse vessel)
    {
        try
        {
            if (vessel.IsActive)
                await VesselService.DeactivateAsync(vessel.Id);
            else
                await VesselService.ActivateAsync(vessel.Id);

            Snackbar.Add(vessel.IsActive ? "Vessel deactivated." : "Vessel activated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmDelete(VesselResponse vessel)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Vessel",
            $"Delete '{vessel.Name}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await VesselService.DeleteAsync(vessel.Id);
            Snackbar.Add("Vessel deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }


    // ── Certificates ──────────────────────────────────────────────────────────────

    private async Task OpenAddCertificateDialog(VesselResponse vessel)
    {
        var paramaters = new DialogParameters 
        { [nameof(CertificateDialog.Entity)] = EntityType.Vessel };
        var dialog = await DialogService.ShowAsync<CertificateDialog>("New Certificate", paramaters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpsertCertificateRequest)result.Data!;
        await VesselService.AddCertificateAsync(vessel.Id, request);
        Snackbar.Add("Certificate added.", Severity.Success);
        await LoadAsync();
        await RefreshSelected(vessel.Id);
    }

    private async Task OpenEditCertificateDialog((VesselResponse vessel, CertificateResponse cert) args)
    {
        var parameters = new DialogParameters { ["Certificate"] = args.cert, [nameof(CertificateDialog.Entity)] = EntityType.Vessel };
        var dialog = await DialogService.ShowAsync<CertificateDialog>("Edit Certificate", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpsertCertificateRequest)result.Data!;
        await VesselService.UpdateCertificateAsync(args.vessel.Id, args.cert.Index, request);
        Snackbar.Add("Certificate updated.", Severity.Success);
        await LoadAsync();
        await RefreshSelected(args.vessel.Id);
    }

    private async Task ConfirmRemoveCertificate((VesselResponse vessel, CertificateResponse cert) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Certificate",
            $"Remove '{args.cert.CertificateName}'?",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed == true)
        {
            await VesselService.RemoveCertificateAsync(args.vessel.Id, args.cert.Index);
            Snackbar.Add("Certificate removed.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(args.vessel.Id);
        }
    }
    private SharedVesselPage _sharedPage = default!;
    private async Task RefreshSelected(int vesselId)
    {
        var updated = await VesselService.GetByIdAsync(vesselId) ?? new();
        _sharedPage?.UpdateSelected(updated);
    }
}