@page "/persons"
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Shared.UI.Pages.Persons
@using Marilog.Contracts.DTOs.Requests.PersonDTOs
@inject ICountryService CountryService
@inject IPersonService PersonService
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRankService RankService
@if (_loading == true)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
<SharedPersonPage @ref="_sharedPage"
                   Persons="_persons"
                   OnActivateClicked="Activate"
                   OnDeactivateClicked="Deactivate"
                   OnDeleteClicked="ConfirmDelete"
                   OnEditClicked="OpenEditDialog"
                   OnAddClicked="OpenAddDialog"
                   OnEditBankClicked="OpenEditBankDialog"
                   OnAddCertificateClicked="OpenAddCertificateDialog"
                   OnEditCertificateClicked="OpenEditCertificateDialog"
                   OnAddSeaServiceClicked="OpenAddSeaServiceDialog"
                   OnEditSeaServiceClicked="OpenEditSeaServiceDialog"
                   OnShowExpiringCertificatesClicked="OpenExpiringCertificatesDialog" />
@code {

    private IReadOnlyList<PersonResponse> _persons = [];
    private IReadOnlyList<CountryResponse> _countries = [];
    private bool _loading = true;
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }
    private async Task LoadAsync()
    {
        _loading = true;
        _persons = await PersonService.GetAllAsync();
        _loading = false;
    }

    private async Task<IReadOnlyList<CountryResponse>> CountriesList()
    {
        var response = await CountryService.GetActiveAsync();
        return response.Select(s => new CountryResponse
        {
            Code = s.Code,
            IsActive = s.IsActive,
            Id = s.Id,
            Name = s.Name
        }).ToList().AsReadOnly();

    }


    private async Task<IReadOnlyList<RankResponse>> RanksList()
    {
        var response = await RankService.GetActiveAsync();
        return response.Select(s => new RankResponse
        {
            Code = s.Code,
            IsActive = s.IsActive,
            Department =s.Department,
            Id = s.Id,
            Name = s.Name
        }).ToList().AsReadOnly();

    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<PersonDialog>("New Person",
            new DialogParameters { ["Countries"] = await CountriesList() });
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;  // ← check null first

        var request = (CreatePersonRequest)result.Data!;
        await PersonService.CreateAsync(
            request.BankName,
            request.IBAN,
            request.IsPassportExpired,
            request.BankSwiftCode,
            request.FullName,
            request.Nationality,
            request.PassportNo,
            request.PassportExpiry,
            request.SeamanBookNo,
            request.DateOfBirth,
            request.Phone,
            request.Email);

        Snackbar.Add("Person created.", Severity.Success);
        await LoadAsync();
    }

    private async Task OpenEditDialog(PersonResponse person)
    {
        var parameters = new DialogParameters
        {
            ["Person"] = person,
            ["Countries"] = await CountriesList()  // ← pass countries here too
        };
        var dialog = await DialogService.ShowAsync<PersonDialog>("Edit Person", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;  // ← check null first

        var request = (UpdatePersonRequest)result.Data!;
        await PersonService.UpdateAsync(
            person.Id,
            request.FullName,
            request.Nationality,
            request.PassportNo,
            request.PassportExpiry,
            request.SeamanBookNo,
            request.DateOfBirth,
            request.Phone,
            request.Email
            );

        Snackbar.Add("person updated.", Severity.Success);
        await LoadAsync();
    }

    private async Task ConfirmDelete(PersonResponse person)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Person",
            $"Are you sure you want to delete '{person.FullName}'?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await PersonService.DeleteAsync(person.Id);
            Snackbar.Add("Company deleted.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task Activate(PersonResponse person)
    {
        await PersonService.ActivateAsync(person.Id);
        Snackbar.Add($"{person.FullName} activated.", Severity.Success);
        await LoadAsync();
    }



    private SharedPersonPage _sharedPage = default!;

    private async Task RefreshSelected(int personId)
    {
        var updated = await PersonService.GetByIdAsync(personId) ?? new();
        _sharedPage?.UpdateSelected(updated);
    }

    private async Task Deactivate(PersonResponse person)
    {
        await PersonService.DeactivateAsync(person.Id);
        Snackbar.Add($"{person.FullName} deactivated.", Severity.Warning);
        await LoadAsync();
    }

    private async Task OpenEditBankDialog(PersonResponse person)
    {
        var parameters = new DialogParameters { ["Person"] = person };
        var dialog = await DialogService.ShowAsync<BankAccountDialog>("Bank Account", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpdateBankAccountRequest)result.Data!;

        // Clear إذا كانت كل القيم null
        if (request.BankName is null && request.IBAN is null && request.BankSwiftCode is null)
        {
            await PersonService.ClearBankAccountAsync(person.Id);
            Snackbar.Add("Bank account cleared.", Severity.Info);
        }
        else
        {
            await PersonService.UpdateBankAccountAsync(person.Id, request.BankName, request.IBAN, request.BankSwiftCode);
            Snackbar.Add("Bank account updated.", Severity.Success);
        }

        await LoadAsync();
        await RefreshSelected(person.Id);
    }


    // ── Certificates ──────────────────────────────────────────────────────────────

    private async Task OpenAddCertificateDialog(PersonResponse person)
    {
        var dialog = await DialogService.ShowAsync<CertificateDialog>("New Certificate");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpsertCertificateRequest)result.Data!;
        await PersonService.AddCertificateAsync(person.Id, request);
        Snackbar.Add("Certificate added.", Severity.Success);
        await LoadAsync();
        await RefreshSelected(person.Id);
    }

    private async Task OpenEditCertificateDialog((PersonResponse person, PersonCertificateResponse cert) args)
    {
        var parameters = new DialogParameters { ["Certificate"] = args.cert };
        var dialog = await DialogService.ShowAsync<CertificateDialog>("Edit Certificate", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpsertCertificateRequest)result.Data!;
        await PersonService.UpdateCertificateAsync(args.person.Id, args.cert.Index, request);
        Snackbar.Add("Certificate updated.", Severity.Success);
        await LoadAsync();
        await RefreshSelected(args.person.Id);
    }

    private async Task ConfirmRemoveCertificate((PersonResponse person, PersonCertificateResponse cert) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Certificate",
            $"Remove '{args.cert.CertificateName}'?",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed == true)
        {
            await PersonService.RemoveCertificateAsync(args.person.Id, args.cert.Index);
            Snackbar.Add("Certificate removed.", Severity.Success);
            await LoadAsync();
            await RefreshSelected(args.person.Id);
        }
    }

    // ── Sea Service ──────────────────────────────────────────────────────────────

    private async Task OpenAddSeaServiceDialog(PersonResponse person)
    {
        var ranks = await RanksList();
        var parameters = new DialogParameters
        {
            ["Ranks"] = ranks,
        };
        var dialog = await DialogService.ShowAsync<SeaServiceDialog>("New Sea Service", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpsertSeaServiceRequest)result.Data!;

        await PersonService.AddSeaServiceAsync(person.Id, request);

        Snackbar.Add("Sea service added.", Severity.Success);

        await LoadAsync();
        await RefreshSelected(person.Id);
    }

    private async Task OpenEditSeaServiceDialog((PersonResponse person, PersonSeaServiceResponse seaService) args)
    {
        var ranks = await RanksList();
        var parameters = new DialogParameters
        {
            ["Ranks"] = ranks,
            ["SeaService"] = args.seaService
        };

        var dialog = await DialogService.ShowAsync<SeaServiceDialog>(
            "Edit Sea Service",
            parameters);

        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpsertSeaServiceRequest)result.Data!;

        await PersonService.UpdateSeaServiceAsync(
            args.person.Id,
            args.seaService.Index,
            request);

        Snackbar.Add("Sea service updated.", Severity.Success);

        await LoadAsync();
        await RefreshSelected(args.person.Id);
    }

    private async Task ConfirmRemoveSeaService(
        (PersonResponse person, PersonSeaServiceResponse seaService) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Sea Service",
            $"Remove '{args.seaService.RankName}'?",
            yesText: "Remove",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await PersonService.RemoveSeaServiceAsync(
                args.person.Id,
                args.seaService.Index);

            Snackbar.Add("Sea service removed.", Severity.Success);

            await LoadAsync();
            await RefreshSelected(args.person.Id);
        }
    }

    private async Task OpenExpiringCertificatesDialog(List<PersonResponse> items)
    {
        var parameters = new DialogParameters
        {
            ["Items"] = items
        };

        await DialogService.ShowAsync<ExpiringCertificatesDialog>(
            "Expiring Certificates",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
    }

}
