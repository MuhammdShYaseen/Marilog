@page "/documents"
@using Marilog.Contracts.DTOs.Requests.DocumentDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Shared.UI.Pages.Documents
@using MudBlazor

@inject IDocumentService DocumentService
@inject IVesselService VesselService
@inject ICompanyService CompanyService
@inject IDocumentTypeService DocTypeService
@inject ICurrencyService CurrencyService
@inject IPortService PortService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ISwiftTransferService SwiftTransferService

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_detail is not null)
{
    <SharedDocumentDetailPage Document="_detail"
                              OnBackClicked="CloseDetail"
                              OnEditClicked="OpenEditDialog"
                              OnDeleteClicked="ConfirmDelete"
                              OnAddPaymentClicked="OpenAddPaymentDialog"
                              OnAddItemClicked="OpenAddItemDialog"
                              OnEditItemClicked="OpenEditItemDialog"
                              OnRemoveItemClicked="ConfirmRemoveItem" />
}
else
{
    <SharedDocumentsPage Unpaid="_unpaid"
                         ByVessel="_byVessel"
                         BySupplier="_bySupplier"
                         Vessels="_vessels"
                         Suppliers="_suppliers"
                         OnAddClicked="OpenAddDialog"
                         OnEditClicked="OpenEditDialog"
                         OnDeleteClicked="ConfirmDelete"
                         OnDocumentSelected="LoadDetail"
                         OnVesselSelected="LoadByVessel"
                         OnSupplierSelected="LoadBySupplier" 
                         OnReportRequested="HandleReportRequestedAsync"
                         @ref="_documentsPage" />
}

@code {
    private IReadOnlyList<DocumentResponse> _unpaid = [];
    private IReadOnlyList<DocumentResponse> _byVessel = [];
    private IReadOnlyList<DocumentResponse> _bySupplier = [];
    private IReadOnlyList<VesselResponse> _vessels = [];
    private IReadOnlyList<CompanyResponse> _suppliers = [];
    private IReadOnlyList<DocumentTypeResponse> _docTypes = [];
    private IReadOnlyList<CurrencyResponse> _currencies = [];
    private IReadOnlyList<PortResponse> _ports = [];
    private IReadOnlyList<SwiftTransferResponse> _swifts = [];
    private DocumentResponse? _detail;
    private bool _loading = true;
    private int? _selectedVesselId;
    private int? _selectedSupplierId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var t1 = DocumentService.GetUnpaidAsync();
            var t2 = VesselService.GetActiveAsync();
            var t3 = CompanyService.GetActiveAsync();
            var t4 = DocTypeService.GetActiveAsync();
            var t5 = CurrencyService.GetActiveAsync();
            var t6 = PortService.GetActiveAsync();

            await Task.WhenAll(t1, t2, t3, t4, t5, t6);

            _unpaid = t1.Result;
            _vessels = t2.Result;
            _suppliers = t3.Result;
            _docTypes = t4.Result;
            _currencies = t5.Result;
            _ports = t6.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadByVessel(int? vesselId)
    {
        _selectedVesselId = vesselId;

        if (vesselId is null)
        {
            _byVessel = [];
            return;
        }

        _byVessel = await DocumentService.GetByVesselAsync(vesselId.Value);
    }

    private async Task LoadBySupplier(int? supplierId)
    {
        _selectedSupplierId = supplierId;

        if (supplierId is null)
        {
            _bySupplier = [];
            return;
        }

        _bySupplier = await DocumentService.GetBySupplierAsync(supplierId.Value);
    }

    private async Task LoadDetail(int id)
    {
        _detail = await DocumentService.GetFullAsync(id);
    }

    private void CloseDetail() => _detail = null;

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            ["DocTypes"] = _docTypes,
            ["Companies"] = _suppliers,
            ["Currencies"] = _currencies,
            ["Vessels"] = _vessels,
            ["Ports"] = _ports
        };

        var dialog = await DialogService.ShowAsync<DocumentFormDialog>("New Document", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is null) return;

        var model = (CreateDocumentRequest)result.Data;
        await DocumentService.CreateAsync
        (
            model.DocNumber,
            model.DocTypeId,
            model.DocDate,
            model.CurrencyId,
            model.TotalAmount,
            model.SupplierId,
            model.BuyerId,
            model.VesselId,
            model.PortId,
            model.ParentDocumentId,
            model.Reference
        );

        Snackbar.Add("Document created.", Severity.Success);
        await LoadAsync();
    }

    private async Task OpenEditDialog(DocumentResponse doc)
    {
        var parameters = new DialogParameters
        {
            ["Document"] = doc,
            ["DocTypes"] = _docTypes,
            ["Companies"] = _suppliers,
            ["Currencies"] = _currencies,
            ["Vessels"] = _vessels,
            ["Ports"] = _ports
        };

        var dialog = await DialogService.ShowAsync<DocumentFormDialog>("Edit Document", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is null) return;

        var model = (UpdateDocumentRequest)result.Data;
        await DocumentService.UpdateAsync
        (
            doc.Id,
            model.DocTypeId,
            model.DocDate,
            model.CurrencyId,
            model.TotalAmount,
            model.SupplierId,
            model.BuyerId,
            model.VesselId,
            model.PortId,
            model.ParentDocumentId,
            model.Reference
        );

        Snackbar.Add("Document updated.", Severity.Success);
        await LoadAsync();

        if (_detail?.Id == doc.Id)
            await LoadDetail(doc.Id);
    }

    private async Task ConfirmDelete(DocumentResponse doc)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync
        (
            "Delete Document",
            $"Delete document '{doc.DocNumber}'?",
            yesText: "Delete", 
            cancelText: "Cancel"
        );

        if (confirmed != true) return;
        await DocumentService.DeleteAsync(doc.Id);
        Snackbar.Add("Document deleted.", Severity.Success);
        _detail = null;
        await LoadAsync();
        if (_selectedVesselId.HasValue)
        {
            _byVessel = await DocumentService
                .GetByVesselAsync(_selectedVesselId.Value);
        }

        if (_selectedSupplierId.HasValue)
        {
            _bySupplier = await DocumentService
                .GetBySupplierAsync(_selectedSupplierId.Value);
        }
    }

    private async Task OpenAddPaymentDialog(DocumentResponse doc)
    {
        var swifts = await SwiftTransferService.GetBySenderAndReceverAsync(doc.BuyerId!.Value, doc.SupplierId!.Value);
        var parameters = new DialogParameters 
        { 
            ["Document"] = doc,
            ["SwiftTransfers"] = swifts
        };
        var dialog = await DialogService.ShowAsync<AddPaymentDialog>("Add Payment", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is null) return;

        var (swiftId, amount, date) = ((int, decimal, DateOnly))result.Data;
        await DocumentService.AddPaymentAsync(doc.Id, swiftId, amount, date);
        Snackbar.Add("Payment recorded.", Severity.Success);
        await LoadDetail(doc.Id);
    }

    private async Task OpenAddItemDialog(DocumentResponse doc)
    {
        var dialog = await DialogService.ShowAsync<DocumentItemFormDialog>("Add Item");
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is null || result.Data is not AddDocumentItemRequest) return;

        var data = (AddDocumentItemRequest)result.Data;
        await DocumentService.AddItemAsync(doc.Id, data.ProductName, data.Quantity, data.UnitPrice, data.Unit);
        Snackbar.Add("Item added.", Severity.Success);
        await LoadDetail(doc.Id);
    }

    private async Task OpenEditItemDialog((int DocumentId, DocumentItemResponse Item) args)
    {
        var parameters = new DialogParameters { ["Item"] = args.Item };
        var dialog = await DialogService.ShowAsync<DocumentItemFormDialog>("Edit Item", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is null || result.Data is not UpdateDocumentItemRequest) return;

        var data = (UpdateDocumentItemRequest)result.Data;
        await DocumentService.UpdateItemAsync(args.DocumentId, args.Item.Id, data.ProductName, data.Quantity, data.UnitPrice, data.Unit);
        Snackbar.Add("Item updated.", Severity.Success);
        await LoadDetail(args.DocumentId);
    }

    private async Task ConfirmRemoveItem((int DocumentId, int ItemId) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Item", "Remove this item?",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed != true) return;
        await DocumentService.RemoveItemAsync(args.DocumentId, args.ItemId);
        Snackbar.Add("Item removed.", Severity.Success);
        await LoadDetail(args.DocumentId);
    }

    private SharedDocumentsPage? _documentsPage;

    private async Task HandleReportRequestedAsync(Marilog.Contracts.DTOs.Reports.DocumentReports.DocumentFilterOptions filter)
    {
        var report = await DocumentService.GetFilteredDocsReportAsync(filter);
        _documentsPage?.SetReport(report);
    }
}