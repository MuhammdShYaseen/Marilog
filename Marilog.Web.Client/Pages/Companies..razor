@page "/companies"
@using Marilog.Contracts.DTOs.Requests.CompanyDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.DTOs.Requests.ContactsRequestDTOs
@using Marilog.Contracts.Interfaces.Services.SystemServices
@using Marilog.Shared.UI.Pages.Companies
@using Marilog.Shared.UI.Pages.ContactForms
@using MudBlazor

@inject ICompanyService CompanyService
@inject ICountryService CountryService
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ICurrencyService CurrencyService

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <SharedCompaniesPage @ref="_sharedPage"
                         Companies="_companies"
                         OnAddClicked="OpenAddDialog"
                         OnEditClicked="OpenEditDialog"
                         OnDeleteClicked="ConfirmDelete"
                         OnActivateClicked="Activate"
                         OnDeactivateClicked="Deactivate"
                         OnVesselClick="OnVesselClicked"
                         GetCompanyWithVessels="RowSelectedHandler"
                         OnAddBankAccountClicked="OpenAddBankAccountDialog"
                         OnAddEmailClicked="OpenAddEmailDialog"
                         OnAddPhoneClicked="OpenAddPhoneDialog"
                         OnDeleteBankAccountClicked="ConfirmDeleteBankAccount"
                         OnDeleteEmailClicked="ConfirmDeleteEmail"
                         OnDeletePhoneClicked="ConfirmDeletePhone"
                         OnEditBankAccountClicked="OpenEditBankAccountDialog"
                         OnEditEmailClicked="OpenEditEmailDialog"
                         OnEditPhoneClicked="OpenEditPhoneDialog"/>
}

@code {
    private IReadOnlyList<CompanyResponse> _companies = [];
    private bool _loading = true;
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _companies = await CompanyService.GetAllAsync();
        _loading = false;
    }

    private async Task<IReadOnlyList<CountryResponse>>CountriesList()
    {
        var response = await CountryService.GetActiveAsync();
        return response.Select(s => new CountryResponse
            {
                Code = s.Code,
                IsActive = s.IsActive,
                Id = s.Id,
                Name = s.Name
            }).ToList().AsReadOnly();

    }
    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<CompanyFormDialog>("New Company",
            new DialogParameters { ["Countries"] = await CountriesList() });
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;  // ← check null first

        var request = (CreateCompanyRequest)result.Data!;
        await CompanyService.CreateAsync(
            request.RegistrationNumber,
            request.WebSite,
            request.CompanyName,
            request.CountryId,
            request.ContactName,
            request.Address);

        Snackbar.Add("Company created.", Severity.Success);
        await LoadAsync();
    }

    private async Task OpenEditDialog(CompanyResponse company)
    {
        var parameters = new DialogParameters
        {
            ["Company"] = company,
            ["Countries"] = await CountriesList()  // ← pass countries here too
        };
        var dialog = await DialogService.ShowAsync<CompanyFormDialog>("Edit Company", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;  // ← check null first

        var request = (CreateCompanyRequest)result.Data!;
        await CompanyService.UpdateAsync(
            company.Id,
            request.RegistrationNumber,
            request.ContactName,
            request.CompanyName,
            request.CountryId,
            request.WebSite,
            request.Address);

        Snackbar.Add("Company updated.", Severity.Success);
        await LoadAsync();
    }

    private async Task ConfirmDelete(CompanyResponse company)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Company",
            $"Are you sure you want to delete '{company.Name}'?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await CompanyService.DeleteAsync(company.Id);
            Snackbar.Add("Company deleted.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task Activate(CompanyResponse company)
    {
        await CompanyService.ActivateAsync(company.Id);
        Snackbar.Add($"{company.Name} activated.", Severity.Success);
        await LoadAsync();
    }

    private async Task Deactivate(CompanyResponse company)
    {
        await CompanyService.DeactivateAsync(company.Id);
        Snackbar.Add($"{company.Name} deactivated.", Severity.Warning);
        await LoadAsync();
    }

    private CompanyResponse _selectedCompany =new();
    private async Task<CompanyResponse?> RowSelectedHandler(int id)
    {
        _selectedCompany = await CompanyService.GetWithVesselsAsync(id) ?? new();
        return _selectedCompany;

    }


    // ── Emails ────────────────────────────────────────────────────────────────
    private async Task OpenAddEmailDialog(CompanyResponse company)
    {
        var dialog = await DialogService.ShowAsync<EmailFormDialog>("Add Email");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (AddEmailRequest)result.Data!;
        await CompanyService.AddEmailAsync(company.Id, request.Address, request.Role, request.Label, request.IsPrimary);
        Snackbar.Add("Email added.", Severity.Success);
        await RefreshSelected(company.Id);
    }

    private async Task OpenEditEmailDialog((CompanyResponse company, EmailsResponse email) args)
    {
        var parameters = new DialogParameters { ["Email"] = args.email };
        var dialog = await DialogService.ShowAsync<EmailFormDialog>("Edit Email", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (AddEmailRequest)result.Data!;
        await CompanyService.UpdateEmailAsync(args.company.Id, args.email.Address, request.Address, request.Role, request.Label, request.IsPrimary);
        Snackbar.Add("Email updated.", Severity.Success);
        await RefreshSelected(args.company.Id);
    }

    private async Task ConfirmDeleteEmail((CompanyResponse company, EmailsResponse email) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Email", $"Delete '{args.email.Address}'?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        await CompanyService.RemoveEmailAsync(args.company.Id, args.email.Address);
        Snackbar.Add("Email removed.", Severity.Success);
        await RefreshSelected(args.company.Id);
    }

    // ── Phones ────────────────────────────────────────────────────────────────
    private async Task OpenAddPhoneDialog(CompanyResponse company)
    {
        var dialog = await DialogService.ShowAsync<PhoneFormDialog>("Add Phone");
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (AddPhoneRequest)result.Data!;
        await CompanyService.AddPhoneAsync(company.Id, request.Number, request.Type, request.Label, request.IsPrimary);
        Snackbar.Add("Phone added.", Severity.Success);
        await RefreshSelected(company.Id);
    }

    private async Task OpenEditPhoneDialog((CompanyResponse company, PhonesResponse phone) args)
    {
        var parameters = new DialogParameters { ["Phone"] = args.phone };
        var dialog = await DialogService.ShowAsync<PhoneFormDialog>("Edit Phone", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (AddPhoneRequest)result.Data!;
        await CompanyService.UpdatePhoneAsync(args.company.Id, args.phone.Number, args.phone.Type, request.Number, request.Type, request.Label, request.IsPrimary);
        Snackbar.Add("Phone updated.", Severity.Success);
        await RefreshSelected(args.company.Id);
    }

    private async Task ConfirmDeletePhone((CompanyResponse company, PhonesResponse phone) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Phone", $"Delete '{args.phone.Number}'?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        await CompanyService.RemovePhoneAsync(args.company.Id, args.phone.Number, args.phone.Type);
        Snackbar.Add("Phone removed.", Severity.Success);
        await RefreshSelected(args.company.Id);
    }

    // ── Bank Accounts ─────────────────────────────────────────────────────────
    private async Task OpenAddBankAccountDialog(CompanyResponse company)
    {
        var parameters = new DialogParameters { ["Currencies"] = await CurrenciesList() };
        var dialog = await DialogService.ShowAsync<BankAccountFormDialog>("Add Bank Account", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (AddBankAccountRequest)result.Data!;
        await CompanyService.AddBankAccountAsync(company.Id, request.IBAN, request.BankName, request.SwiftCode, request.CurrencyId, request.AccountHolderName, request.IsPrimary);
        Snackbar.Add("Bank account added.", Severity.Success);
        await RefreshSelected(company.Id);
    }

    private async Task OpenEditBankAccountDialog((CompanyResponse company, BankAccountResponse bank) args)
    {
        var parameters = new DialogParameters
        {
            ["BankAccount"] = args.bank,
            ["Currencies"] = await CurrenciesList()
        };
        var dialog = await DialogService.ShowAsync<BankAccountFormDialog>("Edit Bank Account", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var request = (UpdateBankAccountRequest)result.Data!;
        await CompanyService.UpdateBankAccountAsync(args.company.Id, args.bank.IBAN, request.NewIban, request.BankName, request.SwiftCode, request.CurrencyId, request.AccountHolderName, request.IsPrimary);
        Snackbar.Add("Bank account updated.", Severity.Success);
        await RefreshSelected(args.company.Id);
    }

    private async Task ConfirmDeleteBankAccount((CompanyResponse company, BankAccountResponse bank) args)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Bank Account", $"Delete IBAN '{args.bank.IBAN}'?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        await CompanyService.RemoveBankAccountAsync(args.company.Id, args.bank.IBAN);
        Snackbar.Add("Bank account removed.", Severity.Success);
        await RefreshSelected(args.company.Id);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private async Task<IReadOnlyList<CurrencyResponse>> CurrenciesList()
    {
        return await CurrencyService.GetActiveAsync();
    }

    private SharedCompaniesPage _sharedPage = default!;

    private async Task RefreshSelected(int companyId)
    {
        var updated = await CompanyService.GetWithVesselsAsync(companyId) ?? new();
        _sharedPage?.UpdateSelected(updated);
    }
    private void OnVesselClicked(int id) => Nav.NavigateTo($"/vessels/{id}");
}