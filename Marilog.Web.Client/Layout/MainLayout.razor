@using Marilog.Contracts.Interfaces.FrontendServices
@inherits LayoutComponentBase
@* Required *@
<MudThemeProvider />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />
<MudLayout>

    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">Marilog</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="mr-3">WKA Ocean Shipping</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen"
               Elevation="2"
               Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigation</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            @if (Items is null)
            {
                <MudText>Loading...</MudText>
            }
            else
            {
                <NavMenu Items="Items" />
            }
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

