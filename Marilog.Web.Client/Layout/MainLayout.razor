@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.FrontendServices
@using Marilog.Shared.UI.Layout
@using Marilog.Shared.UI.Services

@inject INavigationService NavService
@inject IAppThemeService ThemeService
@inject AppStateService AppState

@inherits LayoutComponentBase


    <SharedMainLayout 
        Items="AppState.NavItems"
        Theme="AppState.Theme"
        AppTitle="Marilog"
        AppSubtitle="WKA Ocean Shipping">

        @Body

    </SharedMainLayout>
@code {

    private static List<NavItemResponse>? _items;  // Static cache here
    private static bool _isLoaded = false;
    protected override async Task OnInitializedAsync()
    {
        if (!_isLoaded)
        {
            try
            {
                await AppState.InitializeAsync(
                    loadNav: () => NavService.GetAsync(),
                    loadTheme: () => ThemeService.GetDefaultThemeAsync());
                _items = AppState.NavItems;
                _isLoaded = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex);
                _items = new();
            }
        }
    }

    
}