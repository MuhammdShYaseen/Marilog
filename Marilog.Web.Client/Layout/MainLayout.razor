@using Marilog.Contracts.DTOs.Responses
@using Marilog.Contracts.Interfaces.FrontendServices
@using Marilog.Shared.UI.Layout

@inherits LayoutComponentBase

<SharedMainLayout Items="Items"
                  AppTitle="Marilog"
                  AppSubtitle="WKA Ocean Shipping">

    @Body

</SharedMainLayout>

@code {

    [Inject]
    public INavigationService NavService { get; set; }
        = default!;

    private List<NavItemResponse> Items = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Items = await NavService.GetAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);

            Items = new();
        }
    }

}