@using Marilog.Contracts.DTOs.Responses
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using MudBlazor
@using Marilog.Shared.UI.Components.Upload
@namespace Marilog.Shared.UI.Components.ManagingStoredFiles

<MudDialog>

    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-grow-1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Attached Files Management</MudText>
            </MudStack>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                    <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                                   Color="@(_viewMode == ViewMode.List ? Color.Primary : Color.Default)"
                                   OnClick="@(() => _viewMode = ViewMode.List)" />
                    <MudIconButton Icon="@Icons.Material.Filled.GridView"
                                   Color="@(_viewMode == ViewMode.Grid ? Color.Primary : Color.Default)"
                                   OnClick="@(() => _viewMode = ViewMode.Grid)" />
                </MudButtonGroup>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           OnClick="OpenUploadDialogAsync">
                    Add Files
                </MudButton>

            </MudStack>
        </MudStack>
    </TitleContent>

    <DialogContent>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else if (_files.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-8">
                <MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Color="Color.Secondary">There Are No Attached Files</MudText>
            </MudStack>
        }
        else
        {
            @if (_viewMode == ViewMode.List)
            {
                <MudTable T="StoredFileResponse"
                          Items="_files"
                          Hover="true"
                          Class="manage-files-table"
                          OnRowClick="OnTableRowClick"
                          RowClassFunc="@((f, index) => f.Id == _selectedFile?.Id ? "selected-row" : string.Empty)">

                    <HeaderContent>
                        <MudTh>File</MudTh>
                        <MudTh>Size</MudTh>
                        <MudTh>Tags</MudTh>
                        <MudTh>Added Date</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>

                    <RowTemplate Context="file">

                        <MudTd DataLabel="File">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@GetFileIcon(file)" Size="Size.Small" Color="Color.Primary" />
                                <MudText>@file.OriginalFileName</MudText>
                            </MudStack>
                        </MudTd>

                        <MudTd DataLabel="Size">
                            @FormatSize(file.Size)
                        </MudTd>

                        <MudTd DataLabel="Tags" @onclick:stopPropagation="true">
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" AlignItems="AlignItems.Center">
                                @if (file.Tags != null)
                                {
                                    foreach (var tag in file.Tags)
                                    {
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@ParseColor(tag.Color)"
                                                 Variant="Variant.Filled"
                                                 OnClose="@(() => RemoveTagAsync(file, tag))">
                                            @tag.Name
                                        </MudChip>
                                    }
                                }
                                <MudMenu Icon="@Icons.Material.Filled.Sell" Size="Size.Small" Dense="true">
                                    @TagPickerContent(file)
                                </MudMenu>

                            </MudStack>
                        </MudTd>

                        <MudTd DataLabel="Date">
                            @file.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                        </MudTd>

                        <MudTd @onclick:stopPropagation="true">
                            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">

                                <MudIconButton Icon="@Icons.Material.Filled.Download"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => DownloadAsync(file))" />

                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteAsync(file))" />

                            </MudStack>
                        </MudTd>

                    </RowTemplate>

                </MudTable>
            }
            else
            {
                <MudGrid Spacing="3" Class="mt-1">

                    @foreach (var file in _files)
                    {
                        <MudItem xs="6" sm="4" md="3">

                            <div class="file-card-wrapper" @onclick="() => SelectFile(file)">

                                <MudPaper Class="@GetCardClass(file)" Outlined="true">

                                    <div class="file-thumb">

                                        @if (IsImage(file))
                                        {
                                            <img src="@BuildDownloadUrl(file)" alt="@file.OriginalFileName" />
                                        }
                                        else if (file.HasThumbnail)
                                        {
                                            <img src="@BuildThumbnailUrl(file)" alt="@file.OriginalFileName" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@GetFileIcon(file)" Color="Color.Primary" Class="file-thumb-icon" />
                                        }

                                        <div class="file-thumb-actions" @onclick:stopPropagation="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                           Size="Size.Small"
                                                           Color="Color.Inherit"
                                                           OnClick="@(() => DownloadAsync(file))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Inherit"
                                                           OnClick="@(() => DeleteAsync(file))" />
                                        </div>

                                    </div>

                                    <div class="pa-2">
                                        <MudText Typo="Typo.body2" Class="file-card-name">
                                            @file.OriginalFileName
                                        </MudText>

                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @FormatSize(file.Size)
                                        </MudText>

                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-1" @onclick:stopPropagation="true">

                                            @if (file.Tags != null)
                                            {
                                                foreach (var tag in file.Tags)
                                                {
                                                    <MudChip T="string"
                                                             Size="Size.Small"
                                                             Color="@ParseColor(tag.Color)"
                                                             Variant="Variant.Filled"
                                                             OnClose="@(() => RemoveTagAsync(file, tag))">
                                                        @tag.Name
                                                    </MudChip>
                                                }
                                            }

                                            <MudMenu Icon="@Icons.Material.Filled.Sell" Size="Size.Small" Dense="true">
                                                @TagPickerContent(file)
                                            </MudMenu>

                                        </MudStack>
                                    </div>

                                </MudPaper>

                            </div>

                        </MudItem>
                    }

                </MudGrid>
            }

            @if (_selectedFile is not null)
            {
                <MudPaper Class="detail-panel mt-4 pa-3" Outlined="true">

                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@GetFileIcon(_selectedFile)" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1">@_selectedFile.OriginalFileName</MudText>
                        </MudStack>

                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       OnClick="ClearSelection" />

                    </MudStack>

                    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">

                        <MudTabPanel Text="Text" Icon="@Icons.Material.Filled.Description">

                            @if (string.IsNullOrEmpty(_selectedFile.Content))
                            {
                                <MudText Color="Color.Secondary" Class="py-4">
                                    No text content available for this file yet.
                                </MudText>
                            }
                            else
                            {
                                <MudStack Spacing="2">

                                    <MudTextField T="string"
                                                  @bind-Value="_editableContent"
                                                  Lines="12"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true" />

                                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                                        <MudButton Variant="Variant.Text"
                                                   Disabled="@(!_isContentDirty)"
                                                   OnClick="ResetContent">
                                            Discard
                                        </MudButton>

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Save"
                                                   Disabled="@(!_isContentDirty || _isSavingContent)"
                                                   OnClick="SaveContentAsync">
                                            @(_isSavingContent ? "Saving..." : "Save")
                                        </MudButton>
                                    </MudStack>

                                </MudStack>
                            }

                        </MudTabPanel>

                        <MudTabPanel Text="PDF" Icon="@Icons.Material.Filled.PictureAsPdf">

                            @if (IsPdf(_selectedFile))
                            {
                                <iframe src="@BuildDownloadUrl(_selectedFile)" class="pdf-preview-frame"></iframe>
                            }
                            else
                            {
                                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-8">
                                    <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Color="Color.Secondary">Preview is only available for PDF files.</MudText>
                                    <MudButton Variant="Variant.Outlined"
                                               StartIcon="@Icons.Material.Filled.Download"
                                               OnClick="@(() => DownloadAsync(_selectedFile))">
                                        Download instead
                                    </MudButton>
                                </MudStack>
                            }

                        </MudTabPanel>

                    </MudTabs>

                </MudPaper>
            }
        }

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>

</MudDialog>

@code {
    private RenderFragment TagPickerContent(StoredFileResponse file) => @<MudStack Spacing="2" Class="pa-3" Style="min-width:240px">

        <MudTextField T="string"
                      @bind-Value="_newTagName"
                      Label="Tag Name"
                      Immediate="true" />

        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
            @foreach (var color in _presetColors)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@color.Value"
                         Variant="@(color.Name == _newTagColor ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => _newTagColor = color.Name)">
                    @color.Name
                </MudChip>
            }
        </MudStack>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="@string.IsNullOrWhiteSpace(_newTagName)"
                   OnClick="@(() => AddTagAsync(file))">
            Add
        </MudButton>

    </MudStack>;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Inject]
    private IDialogService DialogService { get; set; } = default!;

    [Inject]
    private IJSRuntime JsRuntime { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    // ── all client-service dependencies come from the host via Parameters ──

    [Parameter, EditorRequired]
    public Func<CancellationToken, Task<IReadOnlyList<StoredFileResponse>>> LoadFilesFunc { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<int, CancellationToken, Task> DeleteFileFunc { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<int, string, string, CancellationToken, Task> AddTagFunc { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<int, int, CancellationToken, Task> RemoveTagFunc { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<IReadOnlyList<IBrowserFile>, CancellationToken, Task<bool>> UploadFilesFunc { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<StoredFileResponse, string> BuildDownloadUrl { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<StoredFileResponse, string> BuildThumbnailUrl { get; set; } = default!;

    // Optional: not wired by the host yet until the update-content endpoint exists.
    // When null, the Save button still works in the UI but informs the user it's not available yet.
    [Parameter]
    public Func<int, string, CancellationToken, Task<bool>>? SaveContentFunc { get; set; }

    private enum ViewMode { List, Grid }

    private ViewMode _viewMode = ViewMode.Grid;

    private IReadOnlyList<StoredFileResponse> _files = Array.Empty<StoredFileResponse>();
    private bool _isLoading;

    private StoredFileResponse? _selectedFile;
    private string _editableContent = string.Empty;
    private bool _isSavingContent;

    private bool _isContentDirty =>
        _selectedFile is not null && _editableContent != (_selectedFile.Content ?? string.Empty);

    private string _newTagName = string.Empty;
    private string _newTagColor = nameof(Color.Primary);

    private readonly (string Name, Color Value)[] _presetColors =
    {
        (nameof(Color.Primary), Color.Primary),
        (nameof(Color.Secondary), Color.Secondary),
        (nameof(Color.Tertiary), Color.Tertiary),
        (nameof(Color.Success), Color.Success),
        (nameof(Color.Warning), Color.Warning),
        (nameof(Color.Error), Color.Error),
        (nameof(Color.Info), Color.Info),
        (nameof(Color.Dark), Color.Dark),
    };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        StateHasChanged();

        _files = await LoadFilesFunc(CancellationToken.None);

        _isLoading = false;
        StateHasChanged();
    }

    private void SelectFile(StoredFileResponse file)
    {

        _selectedFile = file;
        _editableContent = file.Content ?? string.Empty;
    }

    private void ClearSelection()
    {
        _selectedFile = null;
        _editableContent = string.Empty;
    }

    private void ResetContent()
    {
        if (_selectedFile is not null)
            _editableContent = _selectedFile.Content ?? string.Empty;
    }

    private void OnTableRowClick(TableRowClickEventArgs<StoredFileResponse> args)
    {
        if (args.Item is null)
            return;

        SelectFile(args.Item);
    }

    private async Task SaveContentAsync()
    {
        if (_selectedFile is null)
            return;

        if (SaveContentFunc is null)
        {
            Snackbar.Add("Saving content is not available yet — the server endpoint isn't implemented.", Severity.Info);
            return;
        }

        _isSavingContent = true;
        StateHasChanged();

        var success = await SaveContentFunc(_selectedFile.Id, _editableContent, CancellationToken.None);

        _isSavingContent = false;

        if (success)
        {
            Snackbar.Add("Content saved.", Severity.Success);
            await ReloadAsync();

            // keep the same file selected with the freshly reloaded data
            var refreshed = _files.FirstOrDefault(f => f.Id == _selectedFile.Id);
            if (refreshed is not null)
                SelectFile(refreshed);
        }
        else
        {
            Snackbar.Add("Failed to save content.", Severity.Error);
        }
    }

    private async Task OpenUploadDialogAsync()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true,
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<FileUploadDialog>("Attach Files", options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
            return;

        var files = (IReadOnlyList<IBrowserFile>)result.Data!;

        var success = await UploadFilesFunc(files, CancellationToken.None);

        if (success)
        {
            Snackbar.Add("Files attached successfully.", Severity.Success);
            await ReloadAsync();
        }
        else
        {
            Snackbar.Add("An error occurred while uploading files.", Severity.Error);
        }
    }

    private async Task DownloadAsync(StoredFileResponse file)
    {
        var url = BuildDownloadUrl(file);
        await JsRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task DeleteAsync(StoredFileResponse file)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Are you sure you want to delete \"{file.OriginalFileName}\"?",
            yesText: "Delete",
            cancelText: "Cancel",
            options: new DialogOptions { CloseButton = true });

        if (confirmed != true)
            return;

        await DeleteFileFunc(file.Id, CancellationToken.None);

        if (_selectedFile?.Id == file.Id)
            ClearSelection();

        Snackbar.Add("File deleted.", Severity.Success);
        await ReloadAsync();
    }

    private async Task AddTagAsync(StoredFileResponse file)
    {
        if (string.IsNullOrWhiteSpace(_newTagName))
            return;

        await AddTagFunc(file.Id, _newTagName.Trim(), _newTagColor, CancellationToken.None);

        _newTagName = string.Empty;
        await ReloadAsync();
    }

    private async Task RemoveTagAsync(StoredFileResponse file, TagResponse tag)
    {
        await RemoveTagFunc(file.Id, tag.Id, CancellationToken.None);
        await ReloadAsync();
    }

    private static Color ParseColor(string? colorName)
    {
        return Enum.TryParse<Color>(colorName, ignoreCase: true, out var parsed)
            ? parsed
            : Color.Default;
    }

    private static bool IsImage(StoredFileResponse file)
    {
        return !string.IsNullOrWhiteSpace(file.ContentType)
            && file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPdf(StoredFileResponse file)
    {
        return string.Equals(file.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase);
    }

    private string GetCardClass(StoredFileResponse file)
    {
        return file.Id == _selectedFile?.Id
            ? "file-card pa-0 file-card-selected"
            : "file-card pa-0";
    }

    private static string GetFileIcon(StoredFileResponse file)
    {
        var ext = System.IO.Path.GetExtension(file.OriginalFileName).ToLowerInvariant();

        return ext switch
        {
            ".pdf" => Icons.Material.Filled.PictureAsPdf,
            ".doc" or ".docx" => Icons.Material.Filled.Description,
            ".xls" or ".xlsx" or ".csv" => Icons.Material.Filled.TableChart,
            ".ppt" or ".pptx" => Icons.Material.Filled.Slideshow,
            ".zip" or ".rar" or ".7z" => Icons.Material.Filled.FolderZip,
            ".txt" => Icons.Material.Filled.Article,
            _ => Icons.Material.Filled.InsertDriveFile
        };
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{bytes / 1024d:F1} KB";

        return $"{bytes / 1024d / 1024d:F1} MB";
    }

    private void Close()
    {
        MudDialog.Close();
    }
}

<style>
    .manage-files-table .mud-table-head {
        background-color: var(--mud-palette-background-grey);
    }

    .manage-files-table .selected-row {
        background-color: var(--mud-palette-primary-hover) !important;
    }

    .file-card {
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        transition: box-shadow 0.15s ease, border-color 0.15s ease;
    }

        .file-card:hover {
            box-shadow: var(--mud-elevation-4);
        }

    .file-card-selected {
        border: 2px solid var(--mud-palette-primary);
    }

    .file-thumb {
        position: relative;
        height: 110px;
        background-color: var(--mud-palette-background-grey);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .file-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .file-thumb-icon {
        font-size: 3rem;
        opacity: 0.6;
    }

    .file-thumb-actions {
        position: absolute;
        top: 4px;
        right: 4px;
        display: flex;
        gap: 2px;
        background-color: rgba(0, 0, 0, 0.55);
        border-radius: 6px;
        opacity: 0;
        transition: opacity 0.15s ease;
    }

    .file-thumb:hover .file-thumb-actions {
        opacity: 1;
    }

    .file-card-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .detail-panel {
        border-radius: 8px;
    }

    .pdf-preview-frame {
        width: 100%;
        height: 500px;
        border: none;
        border-radius: 4px;
    }
</style>