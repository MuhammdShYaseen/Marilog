@using Marilog.Contracts.DTOs.Requests.Common
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Kernel.Enums
@using MudBlazor
@namespace Marilog.Shared.UI.Components.SharedDialogs

<MudDialog>
    <DialogContent>
        <MudGrid>

            <MudItem xs="12">
                @if (Entity == EntityType.Person || Entity == 0 || Entity == null)
                {
                    <MudSelect T="PersonCertificateType"
                               @bind-Value="_typePerson"
                               Label="Certificate Type"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">

                        @foreach (var type in Enum.GetValues<PersonCertificateType>())
                        {
                            <MudSelectItem Value="@type">@type</MudSelectItem>
                        }
                    </MudSelect>
                }
                @if (Entity == EntityType.Vessel)
                {
                    <MudSelect T="VesselCertificateType"
                               @bind-Value="_typeVessel"
                               Label="Certificate Type"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">

                        @foreach (var type in Enum.GetValues<VesselCertificateType>())
                        {
                            <MudSelectItem Value="@type">@type</MudSelectItem>
                        }
                    </MudSelect>
                }


            </MudItem>


            <MudItem xs="12">
                <MudTextField @bind-Value="_certificateName"
                              Label="Certificate Name"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_certificateNumber"
                              Label="Certificate Number"
                              Required="false"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_issuingAuthority"
                              Label="Issuing Authority"
                              Required="false"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudDatePicker @bind-Date="_issueDateDt"
                               Label="Issue Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudDatePicker @bind-Date="_expiryDateDt"
                               Label="Expiry Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_description"
                              Label="Description"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="string.IsNullOrWhiteSpace(_certificateName)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CertificateResponse? Certificate { get; set; }
    [Parameter] public EntityType? Entity { get; set; }
    private string _certificateName = string.Empty;
    private DateTime? _issueDateDt;
    private DateTime? _expiryDateDt;
    private string? _description;
    private string? _certificateNumber;
    private string? _issuingAuthority;
    private PersonCertificateType _typePerson = PersonCertificateType.Other;
    private VesselCertificateType _typeVessel = VesselCertificateType.Other;
    protected override void OnParametersSet()
    {
        if (Certificate is null) return;
        _certificateName = Certificate.CertificateName;
        _issueDateDt = Certificate.IssueDate?.ToDateTime(TimeOnly.MinValue);
        _expiryDateDt = Certificate.ExpiryDate?.ToDateTime(TimeOnly.MinValue);
        _description = Certificate.Description;
        _certificateNumber = Certificate.CertificateNumber;
        _issuingAuthority = Certificate.IssuingAuthority;
        _typePerson = Certificate.PType ?? 0;
        _typeVessel = Certificate.VType ?? 0;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() =>
        MudDialog.Close(DialogResult.Ok(new UpsertCertificateRequest
        {
            CertificateName = _certificateName.Trim(),
            IssueDate = _issueDateDt.HasValue ? DateOnly.FromDateTime(_issueDateDt.Value) : null,
            ExpiryDate = _expiryDateDt.HasValue ? DateOnly.FromDateTime(_expiryDateDt.Value) : null,
            Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
            CertificateNumber = string.IsNullOrWhiteSpace(_certificateNumber) ? null : _certificateNumber.Trim(),
            IssuingAuthority = string.IsNullOrWhiteSpace(_issuingAuthority) ? null : _issuingAuthority.Trim(),
            PType = _typePerson,
            VType = _typeVessel
        }));
}