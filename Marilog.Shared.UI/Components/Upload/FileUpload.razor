@using MudBlazor
@namespace Marilog.Shared.UI.Components.Upload

<MudPaper @onclick="OnSelectRequested"
          @ondragenter="OnDragEnter"
          @ondragleave="OnDragLeave"
          Height="120px"
          Outlined="true"
          Class="@DropZoneClass"
          Style="display:flex; align-items:center; justify-content:center; cursor:pointer;">
    <MudStack AlignItems="AlignItems.Center" Spacing="1">
        <MudIcon Icon="@Icons.Material.Filled.CloudUpload"
                 Color="@(_isDragging ? Color.Primary : Color.Default)"
                 Size="MudBlazor.Size.Large" />
        @if (FileName is null)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Drag & drop or click to select
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Primary">@FileName</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@GetFormattedSize()</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="MudBlazor.Size.Small"
                           OnClick="Clear" />
        }
    </MudStack>
</MudPaper>