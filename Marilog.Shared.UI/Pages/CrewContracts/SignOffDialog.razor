@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.CrewContracts

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudDatePicker @bind-Date="_signOffDate"
                               Label="Sign Off Date"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   OnClick="Submit"
                   Disabled="@(_signOffDate is null)">
            Sign Off
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CrewContractResponse? Contract { get; set; }

    private DateTime? _signOffDate;

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(
        (DateOnly.FromDateTime(_signOffDate!.Value), (int?)null)
    ));
}