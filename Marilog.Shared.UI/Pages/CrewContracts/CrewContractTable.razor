@using Marilog.Contracts.DTOs.Responses
@using Marilog.Kernel.Enums
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.CrewContracts

<MudDataGrid T="CrewContractResponse"
             Items="Items"
             Hover="true"
             Dense="true"
             Striped="true"
             SelectedItem="_selected"
             SelectedItemChanged="OnRowSelectedChanged"
             Breakpoint="Breakpoint.Sm">

    <Columns>
        <PropertyColumn Property="x => x.PersonFullName" Title="Name" />
        <PropertyColumn Property="x => x.VesselName" Title="Vessel" />
        <PropertyColumn Property="x => x.RankName" Title="Rank" />
        <PropertyColumn Property="x => x.RankDepartment" Title="Dept" />
        <PropertyColumn Property="x => x.MonthlyWage" Title="Wage"
                        Format="N2" />
        <PropertyColumn Property="x => x.SignOnDate" Title="Sign On"
                        Format="dd MMM yyyy" />
        <PropertyColumn Property="x => x.SignOffDate" Title="Sign Off">
            <CellTemplate>
                @(context.Item.SignOffDate?.ToString("dd MMM yyyy") ?? "—")
            </CellTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Status" Sortable="false">
            <CellTemplate>
                <MudChip T="string"
                         Color="@(context.Item.IsActive ? Color.Success : Color.Default)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @(context.Item.IsActive ? "Active" : "Signed Off")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Validity" Sortable="false">
            <CellTemplate>
                <MudChip T="string"
                         Color="@StatusColor(context.Item.ContractStatus)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @context.Item.ContractStatus
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="" Sortable="false" CellStyle="width:120px">
            <CellTemplate>
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="() => OnEditClicked.InvokeAsync(context.Item)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => OnDeleteClicked.InvokeAsync(context.Item)" />
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>

    <NoRecordsContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
            No contracts found.
        </MudText>
    </NoRecordsContent>

</MudDataGrid>

@code {
    [Parameter] public IEnumerable<CrewContractResponse> Items { get; set; } = [];
    [Parameter] public CrewContractResponse? Selected { get; set; }
    [Parameter] public EventCallback<CrewContractResponse> OnRowSelected { get; set; }
    [Parameter] public EventCallback<CrewContractResponse> OnEditClicked { get; set; }
    [Parameter] public EventCallback<CrewContractResponse> OnDeleteClicked { get; set; }

    private CrewContractResponse? _selected;

    protected override void OnParametersSet() => _selected = Selected;

    private async Task OnRowSelectedChanged(CrewContractResponse? item)
    {
        if (item is null) return;
        _selected = item;
        await OnRowSelected.InvokeAsync(item);
    }

    private static Color StatusColor(CrewContractStatus s) => s switch
    {
        CrewContractStatus.Valied => Color.Success,
        CrewContractStatus.Expiring => Color.Warning,
        CrewContractStatus.Expired => Color.Error,
        _ => Color.Default
    };
}