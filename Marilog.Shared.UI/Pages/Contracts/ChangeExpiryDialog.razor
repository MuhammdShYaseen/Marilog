@using Marilog.Contracts.DTOs.Requests.ContractDTOs
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Contracts.Dialogs

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudDatePicker @bind-Date="_ExpiryDate"
                               Label="New Expiry Date"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_changeBy"
                              Label="Change By:"
                              Required="true"
                              RequiredError="This field is required"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
               </MudItem>

        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(_ExpiryDate is null || string.IsNullOrWhiteSpace(_changeBy))">
            Change
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime? _ExpiryDate { get; set; }
    private string? _changeBy;
    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(
        new ChangeExpiryRequest(DateOnly.FromDateTime(_ExpiryDate!.Value), _changeBy ?? "")));
}
