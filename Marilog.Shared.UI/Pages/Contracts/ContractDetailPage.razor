@page "/contracts/{Id:int}"

@using MudBlazor



@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_detail is null)
{
    <MudAlert Severity="Severity.Warning">Contract not found.</MudAlert>
}
else
{
    <MudStack Spacing="3">

        {{!-- Header --}}
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5">@_detail.ContractNumber</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_detail.Type</MudText>
            </MudStack>
            <MudChip T="string" 
                Color="@(_detail.Status switch
                     {
                          "Active" => Color.Success,
                          "Suspended" => Color.Warning,
                          "Terminated" => Color.Error,
                          "Expired" => Color.Dark,
                                    _ => Color.Default
                      })">
                @_detail.Status
            </MudChip>
        </MudStack>

        {{!-- Tabs --}}
        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

            {{!-- Tab 1: Info --}}
            <MudTabPanel Text="Info" Icon="@Icons.Material.Filled.Info">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudField Label="Effective Date" Variant="Variant.Outlined">
                            @_detail.EffectiveDate.ToShortDateString()
                        </MudField>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudField Label="Expiry Date" Variant="Variant.Outlined">
                            @(_detail.ExpiryDate?.ToShortDateString() ?? "—")
                        </MudField>
                    </MudItem>
                    @if (!string.IsNullOrWhiteSpace(_detail.Notes))
                    {
                        <MudItem xs="12">
                            <MudField Label="Notes" Variant="Variant.Outlined">
                                @_detail.Notes
                            </MudField>
                        </MudItem>
                    }
                </MudGrid>

                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Actions</MudText>
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               Disabled="@(_detail.Status == "Active")"
                               OnClick="Activate">
                        Activate
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Pause"
                               Disabled="@(_detail.Status != "Active")"
                               OnClick="Suspend">
                        Suspend
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               Disabled="@(_detail.Status is "Terminated" or "Expired")"
                               OnClick="Terminate">
                        Terminate
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Dark"
                               StartIcon="@Icons.Material.Filled.EventBusy"
                               Disabled="@(_detail.Status is "Terminated" or "Expired")"
                               OnClick="MarkExpired">
                        Mark Expired
                    </MudButton>
                </MudStack>
            </MudTabPanel>

            {{!-- Tab 2: Parties --}}
            <MudTabPanel Text="Parties" Icon="@Icons.Material.Filled.Business">
                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenAddPartyDialog">
                        Add Party
                    </MudButton>
                </MudStack>

                <MudTable Items="_detail.Parties" Hover="true" Elevation="0" Dense="true">
                    <HeaderContent>
                        <MudTh>Company</MudTh>
                        <MudTh>Role</MudTh>
                        <MudTh Style="width:120px"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.CompanyName</MudTd>
                        <MudTd>@context.Role</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="() => OpenRemovePartyDialog(context)" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText>No parties added.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>

            {{!-- Tab 3: Amendments --}}
            <MudTabPanel Text="Amendments" Icon="@Icons.Material.Filled.Edit">
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mb-3">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.DateRange"
                               OnClick="OpenChangeExpiryDialog">
                        Extend Expiry
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenRecordAmendmentDialog">
                        Record Amendment
                    </MudButton>
                </MudStack>

                <MudTable Items="_detail.Amendments" Hover="true" Elevation="0" Dense="true">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Effective Date</MudTh>
                        <MudTh>Changed By</MudTh>
                        <MudTh>Recorded At</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.AmendmentNumber</MudTd>
                        <MudTd>@context.Description</MudTd>
                        <MudTd>@context.EffectiveDate.ToShortDateString()</MudTd>
                        <MudTd>@context.ChangedBy</MudTd>
                        <MudTd>@context.RecordedAtUtc.ToLocalTime().ToString("g")</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText>No amendments recorded.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>

            {{!-- Tab 4: Documents --}}
            <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.AttachFile">
                <MudStack Spacing="3">
                    @if (!string.IsNullOrWhiteSpace(_detail.ContractFileUrl))
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Color="Color.Primary" />
                            <MudLink Href="@_detail.ContractFileUrl" Target="_blank">
                                @(_detail.ContractFileName ?? "Contract File")
                            </MudLink>
                        </MudStack>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">No file attached.</MudText>
                    }

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="OpenAttachFileDialog">
                        Attach File
                    </MudButton>
                </MudStack>
            </MudTabPanel>

        </MudTabs>
    </MudStack>
}

@code {
    [Parameter] public int Id { get; set; }
}
