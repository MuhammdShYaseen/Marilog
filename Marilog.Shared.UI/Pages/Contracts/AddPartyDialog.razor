@using Marilog.Contracts.DTOs.Requests.ContractDTOs
@using Marilog.Kernel.Enums
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Contracts.Dialogs

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_companyId"
                              Label="Company ID"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="ContractRole"
                           @bind-Value="_role"
                           Label="Role"
                           Required="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">

                    @foreach (ContractRole role in Enum.GetValues(typeof(ContractRole)))
                    {
                        <MudSelectItem Value="@role">
                            @role.ToString()
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(_companyId <= 0 || string.IsNullOrWhiteSpace(_role.ToString()))">
            Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private int _companyId;
    private ContractRole _role = ContractRole.Owner;

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(
        new PartyRequest(_companyId, _role.ToString())));
}
