@using Marilog.Contracts.DTOs.Requests.ContractDTOs
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Contracts

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_description"
                              Label="Description"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_effectiveDate"
                               Label="Effective Date"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_changedBy"
                              Label="Changed By"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_description) || _effectiveDate is null || string.IsNullOrWhiteSpace(_changedBy))">
            Record
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private string _description = string.Empty;
    private DateTime? _effectiveDate;
    private string _changedBy = string.Empty;

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(
        new AmendmentRequest(
            _description,
            DateOnly.FromDateTime(_effectiveDate!.Value),
            _changedBy
        )));
}
