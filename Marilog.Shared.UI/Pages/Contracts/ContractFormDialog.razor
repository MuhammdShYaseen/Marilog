@using Marilog.Contracts.DTOs.Requests.ContractDTOs
@using Marilog.Kernel.Enumerations
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Contracts

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_contractNumber"
                              Label="Contract Number"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="ContractType"
                           @bind-Value="_type"
                           Label="Type"
                           Required="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">

                    <MudSelectItem Value="ContractType.CharterParty">
                        Charter Party
                    </MudSelectItem>

                    <MudSelectItem Value="ContractType.Supplier">
                        Supplier
                    </MudSelectItem>

                    <MudSelectItem Value="ContractType.Agency">
                        Agency
                    </MudSelectItem>

                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_effectiveDate"
                               Label="Effective Date"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_expiryDate"
                               Label="Expiry Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_notes"
                              Label="Notes"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_contractNumber) || _type == null || _effectiveDate is null)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? ContractId { get; set; }

    private string _contractNumber = string.Empty;
    private ContractType _type = ContractType.CharterParty;
    private DateTime? _effectiveDate;
    private DateTime? _expiryDate;
    private string? _notes;

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(new 
        CreateContractRequest
        (
            _contractNumber,
            _type.Name,
            DateOnly.FromDateTime(_effectiveDate!.Value),
            _expiryDate.HasValue ? DateOnly.FromDateTime(_expiryDate.Value) : null,
            _notes
        )));
}