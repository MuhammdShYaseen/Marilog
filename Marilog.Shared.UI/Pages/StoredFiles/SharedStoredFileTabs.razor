@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.StoredFiles

@* ────────────────────────────────────────────────────────────────────────────
   SharedStoredFileTabs
   Text (editable OCR/user content) + PDF (inline preview via ?inline=true).
   SaveContentFunc returns Task<bool> to match IStoredFileService's real
   success/failure signalling for this call.
   ──────────────────────────────────────────────────────────────────────── *@
<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
    <MudTabPanel Text="Text" Icon="@Icons.Material.Filled.Description">
        @if (string.IsNullOrEmpty(File.Content))
        {
            <MudText Color="Color.Secondary" Class="py-4">
                No text content available for this file yet.
            </MudText>
        }
        else
        {
            <MudStack Spacing="2">
                <MudTextField T="string" @bind-Value="_editableContent" Lines="12"
                              Variant="Variant.Outlined" FullWidth="true" />
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                    <MudButton Variant="Variant.Text" Disabled="@(!_isContentDirty)" OnClick="ResetContent">
                        Discard
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@(!_isContentDirty || _isSavingContent)" OnClick="SaveContentAsync">
                        @(_isSavingContent ? "Saving..." : "Save")
                    </MudButton>
                </MudStack>
            </MudStack>
        }
    </MudTabPanel>

    <MudTabPanel Text="PDF" Icon="@Icons.Material.Filled.PictureAsPdf">
        @if (IsPdf())
        {
            @* MudBlazor has no iframe-equivalent component; this raw tag is a required exception. *@
            <iframe src="@($"{DownloadUrl}?inline=true")" class="pdf-preview-frame"></iframe>
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-8">
                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Color="Color.Secondary">Preview is only available for PDF files.</MudText>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" Href="@DownloadUrl" Target="_blank">
                    Download instead
                </MudButton>
            </MudStack>
        }
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter, EditorRequired] public StoredFileResponse File { get; set; } = default!;
    [Parameter, EditorRequired] public string DownloadUrl { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ThumbnailUrl { get; set; } = string.Empty;

    /// <summary>Host wires this to IStoredFileService.UpdateContentFromUserAsync(id, content, ct),
    /// wrapped to report success/failure per this call's actual usage pattern.</summary>
    [Parameter] public Func<int, string, CancellationToken, Task<bool>>? SaveContentFunc { get; set; }

    [Inject] ISnackbar Snackbar { get; set; } = default!;

    string _editableContent = string.Empty;
    int? _loadedFileId;
    bool _isSavingContent;

    bool _isContentDirty => _editableContent != (File.Content ?? string.Empty);

    protected override void OnParametersSet()
    {
        if (_loadedFileId == File.Id)
            return;

        _loadedFileId = File.Id;
        _editableContent = File.Content ?? string.Empty;
    }

    void ResetContent() => _editableContent = File.Content ?? string.Empty;

    async Task SaveContentAsync()
    {
        if (SaveContentFunc is null)
        {
            Snackbar.Add("Saving content isn't available yet.", Severity.Info);
            return;
        }

        _isSavingContent = true;
        try
        {
            var success = await SaveContentFunc(File.Id, _editableContent, CancellationToken.None);
            if (success)
                Snackbar.Add("Content saved.", Severity.Success);
            else
                Snackbar.Add("Failed to save content.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save content: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSavingContent = false;
        }
    }

    bool IsPdf() => string.Equals(File.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase);
}
