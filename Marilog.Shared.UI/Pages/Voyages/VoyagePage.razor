@using Marilog.Contracts.DTOs.Responses
@using Marilog.Shared.UI.Pages.BillOfLading
@using Marilog.Shared.UI.Pages.Documents
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Voyages

@if (SelectedVoyage is null)
{
    <MudTabs ActivePanelIndexChanged="OnTabChanged" Elevation="0" Rounded="true" Class="mb-3">
        @*All*@
        <MudTabPanel Text="All">
            <VoyageTable Voyages="Voyages"
                         IsLoading="IsLoading"
                         OnAddClicked="OnAddClicked"
                         OnViewClicked="OnViewClicked"
                         OnEditClicked="OnEditClicked"
                         OnDeleteClicked="OnDeleteClicked" />
        </MudTabPanel>

        @* ── By Vessel ─────────────────────────────────────────── *@
        <MudTabPanel Text="By Vessel">
            <MudSelect T="int?"
                       Value="_selectedVesselId"
                       ValueChanged="OnVesselChanged"
                       Label="Select Vessel"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="mb-3"
                       Style="max-width:250px">
                <MudSelectItem T="int?" Value="null">All Vessels</MudSelectItem>
                @foreach (var vessel in Vessels)
                {
                    <MudSelectItem T="int?" Value="@((int?)vessel.Id)">@vessel.Name</MudSelectItem>
                }
            </MudSelect>
            <VoyageTable   Voyages="ByVessel"
                           IsLoading="IsLoading"
                           OnAddClicked="OnAddClicked"
                           OnViewClicked="OnViewClicked"
                           OnEditClicked="OnEditClicked"
                           OnDeleteClicked="OnDeleteClicked" />
        </MudTabPanel>


    </MudTabs>
    
}
else
{
    <div class="d-flex align-center mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="OnBackClicked" />
        <MudBreadcrumbs Items="_breadcrumbs" />
    </div>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">

        @* Tab 1: Overview *@
        <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Info">
            <MudGrid Class="mt-2">

                @* Header Card *@
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Voyage Number</MudText>
                                <MudText Typo="Typo.h6">@SelectedVoyage.VoyageNumber</MudText>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Vessel</MudText>
                                <MudText Typo="Typo.body1">@SelectedVoyage.VesselName</MudText>
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudText Typo="Typo.caption">Month</MudText>
                                <MudText Typo="Typo.body1">@SelectedVoyage.VoyageMonth.ToString("MMM yyyy")</MudText>
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudText Typo="Typo.caption">Status</MudText>
                                <MudChip T="string"
                                         Color="@GetStatusColor(SelectedVoyage.Status.ToString())"
                                         Size="Size.Small">
                                    @SelectedVoyage.Status
                                </MudChip>
                            </MudItem>
                            <MudItem xs="12" md="2" Class="d-flex align-center gap-2">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               OnClick="@(() => OnEditClicked.InvokeAsync(SelectedVoyage))"
                                               @onclick:stopPropagation="true" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => OnDeleteClicked.InvokeAsync(SelectedVoyage))"
                                               @onclick:stopPropagation="true" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                @* Cargo Info *@
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Departure Port</MudText>
                                <MudText Typo="Typo.body1">@(SelectedVoyage.DeparturePortName ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Arrival Port</MudText>
                                <MudText Typo="Typo.body1">@(SelectedVoyage.ArrivalPortName ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Departure Date</MudText>
                                <MudText Typo="Typo.body1">@(SelectedVoyage.DepartureDate?.ToString("dd MMM yyyy HH:mm") ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Arrival Date</MudText>
                                <MudText Typo="Typo.body1">@(SelectedVoyage.ArrivalDate?.ToString("dd MMM yyyy HH:mm") ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Cargo Type</MudText>
                                <MudText Typo="Typo.body1">@(SelectedVoyage.CargoType ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudText Typo="Typo.caption">Cargo Quantity (MT)</MudText>
                                <MudText Typo="Typo.body1">@(SelectedVoyage.CargoQuantityMT?.ToString("N3") ?? "—")</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                @* Stops Timeline *@
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Port Stops</MudText>
                    @if (SelectedVoyage.Stops is { Count: > 0 })
                    {
                        @foreach (var stop in SelectedVoyage.Stops.OrderBy(s => s.StopOrder))
                        {
                            <VoyageStopCard Stop="stop" />
                        }
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">No stops recorded.</MudText>
                    }
                    <MudButton StartIcon="@Icons.Material.Filled.AddLocation"
                               Variant="Variant.Outlined"
                               Class="mt-2"
                               OnClick="OnAddStopClicked">
                        Add Stop
                    </MudButton>
                </MudItem>

            </MudGrid>
        </MudTabPanel>

        @* Tab 2: Bills of Lading *@
        <MudTabPanel Text="Bills of Lading" Icon="@Icons.Material.Filled.Description">
            <BillOfLadingTable BillsOfLading="BillsOfLading"
                               OnAddClicked="OnAddBillClicked"
                               OnEditClicked="OnEditBillClicked"
                               OnDeleteClicked="OnDeleteBillClicked"
                               OnViewClicked="OnViewBillClicked" />
        </MudTabPanel>

       @*Tab 3 : Documents*@
        <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.Pages">
            <DocumentTable Items="Docs" />
        </MudTabPanel>

    </MudTabs>
}

@code {
    private int? _selectedVesselId;
    // ── Voyage list ───────────────────────────────────────────────────────────
    [Parameter, EditorRequired] public IReadOnlyList<VoyageResponse> Voyages { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<VesselResponse> Vessels { get; set; } = [];
    [Parameter] public IReadOnlyList<VoyageResponse> ByVessel { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }

    // ── Selected voyage detail ────────────────────────────────────────────────
    [Parameter] public VoyageResponse? SelectedVoyage { get; set; }
    [Parameter] public IReadOnlyList<BillOfLadingResponse> BillsOfLading { get; set; } = [];
    [Parameter] public bool IsBillsLoading { get; set; }

    // ── Voyage callbacks ──────────────────────────────────────────────────────
    [Parameter] public EventCallback OnAddClicked { get; set; }
    [Parameter] public EventCallback<VoyageResponse> OnViewClicked { get; set; }
    [Parameter] public EventCallback<VoyageResponse> OnEditClicked { get; set; }
    [Parameter] public EventCallback<VoyageResponse> OnDeleteClicked { get; set; }
    [Parameter] public EventCallback OnAddStopClicked { get; set; }
    [Parameter] public EventCallback OnBackClicked { get; set; }
    [Parameter] public EventCallback<int?> OnVesselSelected { get; set; }

    // ── BL callbacks ──────────────────────────────────────────────────────────
    [Parameter] public EventCallback OnAddBillClicked { get; set; }
    [Parameter] public EventCallback<BillOfLadingResponse> OnViewBillClicked { get; set; }
    [Parameter] public EventCallback<BillOfLadingResponse> OnEditBillClicked { get; set; }
    [Parameter] public EventCallback<BillOfLadingResponse> OnDeleteBillClicked { get; set; }


    //----Documents--------------------------------------------------------------
    [Parameter] public IReadOnlyList<DocumentResponse> Docs { get; set; } = [];


    private List<BreadcrumbItem> _breadcrumbs =>
    [
        new("Voyages", href: "/voyages", icon: Icons.Material.Filled.Sailing),
        new(SelectedVoyage?.VoyageNumber ?? string.Empty, href: null, disabled: true)
    ];

    private static Color GetStatusColor(string? status) => status switch
    {
        "Active" => Color.Success,
        "Completed" => Color.Info,
        "Cancelled" => Color.Error,
        _ => Color.Default
    };

    private void OnVesselChanged(int? vesselId)
    {
        _selectedVesselId = vesselId;
        Console.WriteLine($"[DEBUG] OnVesselChanged fired: {vesselId}");
        OnVesselSelected.InvokeAsync(vesselId);
    }

    private void OnTabChanged(int index)
    {
        _selectedVesselId = null;
        OnVesselSelected.InvokeAsync(null); // ← tell host to clear _byVessel too
    }
}