@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.SwiftTransfer
@* ────────────────────────────────────────────────────────────────────────────
   SharedSwiftTransferTable
   Stateless list rendering (List view only — no Grid toggle for this entity).
   Data in via Items, every row action out via EventCallback. No service refs.
   ──────────────────────────────────────────────────────────────────────── *@
<MudTable Items="@Items" Hover="true" Dense="true" Loading="@IsLoading"
          RowClassFunc="@RowClassFunc" OnRowClick="@(e => OnRowSelected.InvokeAsync(e.Item))"
          T="SwiftTransferResponse">
    <HeaderContent>
        <MudTh>Reference</MudTh>
        <MudTh>Date</MudTh>
        <MudTh>Currency</MudTh>
        <MudTh Style="text-align:right">Amount</MudTh>
        <MudTh Style="text-align:right">Unallocated</MudTh>
        <MudTh>Sender</MudTh>
        <MudTh>Receiver</MudTh>
        <MudTh>Status</MudTh>
        <MudTh Style="text-align:right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Reference">@context.SwiftReference</MudTd>
        <MudTd DataLabel="Date">@context.TransactionDate.ToString("yyyy-MM-dd")</MudTd>
        <MudTd DataLabel="Currency">@context.CurrencyCode</MudTd>
        <MudTd DataLabel="Amount" Style="text-align:right">@context.Amount.ToString("N2")</MudTd>
        <MudTd DataLabel="Unallocated" Style="text-align:right">@context.UnallocatedAmount.ToString("N2")</MudTd>
        <MudTd DataLabel="Sender">@(context.SenderCompanyName ?? "—")</MudTd>
        <MudTd DataLabel="Receiver">@(context.ReceiverCompanyName ?? "—")</MudTd>
        <MudTd DataLabel="Status">
            @if (context.IsFullyAllocated)
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">Allocated</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Partial</MudChip>
            }
            @if (!context.IsActive)
            {
                <MudChip T="string" Color="Color.Default" Size="Size.Small">Inactive</MudChip>
            }
        </MudTd>
        <MudTd Style="text-align:right">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                            onclick="@(EventCallback.Factory.Create(this, () => OnEditClicked.InvokeAsync(context)))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                            onclick="@(EventCallback.Factory.Create(this, () => OnDeleteClicked.InvokeAsync(context)))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No SWIFT transfers found.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading SWIFT transfers...</MudText>
    </LoadingContent>
</MudTable>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<SwiftTransferResponse> Items { get; set; } = null!;
    [Parameter] public SwiftTransferResponse? SelectedItem { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    [Parameter, EditorRequired] public EventCallback<SwiftTransferResponse> OnRowSelected { get; set; }
    [Parameter, EditorRequired] public EventCallback<SwiftTransferResponse> OnEditClicked { get; set; }
    [Parameter, EditorRequired] public EventCallback<SwiftTransferResponse> OnDeleteClicked { get; set; }

    string RowClassFunc(SwiftTransferResponse item, int index) =>
        SelectedItem is not null && item.Id == SelectedItem.Id ? "mud-theme-primary-hover selected-row" : string.Empty;
}
