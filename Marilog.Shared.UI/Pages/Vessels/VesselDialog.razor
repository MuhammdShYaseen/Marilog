@* VesselDialog.razor *@
@using Marilog.Contracts.DTOs.Requests.VesselDTOs
@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Vessels

<MudDialog>

    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Vessel is null
                                                   ? Icons.Material.Filled.Add
                                                   : Icons.Material.Filled.Edit)"
                     Class="mr-2" />
            @(Vessel is null ? "New Vessel" : "Edit Vessel")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid>

            <MudItem xs="12" sm="6">
                <MudSelect T="int"
                           @bind-Value="_companyId"
                           Label="Company"
                           Required="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var c in Companies)
                    {
                        <MudSelectItem T="int" Value="c.Id">@c.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_vesselName"
                              Label="Vessel Name"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_imoNumber"
                              Label="IMO Number"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="decimal?"
                                 @bind-Value="_grossTonnage"
                                 Label="Gross Tonnage"
                                 Min="0"
                                 Format="N0"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                           @bind-Value="_flagCountryId"
                           Label="Flag Country"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem T="int?" Value="null">— None —</MudSelectItem>
                    @foreach (var c in Countries)
                    {
                        <MudSelectItem T="int?" Value="(int?)c.Id">@c.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_notes"
                              Label="Notes"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="2" />
            </MudItem>

        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!IsValid)"
                   OnClick="Submit">
            Save
        </MudButton>
    </DialogActions>

</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public VesselResponse? Vessel { get; set; }
    [Parameter] public IReadOnlyList<CompanyResponse> Companies { get; set; } = [];
    [Parameter] public IReadOnlyList<CountryResponse> Countries { get; set; } = [];

    private int _companyId;
    private string _vesselName = string.Empty;
    private string? _imoNumber;
    private decimal? _grossTonnage;
    private int? _flagCountryId;
    private string? _notes;

    private bool IsValid => _companyId > 0 && !string.IsNullOrWhiteSpace(_vesselName);

    protected override void OnParametersSet()
    {
        if (Vessel is null) return;
        _companyId = Vessel.CompanyId;
        _vesselName = Vessel.Name;
        _imoNumber = Vessel.IMONumber;
        _grossTonnage = Vessel.GrossTonnage;
        _flagCountryId = Vessel.FlagCountryId;
        _notes = Vessel.Notes;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (Vessel is null)
        {
            MudDialog.Close(DialogResult.Ok(new CreateVesselRequest(
                _companyId,
                _vesselName,
                _imoNumber,
                _grossTonnage,
                _flagCountryId,
                _notes)));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(new UpdateVesselRequest(
                _vesselName,
                _imoNumber,
                _grossTonnage,
                _flagCountryId,
                _notes)));
        }
    }
}