@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Documents

<MudDataGrid T="DocumentResponse"
             Items="Items"
             Hover="true"
             Dense="true"
             Striped="true"
             Breakpoint="Breakpoint.Sm">

    <Columns>

        <HierarchyColumn T="DocumentResponse"
                         ButtonDisabledFunc="x => !x.HasChildren" />

        <TemplateColumn Title="Doc No."
                        SortBy="x => x.DocNumber">
            <CellTemplate>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    @if (context.Item.Depth > 0)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowRight"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Style="@($"margin-left:{context.Item.Depth * 16}px")" />
                    }
                    <MudLink OnClick="() => OnRowClick.InvokeAsync(context.Item)"
                             Style="cursor:pointer">
                        @context.Item.DocNumber
                    </MudLink>
                </MudStack>
            </CellTemplate>
        </TemplateColumn>

        <PropertyColumn Property="x => x.DocTypeName" Title="Type" />
        <PropertyColumn Property="x => x.DocDate" Title="Date" />
        <PropertyColumn Property="x => x.SupplierName" Title="Supplier" />
        <PropertyColumn Property="x => x.VesselName" Title="Vessel" />
        <PropertyColumn Property="x => x.CurrencyCode" Title="Currency" />
        <PropertyColumn Property="x => x.TotalAmount" Title="Total" Format="N2" />
        <PropertyColumn Property="x => x.TotalPaid" Title="Paid" Format="N2" />

        <TemplateColumn Title="Balance" SortBy="x => x.RemainingBalance">
            <CellTemplate>
                <MudText Color="@(context.Item.RemainingBalance > 0 ? Color.Warning : Color.Success)">
                    @context.Item.RemainingBalance.ToString("N2")
                </MudText>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Status" SortBy="x => x.IsFullyPaid">
            <CellTemplate>
                <MudChip T="string"
                         Color="@(context.Item.IsFullyPaid ? Color.Success : Color.Warning)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @(context.Item.IsFullyPaid ? "Paid" : "Unpaid")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="" Sortable="false" CellStyle="width:120px">
            <CellTemplate>
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="() => OnEditClicked.InvokeAsync(context.Item)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => OnDeleteClicked.InvokeAsync(context.Item)" />
                </MudStack>
            </CellTemplate>
        </TemplateColumn>

    </Columns>

    <ChildRowContent>
        @foreach (var child in context.Item.Children)
        {
            <MudTr>
                <MudTd />
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowRight"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Style="@($"margin-left:{child.Depth * 16}px")" />
                        <MudLink OnClick="() => OnRowClick.InvokeAsync(child)"
                                 Style="cursor:pointer; font-weight:500">
                            @child.DocNumber
                        </MudLink>
                    </MudStack>
                </MudTd>
                <MudTd>@(child.DocTypeName ?? "—")</MudTd>
                <MudTd>@child.DocDate.ToString("dd MMM yyyy")</MudTd>
                <MudTd>@(child.SupplierName ?? "—")</MudTd>
                <MudTd>@(child.VesselName ?? "—")</MudTd>
                <MudTd>@child.CurrencyCode</MudTd>
                <MudTd>@child.TotalAmount.ToString("N2")</MudTd>
                <MudTd>@child.TotalPaid.ToString("N2")</MudTd>
                <MudTd>
                    <MudText Color="@(child.RemainingBalance > 0 ? Color.Warning : Color.Success)">
                        @child.RemainingBalance.ToString("N2")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string"
                             Color="@(child.IsFullyPaid ? Color.Success : Color.Warning)"
                             Size="Size.Small"
                             Variant="Variant.Filled">
                        @(child.IsFullyPaid ? "Paid" : "Unpaid")
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => OnEditClicked.InvokeAsync(child)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="() => OnDeleteClicked.InvokeAsync(child)" />
                    </MudStack>
                </MudTd>
            </MudTr>

            @* أحفاد — مستوى ثانٍ *@
            @foreach (var grandchild in child.Children)
            {
                <MudTr Style="background: var(--mud-palette-background-grey)">
                    <MudTd />
                    <MudTd>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowRight"
                                     Size="Size.Small"
                                     Color="Color.Secondary"
                                     Style="@($"margin-left:{grandchild.Depth * 16}px")" />
                            <MudLink OnClick="() => OnRowClick.InvokeAsync(grandchild)"
                                     Style="cursor:pointer">
                                @grandchild.DocNumber
                            </MudLink>
                        </MudStack>
                    </MudTd>
                    <MudTd>@(grandchild.DocTypeName ?? "—")</MudTd>
                    <MudTd>@grandchild.DocDate.ToString("dd MMM yyyy")</MudTd>
                    <MudTd>@(grandchild.SupplierName ?? "—")</MudTd>
                    <MudTd>@(grandchild.VesselName ?? "—")</MudTd>
                    <MudTd>@grandchild.CurrencyCode</MudTd>
                    <MudTd>@grandchild.TotalAmount.ToString("N2")</MudTd>
                    <MudTd>@grandchild.TotalPaid.ToString("N2")</MudTd>
                    <MudTd>
                        <MudText Color="@(grandchild.RemainingBalance > 0 ? Color.Warning : Color.Success)">
                            @grandchild.RemainingBalance.ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Color="@(grandchild.IsFullyPaid ? Color.Success : Color.Warning)"
                                 Size="Size.Small"
                                 Variant="Variant.Filled">
                            @(grandchild.IsFullyPaid ? "Paid" : "Unpaid")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => OnEditClicked.InvokeAsync(grandchild)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="() => OnDeleteClicked.InvokeAsync(grandchild)" />
                        </MudStack>
                    </MudTd>
                </MudTr>
            }
        }
    </ChildRowContent>

    <NoRecordsContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
            No documents found.
        </MudText>
    </NoRecordsContent>

</MudDataGrid>

@code {
    [Parameter] public IEnumerable<DocumentResponse> Items { get; set; } = [];
    [Parameter] public EventCallback<DocumentResponse> OnRowClick { get; set; }
    [Parameter] public EventCallback<DocumentResponse> OnEditClicked { get; set; }
    [Parameter] public EventCallback<DocumentResponse> OnDeleteClicked { get; set; }
}
