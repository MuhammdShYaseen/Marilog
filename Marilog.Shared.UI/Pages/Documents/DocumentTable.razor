@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Documents

<MudDataGrid T="DocumentResponse"
             Items="Items"
             Hover="true"
             Dense="true"
             Striped="true"
             Breakpoint="Breakpoint.Sm">

    <Columns>

        <TemplateColumn Title="Doc No."
                        SortBy="x => x.DocNumber">
            <CellTemplate>
                <MudLink OnClick="() => OnRowClick.InvokeAsync(context.Item)"
                         Style="cursor:pointer">
                    @context.Item.DocNumber
                </MudLink>
            </CellTemplate>
        </TemplateColumn>

        <PropertyColumn Property="x => x.DocTypeName"
                        Title="Type" />

        <PropertyColumn Property="x => x.DocDate"
                        Title="Date" />

        <PropertyColumn Property="x => x.SupplierName"
                        Title="Supplier" />

        <PropertyColumn Property="x => x.VesselName"
                        Title="Vessel" />

        <PropertyColumn Property="x => x.CurrencyCode"
                        Title="Currency" />

        <PropertyColumn Property="x => x.TotalAmount"
                        Title="Total"
                        Format="N2" />

        <PropertyColumn Property="x => x.TotalPaid"
                        Title="Paid"
                        Format="N2" />

        <TemplateColumn Title="Balance"
                        SortBy="x => x.RemainingBalance">
            <CellTemplate>
                <MudText Color="@(context.Item.RemainingBalance > 0
                                             ? Color.Warning
                                             : Color.Success)">
                    @context.Item.RemainingBalance.ToString("N2")
                </MudText>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Status"
                        SortBy="x => x.IsFullyPaid">
            <CellTemplate>
                <MudChip T="string"
                         Color="@(context.Item.IsFullyPaid
                                                      ? Color.Success
                                                      : Color.Warning)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @(context.Item.IsFullyPaid ? "Paid" : "Unpaid")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title=""
                        Sortable="false"
                        CellStyle="width:120px">
            <CellTemplate>
                <MudStack Row="true" Spacing="1">

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="() => OnEditClicked.InvokeAsync(context.Item)" />

                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => OnDeleteClicked.InvokeAsync(context.Item)" />

                </MudStack>
            </CellTemplate>
        </TemplateColumn>

    </Columns>

    <NoRecordsContent>
        <MudText Typo="Typo.body2"
                 Color="Color.Secondary"
                 Class="pa-4">
            No documents found.
        </MudText>
    </NoRecordsContent>

</MudDataGrid>

@code {
    [Parameter] public IEnumerable<DocumentResponse> Items { get; set; } = [];
    [Parameter] public EventCallback<DocumentResponse> OnRowClick { get; set; }
    [Parameter] public EventCallback<DocumentResponse> OnEditClicked { get; set; }
    [Parameter] public EventCallback<DocumentResponse> OnDeleteClicked { get; set; }
}