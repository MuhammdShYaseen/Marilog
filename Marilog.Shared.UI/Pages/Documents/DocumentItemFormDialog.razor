@using Marilog.Contracts.DTOs.Requests.DocumentDTOs
@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Documents

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_productName"
                              Label="Product Name"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="4">
                <MudNumericField @bind-Value="_quantity"
                                 Label="Quantity"
                                 Required="true"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="4">
                <MudNumericField @bind-Value="_unitPrice"
                                 Label="Unit Price"
                                 Required="true"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField @bind-Value="_unit"
                              Label="Unit"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_productName) || _quantity <= 0 || _unitPrice <= 0)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DocumentItemResponse? Item { get; set; }

    private string _productName = string.Empty;
    private decimal _quantity;
    private decimal _unitPrice;
    private string? _unit;

    protected override void OnParametersSet()
    {
        if (Item is null) return;
        _productName = Item.ProductName;
        _quantity = Item.Quantity;
        _unitPrice = Item.UnitPrice;
        _unit = Item.Unit;
    }

    private void Cancel() => MudDialog.Cancel();

    // Option 2: Create a dedicated DTO(best practice)
    private void Submit() => MudDialog.Close(DialogResult.Ok(new AddDocumentItemRequest
    {
        ProductName = _productName,
        Quantity = _quantity,
        UnitPrice = _unitPrice,
        Unit = _unit
    }));
}