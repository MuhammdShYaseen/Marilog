@using Marilog.Contracts.DTOs.Requests.DocumentDTOs
@using Marilog.Contracts.DTOs.Responses
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Documents

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(Document is null ? "Create Document" : "Edit Document")
        </MudText>
    </TitleContent>

    <DialogContent>

        <MudGrid Spacing="2">

            <MudItem xs="12" sm="6">
                <MudTextField T="string"
                              @bind-Value="_DocNumber"
                              Label="Document Number"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_docDateTime"
                               Label="Document Date"
                               Editable="true"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="decimal"
                                 @bind-Value="_TotalAmount"
                                 Label="Total Amount"
                                 Required="true"
                                 Min="0"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int"
                           @bind-Value="_DocTypeId"
                           Label="Document Type"
                           Required="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">

                    <MudSelectItem Value="1">Invoice</MudSelectItem>
                    <MudSelectItem Value="2">Receipt</MudSelectItem>
                    <MudSelectItem Value="3">Debit Note</MudSelectItem>

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int"
                           @bind-Value="_CurrencyId"
                           Label="Currency"
                           Required="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">

                    <MudSelectItem Value="1">USD</MudSelectItem>
                    <MudSelectItem Value="2">EUR</MudSelectItem>
                    <MudSelectItem Value="3">LKR</MudSelectItem>

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int?"
                                 @bind-Value="_SupplierId"
                                 Label="Supplier Id"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int?"
                                 @bind-Value="_BuyerId"
                                 Label="Buyer Id"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int?"
                                 @bind-Value="_VesselId"
                                 Label="Vessel Id"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int?"
                                 @bind-Value="_PortId"
                                 Label="Port Id"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int?"
                                 @bind-Value="_ParentDocumentId"
                                 Label="Parent Document Id"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="string"
                              @bind-Value="_FilePath"
                              Label="File Path"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string"
                              @bind-Value="_Reference"
                              Label="Reference"
                              Lines="3"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>

        </MudGrid>

    </DialogContent>

    <DialogActions>

        <MudButton OnClick="Cancel"
                   Variant="Variant.Text">
            Cancel
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!IsValid)">
            Save
        </MudButton>

    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public DocumentResponse? Document { get; set; }

    [Parameter]
    public IReadOnlyList<CurrencyResponse> Currencies { get; set; } = [];

    [Parameter]
    public IReadOnlyList<VesselResponse> Vessels { get; set; } = [];

    [Parameter]
    public IReadOnlyList<DocumentTypeResponse> DocTypes { get; set; } = [];

    [Parameter]
    public IReadOnlyList<CompanyResponse> Companies { get; set; } = [];

    [Parameter]
    public IReadOnlyList<DocumentResponse> AllDocs { get; set; } = [];

    private string?   _DocNumber;
    private decimal   _TotalAmount;
    private string?   _Reference;
    private DateOnly? _docDate;

    private DateTime? _docDateTime
    {
        get => _docDate?.ToDateTime(TimeOnly.MinValue);
        set => _docDate = value.HasValue
            ? DateOnly.FromDateTime(value.Value)
            : null;
    }
    private int _DocTypeId;
    private int _CurrencyId;

    private int? _SupplierId;
    private int? _BuyerId;
    private int? _VesselId;
    private int? _PortId;
    private int? _ParentDocumentId;
    private string? _FilePath;

    private bool IsValid =>
       !string.IsNullOrWhiteSpace(_DocNumber)
        && _docDate is not null
        && _DocTypeId > 0
        && _CurrencyId > 0
        && _TotalAmount > 0;

    protected override void OnParametersSet()
    {
        if (Document is null)
            return;

        // تعبئة جميع الحقول
        _DocNumber = Document.DocNumber;
        _TotalAmount = Document.TotalAmount;
        _Reference = Document.Reference;
        _DocTypeId = Document.DocTypeId;      
        _CurrencyId = Document.CurrencyId;    
        _SupplierId = Document.SupplierId;
        _BuyerId = Document.BuyerId;
        _VesselId = Document.VesselId;
        _PortId = Document.PortId;
        _ParentDocumentId = Document.ParentDocumentId;
        _FilePath = Document.FilePath;
        if (Document == null)
            return;
        _docDate = Document.DocDate;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    
    private void Submit()
    {
        if (Document is null)
        {
            MudDialog.Close(DialogResult.Ok(new CreateDocumentRequest
            {
                 DocDate = _docDate!.Value,
                 SupplierId = _SupplierId,
                 VesselId = _VesselId,
                 CurrencyId = _CurrencyId,
                 BuyerId = _BuyerId,
                 DocNumber = _DocNumber ?? "NON",
                 DocTypeId = _DocTypeId,
                 FilePath = _FilePath,
                 ParentDocumentId = _ParentDocumentId,
                 PortId = _PortId,
                 Reference = _Reference,
                 TotalAmount = _TotalAmount,
            }));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(new UpdateDocumentRequest
            {
                DocDate = _docDate!.Value,
                SupplierId = _SupplierId,
                VesselId = _VesselId,
                CurrencyId = _CurrencyId,
                BuyerId = _BuyerId,
                DocNumber = _DocNumber ?? "NON",
                DocTypeId = _DocTypeId,
                FilePath = _FilePath,
                ParentDocumentId = _ParentDocumentId,
                PortId = _PortId,
                Reference = _Reference,
                TotalAmount = _TotalAmount,
            }));
        }
    }
}