@using Marilog.Contracts.DTOs.Requests.DocumentDTOs
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Kernel.Enums
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Documents

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(Document is null ? "Create Document" : "Edit Document")
        </MudText>
    </TitleContent>

    <DialogContent>

        <MudGrid Spacing="2">

            <MudItem xs="12" sm="6">
                <MudTextField T="string"
                @bind-Value="_DocNumber"
                Label="Document Number"
                Required="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_docDateTime"
                Label="Document Date"
                Editable="true"
                Required="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="decimal"
                @bind-Value="_TotalAmount"
                Label="Total Amount"
                Required="true"
                Min="0"
                Variant="Variant.Outlined"
                Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int"
                @bind-Value="_DocTypeId"
                Label="Document Type"
                Required="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense">

                    @foreach (var type in DocTypes)
                    {
                        <MudSelectItem Value="@type.Id">
                            @type.Name
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>


            <MudItem xs="12" sm="6">
                <MudSelect T="FinancialSide?"
                           @bind-Value="_Side"
                           Label="Financial Side"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">

                    @foreach (var item in Enum.GetValues<FinancialSide>())
                    {
                        <MudSelectItem T="FinancialSide?" Value="@item">
                            @item.ToString()
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int"
                @bind-Value="_CurrencyId"
                Label="Currency"
                Required="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense">

                    @foreach (var currency in Currencies)
                    {
                        <MudSelectItem Value="@currency.Id">
                            @currency.Code
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                @bind-Value="_SupplierId"
                Label="Supplier"
                Clearable="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense">

                    @foreach (var company in Companies)
                    {
                        <MudSelectItem Value="@((int?)company.Id)">
                            @company.Name
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                @bind-Value="_BuyerId"
                Label="Buyer"
                Clearable="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense">

                    @foreach (var company in Companies)
                    {
                        <MudSelectItem Value="@((int?)company.Id)">
                            @company.Name
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                           Value="_VesselId"
                           ValueChanged="OnVesselChanged"
                           Label="Vessel"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var vessel in Vessels)
                    {
                        <MudSelectItem Value="@((int?)vessel.Id)">@vessel.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                @bind-Value="_PortId"
                Label="Port"
                Clearable="true"
                Variant="Variant.Outlined"
                Margin="Margin.Dense">

                    @foreach (var port in Ports)
                    {
                        <MudSelectItem Value="@((int?)port.Id)">
                            @port.Name
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                           @bind-Value="_ParentDocumentId"
                           Label="Parent Document"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           ToStringFunc="@(id => AllDocs.FirstOrDefault(x => x.Id == id)?.DocNumber ?? "")">

                    @foreach (var doc in AllDocs.Where(x => x.Id != Document?.Id))
                    {
                        <MudSelectItem T="int?" Value="@((int?)doc.Id)">
                            <div style="display:flex; flex-direction:column; gap:2px; padding: 2px 0">
                                <div style="display:flex; justify-content:space-between; align-items:center; gap:16px">
                                    <MudText Typo="Typo.body2" Style="font-weight:600">@doc.DocNumber</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight:600">
                                        @doc.TotalAmount.ToString("N2") @doc.CurrencyCode
                                    </MudText>
                                </div>
                                <div style="display:flex; gap:8px; flex-wrap:wrap">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@doc.DocTypeName</MudChip>
                                    @if (!string.IsNullOrEmpty(doc.SupplierName))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@doc.SupplierName</MudChip>
                                    }
                                    @if (!string.IsNullOrEmpty(doc.PortName))
                                    {
                                        <MudChip T="string" Icon="@Icons.Material.Filled.Anchor" Size="Size.Small" Variant="Variant.Outlined">@doc.PortName</MudChip>
                                    }
                                    <MudText Typo="Typo.caption" Style="align-self:center; opacity:0.7">@doc.DocDate.ToString("dd MMM yyyy")</MudText>
                                </div>
                            </div>
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>



            <MudItem xs="12" sm="6">
                <MudSelect T="int?"
                           @bind-Value="_VoyageId"
                           Label="Voyage"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           ToStringFunc="@(id => AllVoyages.FirstOrDefault(x => x.VoyageId == id)?.VoyageNumber ?? "")">

                    @foreach (var voy in AllVoyages.Where(x => x.VoyageId != Voyage?.VoyageId))
                    {
                        <MudSelectItem T="int?" Value="@((int?)voy.VoyageId)">
                            <div style="display:flex; flex-direction:column; gap:2px; padding: 2px 0">
                                <div style="display:flex; justify-content:space-between; align-items:center; gap:16px">
                                    <MudText Typo="Typo.body2" Style="font-weight:600">@voy.VoyageNumber</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight:600">
                                        Departure : @voy.DeparturePortName Arrival : @voy.ArrivalPortName
                                    </MudText>
                                </div>
                                <div style="display:flex; gap:8px; flex-wrap:wrap">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Type : @voy.CargoType</MudChip>
                                    <MudText Typo="Typo.caption" Style="align-self:center; opacity:0.7">Departure Date : @voy.DepartureDate?.ToString("dd MMM yyyy")</MudText>
                                    <MudText Typo="Typo.caption" Style="align-self:center; opacity:0.7">Arrival Date : @voy.ArrivalDate?.ToString("dd MMM yyyy")</MudText>
                                </div>
                            </div>
                        </MudSelectItem>
                    }

                </MudSelect>
            </MudItem>



            <MudItem xs="12">
                <MudTextField T="string"
                @bind-Value="_Reference"
                Label="Reference"
                Lines="3"
                Variant="Variant.Outlined"
                Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12">

            </MudItem>

        </MudGrid>

    </DialogContent>

    <DialogActions>

        <MudButton OnClick="Cancel"
        Variant="Variant.Text">
            Cancel
        </MudButton>

        <MudButton Color="Color.Primary"
        Variant="Variant.Filled"
        OnClick="Submit"
        Disabled="@(!IsValid)">
            Save
        </MudButton>

    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]public DocumentResponse? Document { get; set; }
    [Parameter] public VoyageResponse? Voyage { get; set; }

    [Parameter]public IReadOnlyList<CurrencyResponse> Currencies { get; set; }   = [];

    [Parameter]public IReadOnlyList<VesselResponse> Vessels { get; set; }        = [];

    [Parameter]public IReadOnlyList<DocumentTypeResponse> DocTypes { get; set; } = [];

    [Parameter]public IReadOnlyList<CompanyResponse> Companies { get; set; }     = [];

    [Parameter]public IReadOnlyList<PortResponse> Ports { get; set; }            = [];

    [Parameter]public Func<int, Task<IReadOnlyList<DocumentResponse>>>? GetDocsByVessel { get; set; }

    [Parameter]public Func<int, Task<IReadOnlyList<VoyageResponse>>>? GetVoyagesByVessel { get; set; }

    private IReadOnlyList<DocumentResponse> AllDocs { get; set; } = [];
    private IReadOnlyList<VoyageResponse> AllVoyages { get; set; } = [];

    private async Task OnVesselChanged(int? vesselId)
    {
        _VesselId = vesselId;

        if (vesselId.HasValue && GetDocsByVessel is not null)
        {
            AllDocs = await GetDocsByVessel(vesselId.Value);
        }

        else
        {
            AllDocs = [];
        }

        if (vesselId.HasValue && GetVoyagesByVessel is not null)
        {
            AllVoyages = await GetVoyagesByVessel(vesselId.Value);
        }
        else
        {
            AllVoyages = [];
        }


        StateHasChanged();
    }
    private string?   _DocNumber;
    private decimal   _TotalAmount;
    private string?   _Reference;
    private DateOnly? _docDate;

    private DateTime? _docDateTime
    {
        get => _docDate?.ToDateTime(TimeOnly.MinValue);
        set => _docDate = value.HasValue
            ? DateOnly.FromDateTime(value.Value)
            : null;
    }
    private int _DocTypeId;
    private int _CurrencyId;

    private int? _SupplierId;
    private int? _BuyerId;
    private int? _VesselId;
    private int? _PortId;
    private int? _ParentDocumentId;
    private int? _VoyageId;
    private FinancialSide? _Side;
    private bool IsValid =>
       !string.IsNullOrWhiteSpace(_DocNumber)
        && _docDate is not null
        && _DocTypeId > 0
        && _CurrencyId > 0
        && _TotalAmount > 0;

    protected override async Task OnParametersSetAsync()
    {
        if (Document is null)
            return;

        _DocNumber = Document.DocNumber;
        _TotalAmount = Document.TotalAmount;
        _Reference = Document.Reference;
        _DocTypeId = Document.DocTypeId;
        _CurrencyId = Document.CurrencyId;
        _SupplierId = Document.SupplierId;
        _BuyerId = Document.BuyerId;
        _VesselId = Document.VesselId;
        _PortId = Document.PortId;
        _ParentDocumentId = Document.ParentDocumentId;
        _docDate = Document.DocDate;
        _Side = Document.Side;

        if (Document.VesselId.HasValue && GetDocsByVessel is not null)
            AllDocs = await GetDocsByVessel(Document.VesselId.Value);

        if (Document.VesselId.HasValue && GetVoyagesByVessel is not null)
            AllVoyages = await GetVoyagesByVessel(Document.VesselId.Value);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    
    private void Submit()
    {
        if (Document is null)
        {
            MudDialog.Close(DialogResult.Ok(new CreateDocumentRequest
            {
                 DocDate = _docDate!.Value,
                 SupplierId = _SupplierId,
                 VesselId = _VesselId,
                 CurrencyId = _CurrencyId,
                 BuyerId = _BuyerId,
                 DocNumber = _DocNumber ?? "NON",
                 DocTypeId = _DocTypeId,
                 ParentDocumentId = _ParentDocumentId,
                 PortId = _PortId,
                 Reference = _Reference,
                 TotalAmount = _TotalAmount,
                 Side = _Side ?? 0,
                 VoyageId = _VoyageId ?? 0,
            }));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(new UpdateDocumentRequest
            {
                DocDate = _docDate!.Value,
                SupplierId = _SupplierId,
                VesselId = _VesselId,
                CurrencyId = _CurrencyId,
                BuyerId = _BuyerId,
                DocNumber = _DocNumber ?? "NON",
                DocTypeId = _DocTypeId,
                ParentDocumentId = _ParentDocumentId,
                PortId = _PortId,
                Reference = _Reference,
                TotalAmount = _TotalAmount,
                Side = _Side ?? 0,
                VoyageId = _VoyageId ?? 0,
            }));
        }
    }

    
}