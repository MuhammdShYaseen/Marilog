@namespace Marilog.Shared.UI.Pages.BillOfLading
@using MudBlazor

<div class="mb-1">
    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform:uppercase; letter-spacing:0.5px;">
        @Label
    </MudText>
    <MudText Typo = "Typo.body1"
             Style = "@(Bold ? "font-weight:600;" : null)">
        @(string.IsNullOrWhiteSpace(Value) ? "—" : Value)
    </MudText>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool Bold { get; set; }
}
