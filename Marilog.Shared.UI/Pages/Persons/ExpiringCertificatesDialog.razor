@using MudBlazor
@using Marilog.Contracts.DTOs.Responses
@namespace Marilog.Shared.UI.Pages.Persons

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.CardMembership" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Expiring Certificates</MudText>
            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@_items.Count</MudChip>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_items.Count == 0)
        {
            <MudText Color="Color.Secondary">No expiring certificates within 90 days.</MudText>
        }
        else
        {
            <MudTable Items="_items" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Person</MudTh>
                    <MudTh>Certificate</MudTh>
                    <MudTh>Issue Date</MudTh>
                    <MudTh>Expiry Date</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.PersonName</MudTd>
                    <MudTd><b>@context.CertificateName</b></MudTd>
                    <MudTd>@(context.IssueDate?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                    <MudTd>@(context.ExpiryDate?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                    <MudTd>
                        @if (context.DaysLeft < 0)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">
                                Expired @(Math.Abs(context.DaysLeft)) days ago
                            </MudChip>
                        }
                        else if (context.DaysLeft == 0)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">
                                Expires Today
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                @context.DaysLeft days left
                            </MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="() => MudDialog.Close()" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public List<PersonResponse> Items { get; set; } = [];

    // ← يُحوَّل عند تهيئة الـ Dialog
    private List<ExpiringCertificateItem> _items = [];

    protected override void OnParametersSet()
    {
        _items = ToExpiringCertificateItems(Items);
    }

    private List<ExpiringCertificateItem> ToExpiringCertificateItems(List<PersonResponse> persons)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);

        return persons
            .SelectMany(p => p.Certificates
                .Where(c => c.ExpiryDate.HasValue &&
                            (c.ExpiryDate.Value.DayNumber - today.DayNumber) <= 90)
                .Select(c => new ExpiringCertificateItem
                {
                    PersonName = p.FullName,
                    CertificateName = c.CertificateName,
                    IssueDate = c.IssueDate,
                    ExpiryDate = c.ExpiryDate,
                    DaysLeft = c.ExpiryDate!.Value.DayNumber - today.DayNumber
                }))
            .OrderBy(x => x.DaysLeft)
            .ToList();
    }

    public record ExpiringCertificateItem
    {
        public string PersonName { get; init; } = "";
        public string CertificateName { get; init; } = "";
        public DateOnly? IssueDate { get; init; }
        public DateOnly? ExpiryDate { get; init; }
        public int DaysLeft { get; init; }
    }
}