@using Marilog.Contracts.DTOs.Responses
@using Marilog.Kernel.Enums
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Persons

<MudGrid>

    @* ── List ─────────────────────────────────────────────────── *@
    <MudItem xs="12" md="@(_selected is null ? 12 : 7)">

        <MudPaper Class="pa-4" Elevation="2">

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">Persons</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search"
                              Placeholder="Search..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mr-2"
                              Style="max-width:250px" />

                @* ── Passport Warning Toggle ── *@
                <MudToggleIconButton @bind-Toggled="_showExpiringOnly"
                                     Icon="@Icons.Material.Filled.Warning"
                                     ToggledIcon="@Icons.Material.Filled.Warning"
                                     ToggledColor="Color.Warning"
                                     Title="Show expiring passports only"
                                     Size="Size.Medium"
                                     Class="mr-1" />

                @* ── Certificates Expiry Button ── *@
                <MudIconButton Icon="@Icons.Material.Filled.CardMembership"
                               Color="Color.Default"
                               Title="Show expiring certificates"
                               Size="Size.Medium"
                               Class="mr-1"
                               OnClick="HandleExpiringCertificatesClick" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OnAddClicked">
                    New
                </MudButton>
            </MudStack>

            <MudDataGrid T="PersonResponse"
                         Items="_filtered"
                         Hover="true"
                         Dense="true"
                         Striped="true"
                         SelectedItem="_selected"
                         SelectedItemChanged="OnRowSelected"
                         Breakpoint="Breakpoint.Sm">

                <Columns>

                    <PropertyColumn Property="x => x.FullName"
                                    Title="Full Name" />

                    <PropertyColumn Property="x => x.PassportNo"
                                    Title="Passport" />

                    <PropertyColumn Property="x => x.SeamanBookNo"
                                    Title="Seaman Book" />

                    <TemplateColumn Title="Status">
                        <CellTemplate>
                            <MudChip T="string"
                                     Color="@(context.Item.IsActive ? Color.Success : Color.Default)"
                                     Size="Size.Small"
                                     Variant="Variant.Filled">
                                @(context.Item.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn Title="Passport Expiry">
                        <CellTemplate>
                            @if (context.Item.PassportExpiry is not null)
                            {
                                var expiry = context.Item.PassportExpiry.Value;
                                var today = DateOnly.FromDateTime(DateTime.Today);
                                var daysLeft = expiry.DayNumber - today.DayNumber;

                                var color =
                                    daysLeft < 30 ? Color.Error :
                                    daysLeft < 90 ? Color.Warning :
                                    Color.Success;

                                <MudChip T="string"
                                         Color="@color"
                                         Size="Size.Small"
                                         Variant="Variant.Filled">
                                    @expiry.ToString("yyyy-MM-dd")
                                    (@daysLeft days)
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">—</MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn Title=""
                                    Sortable="false"
                                    CellStyle="width:140px">
                        <CellTemplate>
                            <MudStack Row="true" Spacing="1">

                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="() => OnEditClicked.InvokeAsync(context.Item)" />

                                <MudIconButton Icon="@Icons.Material.Filled.Receipt"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="() => OnManageAttachedFilesClicked.InvokeAsync((context.Item.Id, EntityType.Person))" />

                                <MudIconButton Icon="@(context.Item.IsActive ? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                               Size="Size.Small"
                                               Color="@(context.Item.IsActive ? Color.Warning : Color.Success)"
                                               OnClick="() =>
                                               {
                                                   if (context.Item.IsActive)
                                                       OnDeactivateClicked.InvokeAsync(context.Item);
                                                   else
                                                       OnActivateClicked.InvokeAsync(context.Item);
                                               }" />

                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="() => OnDeleteClicked.InvokeAsync(context.Item)" />

                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>

                </Columns>

                <NoRecordsContent>
                    <MudText Typo="Typo.body2"
                             Color="Color.Secondary"
                             Class="pa-4">
                        No persons found.
                    </MudText>
                </NoRecordsContent>

            </MudDataGrid>

        </MudPaper>

    </MudItem>

    @* ── Detail Panel ──────────────────────────────────────────── *@
    @if (_selected is not null)
    {
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4" Elevation="2">

                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">@_selected.FullName</MudText>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="ClosePanel" />
                </MudStack>

                <MudDivider Class="mb-3" />

                <MudTabs Elevation="0" Rounded="false" PanelClass="pt-3">

                    @* ── Info ── *@
                    <MudTabPanel Text="Info" Icon="@Icons.Material.Filled.Person">
                        <MudGrid Spacing="2">
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Nationality</MudText>
                                <MudText Typo="Typo.body2">@(_selected.NationalityCountryName ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Date of Birth</MudText>
                                <MudText Typo="Typo.body2">@(_selected.DateOfBirth?.ToString("yyyy-MM-dd") ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Passport</MudText>
                                <MudText Typo="Typo.body2">@(_selected.PassportNo ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Passport Expiry</MudText>
                                <MudText Typo="Typo.body2">@(_selected.PassportExpiry?.ToString("yyyy-MM-dd") ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Seaman Book</MudText>
                                <MudText Typo="Typo.body2">@(_selected.SeamanBookNo ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText>
                                <MudText Typo="Typo.body2">@(_selected.Phone ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                                <MudText Typo="Typo.body2">@(_selected.Email ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                                <MudChip T="string"
                                         Color="@(_selected.IsActive ? Color.Success : Color.Default)"
                                         Size="Size.Small">
                                    @(_selected.IsActive ? "Active" : "Inactive")
                                </MudChip>
                                @if (_selected.IsPassportExpired)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-2">
                                        Passport Expired
                                    </MudChip>
                                }
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>

                    @* ── Bank Account ── *@
                    <MudTabPanel Text="Bank" Icon="@Icons.Material.Filled.AccountBalance">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText Typo="Typo.subtitle2">Bank Details</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => OnEditBankClicked.InvokeAsync(_selected)" />
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(_selected.BankName) || !string.IsNullOrWhiteSpace(_selected.IBAN))
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Bank Name</MudText>
                                <MudText Typo="Typo.body2">@(_selected.BankName ?? "—")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">IBAN</MudText>
                                <MudText Typo="Typo.body2">@(_selected.IBAN ?? "—")</MudText>
                                @if (!string.IsNullOrWhiteSpace(_selected.BankSwiftCode))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Swift Code</MudText>
                                    <MudText Typo="Typo.body2">@_selected.BankSwiftCode</MudText>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No bank details added.</MudText>
                        }
                    </MudTabPanel>

                    @* ── Certificates ── *@
                    <MudTabPanel Text="Certificates" Icon="@Icons.Material.Filled.CardMembership">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText Typo="Typo.subtitle2">Certificates</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => OnAddCertificateClicked.InvokeAsync(_selected)" />
                        </MudStack>

                        @if (_selected.Certificates.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No certificates added.</MudText>
                        }
                        else
                        {
                            @foreach (var cert in _selected.Certificates)
                            {
                                var certToday = DateOnly.FromDateTime(DateTime.Today);
                                var certExpired = cert.ExpiryDate.HasValue && cert.ExpiryDate.Value < certToday;
                                var certExpiringSoon = !certExpired && cert.ExpiryDate.HasValue &&
                                                       (cert.ExpiryDate.Value.DayNumber - certToday.DayNumber) <= 90;

                                <MudPaper Elevation="0" Class="pa-3 mb-2"
                                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="3">

                                        @* أيقونة دائرية تعبيرية عن الشهادة *@
                                        <MudAvatar Color="@(certExpired ? Color.Error : certExpiringSoon ? Color.Warning : Color.Primary)"
                                                   Variant="Variant.Text"
                                                   Size="Size.Medium">
                                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Small" />
                                        </MudAvatar>

                                        <MudStack Spacing="1" Style="flex:1; min-width:0">

                                            @* السطر الأول: الاسم + الحالة *@
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.subtitle2">@cert.CertificateName</MudText>
                                                    @if (certExpired)
                                                    {
                                                        <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">Expired</MudChip>
                                                    }
                                                    else if (certExpiringSoon)
                                                    {
                                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Expiring Soon</MudChip>
                                                    }
                                                </MudStack>

                                                <MudStack Row="true" Spacing="0">


                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                                   Size="Size.Small"
                                                                   OnClick="() => OnEditCertificateClicked.InvokeAsync((_selected, cert))" />

                                                    <MudIconButton Icon="@Icons.Material.Filled.Receipt"
                                                                   Size="Size.Small"
                                                                   OnClick="() => OnManageAttachedFilesClicked.InvokeAsync((cert.Index, EntityType.PersonCertificate))" />

                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="() => OnRemoveCertificateClicked.InvokeAsync((_selected, cert))" />
                                                </MudStack>
                                            </MudStack>

                                            @* رقم الشهادة + الجهة المصدرة *@
                                            @if (!string.IsNullOrWhiteSpace(cert.CertificateNumber) || !string.IsNullOrWhiteSpace(cert.IssuingAuthority))
                                            {
                                                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                                    @if (!string.IsNullOrWhiteSpace(cert.CertificateNumber))
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Tag">
                                                            @cert.CertificateNumber
                                                        </MudChip>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(cert.IssuingAuthority))
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.AccountBalance">
                                                            @cert.IssuingAuthority
                                                        </MudChip>
                                                    }
                                                </MudStack>
                                            }

                                            <MudDivider Class="my-1" />

                                            @* التواريخ *@
                                            <MudStack Row="true" Spacing="4">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Issue date</MudText>
                                                    <MudText Typo="Typo.body2">@(cert.IssueDate?.ToString("yyyy-MM-dd") ?? "—")</MudText>
                                                </MudStack>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Expiry date</MudText>
                                                    <MudText Typo="Typo.body2"
                                                             Color="@(certExpired ? Color.Error : certExpiringSoon ? Color.Warning : Color.Default)">
                                                        @(cert.ExpiryDate?.ToString("yyyy-MM-dd") ?? "—")
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>

                                            @if (!string.IsNullOrWhiteSpace(cert.Description))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-1">
                                                    @cert.Description
                                                </MudText>
                                            }

                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        }
                    </MudTabPanel>

                    @* ── Sea Services ── *@
                    <MudTabPanel Text="Sea Services" Icon="@Icons.Material.Filled.DirectionsBoat">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText Typo="Typo.subtitle2">Sea Services</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => OnAddSeaServiceClicked.InvokeAsync(_selected)" />
                        </MudStack>

                        @if (_selected.SeaServices.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No sea services added.</MudText>
                        }
                        else
                        {
                            @foreach (var service in _selected.SeaServices)
                            {
                                <MudPaper Elevation="0"
                                          Class="pa-2 mb-2"
                                          Style="border:1px solid var(--mud-palette-divider)">
                                    <MudStack Row="true" AlignItems="AlignItems.Start">
                                        <MudStack Spacing="0" Style="flex:1; min-width:0">
                                            <MudText Typo="Typo.body2">
                                                <b>@(service.RankName ?? "Unknown Rank")</b>
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Experience:
                                                @service.ExperienceInMonths month@(service.ExperienceInMonths == 1 ? "" : "s")
                                            </MudText>
                                            @if (service.VesselSizeInMT.HasValue)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                                    Vessel Size: @service.VesselSizeInMT.Value.ToString("N0") MT
                                                </MudText>
                                            }
                                        </MudStack>
                                        <MudStack Row="true" Spacing="0">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Small"
                                                           OnClick="() => OnEditSeaServiceClicked.InvokeAsync((_selected, service))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="() => OnRemoveSeaServiceClicked.InvokeAsync((_selected, service))" />
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        }
                    </MudTabPanel>

                </MudTabs>

                <MudDivider Class="my-3" />

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="() => OnEditClicked.InvokeAsync(_selected)">
                        Edit
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Receipt"
                               OnClick="() => OnManageAttachedFilesClicked.InvokeAsync((_selected.Id, EntityType.Person))">
                        Files
                    </MudButton>
                    @if (_selected.IsActive)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.PauseCircle"
                                   OnClick="() => OnDeactivateClicked.InvokeAsync(_selected)">
                            Deactivate
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.PlayCircle"
                                   OnClick="() => OnActivateClicked.InvokeAsync(_selected)">
                            Activate
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="() => OnDeleteClicked.InvokeAsync(_selected)">
                        Delete
                    </MudButton>
                </MudStack>

            </MudPaper>
        </MudItem>
    }

</MudGrid>

@code {
    // ── Parameters ───────────────────────────────────────────────
    [Parameter] public IReadOnlyList<PersonResponse> Persons { get; set; } = [];
    [Parameter] public IReadOnlyList<RankResponse> Ranks { get; set; } = [];
    [Parameter] public EventCallback<PersonResponse> OnEditClicked { get; set; }
    [Parameter] public EventCallback<PersonResponse> OnDeleteClicked { get; set; }
    [Parameter] public EventCallback<PersonResponse> OnActivateClicked { get; set; }
    [Parameter] public EventCallback<PersonResponse> OnDeactivateClicked { get; set; }
    [Parameter] public EventCallback<PersonResponse> OnEditBankClicked { get; set; }
    [Parameter] public EventCallback OnAddClicked { get; set; }

    // ← يرسل القائمة الجاهزة للـ parent ليفتح الـ Dialog
    [Parameter] public EventCallback<List<PersonResponse>> OnShowExpiringCertificatesClicked { get; set; }
    [Parameter] public EventCallback<(int entityId, EntityType entityType)> OnManageAttachedFilesClicked { get; set; }
    [Parameter] public EventCallback<PersonResponse> OnAddCertificateClicked { get; set; }
    [Parameter] public EventCallback<(PersonResponse, CertificateResponse)> OnEditCertificateClicked { get; set; }
    [Parameter] public EventCallback<(PersonResponse, CertificateResponse)> OnRemoveCertificateClicked { get; set; }

    [Parameter] public EventCallback<PersonResponse> OnAddSeaServiceClicked { get; set; }
    [Parameter] public EventCallback<(PersonResponse person, PersonSeaServiceResponse service)> OnEditSeaServiceClicked { get; set; }
    [Parameter] public EventCallback<(PersonResponse person, PersonSeaServiceResponse service)> OnRemoveSeaServiceClicked { get; set; }

    // ── State ─────────────────────────────────────────────────────
    private PersonResponse? _selected;
    private string _search = string.Empty;
    private bool _showExpiringOnly = false;
    private int? _lastSelectedId;

    // ── Filtered List ─────────────────────────────────────────────
    private IEnumerable<PersonResponse> _filtered =>
        Persons
            .Where(p => !_showExpiringOnly ||
                        (p.PassportExpiry.HasValue &&
                         (p.PassportExpiry.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days <= 90))
            .Where(p => string.IsNullOrWhiteSpace(_search) ||
                        p.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                        (p.PassportNo?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (p.SeamanBookNo?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (p.Phone?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (p.Email?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    // ── Row Selection ─────────────────────────────────────────────
    private async Task OnRowSelected(PersonResponse? person)
    {
        if (person is null) return;
        _selected = person;
    }

    private void ClosePanel() => _selected = null;

    public void UpdateSelected(PersonResponse person)
    {
        _selected = person;
        _lastSelectedId = person.Id;
        StateHasChanged();
    }

    // ── Expiring Certificates ─────────────────────────────────────
    private async Task HandleExpiringCertificatesClick()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);

        var expiring = Persons.Where(c => c.Certificates.Any(a => a.ExpiryDate <= today.AddDays(30))).ToList();

        await OnShowExpiringCertificatesClicked.InvokeAsync(expiring);
    }

}