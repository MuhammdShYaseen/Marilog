@using Marilog.Contracts.DTOs.Responses
@using Marilog.Kernel.Enums
@using MudBlazor
@namespace Marilog.Shared.UI.Pages.Banks

@* ────────────────────────────────────────────────────────────────────────────
   SharedBankTable
   Hierarchy grid: head banks as root rows, Branches expand as child rows.
   Per rule 4, this component recurses into ITSELF for the child rows rather
   than duplicating row markup/actions at a second level — every EventCallback
   flows down unchanged no matter how deep the branch nesting goes.
   No service refs — every action bubbles up via EventCallback.
   ──────────────────────────────────────────────────────────────────────── *@
<MudDataGrid T="BankResponse"
             Items="Items"
             Hover="true"
             Dense="true"
             Loading="IsLoading">

    <Columns>

        <HierarchyColumn T="BankResponse"
                         ButtonDisabledFunc="x => x.Branches is not { Count: > 0 }" />

        <TemplateColumn Title="Bank"
                        SortBy="x => x.BankName">
            <CellTemplate>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">

                    @if (context.Item.Depth > 0)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowRight"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Style="@($"margin-left:{context.Item.Depth * 16}px")" />
                    }

                    <MudText>
                        @context.Item.BankName
                    </MudText>

                </MudStack>
            </CellTemplate>
        </TemplateColumn>

        <PropertyColumn Property="x => x.ShortName" Title="Short Name" />
        <PropertyColumn Property="x => x.CountryName" Title="Country" />
        <PropertyColumn Property="x => x.SwiftBic" Title="SWIFT / BIC" />
        <PropertyColumn Property="x => x.City" Title="City" />

        <TemplateColumn Title="Status">
            <CellTemplate>

                <MudChip T="string"
                         Size="Size.Small"
                         Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                    @(context.Item.IsActive ? "Active" : "Inactive")
                </MudChip>

            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title=""
                        Sortable="false"
                        CellStyle="width:160px">

            <CellTemplate>

                <MudStack Row="true" Spacing="1">

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   OnClick="() => OnEditClicked.InvokeAsync(context.Item)" />

                    <MudIconButton Icon="@Icons.Material.Filled.Receipt"
                                   Size="Size.Small"
                                   OnClick="() => OnManageAttachedFilesClicked.InvokeAsync((context.Item!.BankId!.Value, EntityType.Bank))" />

                    <MudIconButton Icon="@Icons.Material.Filled.ContactMail"
                                   Size="Size.Small"
                                   OnClick="() => OnManageContactsClicked.InvokeAsync(context.Item)" />

                    <MudIconButton Icon="@(context.Item.IsActive
                                            ? Icons.Material.Filled.ToggleOn
                                            : Icons.Material.Filled.ToggleOff)"
                                   Size="Size.Small"
                                   Color="@(context.Item.IsActive
                                            ? Color.Success
                                            : Color.Default)"
                                   OnClick="() => OnToggleActiveClicked.InvokeAsync(context.Item)" />

                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => OnDeleteClicked.InvokeAsync(context.Item)" />

                </MudStack>

            </CellTemplate>

        </TemplateColumn>

    </Columns>

    <ChildRowContent>

        @if (context.Item.Branches?.Any() == true)
        {
            @foreach (var child in context.Item.Branches)
            {
                <BankTreeRow Item="child"
                             OnEditClicked="OnEditClicked"
                             OnManageContactsClicked="OnManageContactsClicked"
                             OnToggleActiveClicked="OnToggleActiveClicked"
                             OnDeleteClicked="OnDeleteClicked" />
            }
        }

    </ChildRowContent>

    <NoRecordsContent>
        <MudText Class="pa-4">
            No banks found.
        </MudText>
    </NoRecordsContent>

    <LoadingContent>
        <MudText Class="pa-4">
            Loading banks...
        </MudText>
    </LoadingContent>

</MudDataGrid>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<BankResponse> Items { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<(int entityId, EntityType entityType)> OnManageAttachedFilesClicked { get; set; }
    [Parameter, EditorRequired] public EventCallback<BankResponse> OnEditClicked { get; set; }
    [Parameter, EditorRequired] public EventCallback<BankResponse> OnManageContactsClicked { get; set; }
    [Parameter, EditorRequired] public EventCallback<BankResponse> OnToggleActiveClicked { get; set; }
    [Parameter, EditorRequired] public EventCallback<BankResponse> OnDeleteClicked { get; set; }
}
