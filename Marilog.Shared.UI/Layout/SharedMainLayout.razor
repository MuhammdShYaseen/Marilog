@using Marilog.Contracts.DTOs.Frontend.AppTheme
@using Marilog.Contracts.DTOs.Responses
@using Marilog.Shared.UI.Components.Navigation
@using MudBlazor
@namespace Marilog.Shared.UI.Layout


<MudThemeProvider Theme="_mudTheme" IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="1" Color="Color.Primary">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />

        <MudText Typo="Typo.h6" Class="ml-3">
            @AppTitle
        </MudText>

        <MudSpacer />

        <MudText Typo="Typo.body2" Class="mr-3">
            @AppSubtitle
        </MudText>

    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen"
               Elevation="2"
               Variant="DrawerVariant.Responsive">

        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigation</MudText>
        </MudDrawerHeader>

        <MudNavMenu>

            @if (Items?.Any() != true)
            {
                <MudText>Loading...</MudText>
            }
            else
            {
                <NavMenu Items="Items" />
            }

        </MudNavMenu>

    </MudDrawer>

    <MudMainContent>

        <MudContainer MaxWidth="MaxWidth.ExtraLarge"
                      Class="mt-4">

            @ChildContent

        </MudContainer>

    </MudMainContent>

</MudLayout>

@code {

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public List<NavItemResponse> Items { get; set; }
        = new();

    [Parameter]
    public string AppTitle { get; set; }
        = "Marilog";

    [Parameter]
    public string AppSubtitle { get; set; }
        = "";
    [Parameter]
    public AppThemeResponse? Theme { get; set; }


    private MudTheme _mudTheme = new();
    private bool _isDark;
    private bool drawerOpen = true;
    protected override void OnParametersSet()
    {
        if (Theme is null) return;

        _isDark = Theme.IsDarkMode;

        _mudTheme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary = Theme.PrimaryColor,
                Secondary = Theme.SecondaryColor,
                AppbarBackground = Theme.AppBarColor,
                Background = Theme.BackgroundColor,
                Surface = Theme.SurfaceColor,
                Error = Theme.ErrorColor,
                Success = Theme.SuccessColor,
                Warning = Theme.WarningColor
            },
            PaletteDark = new PaletteDark
            {
                Primary = Theme.PrimaryColor,
                Secondary = Theme.SecondaryColor,
                AppbarBackground = Theme.AppBarColor,
                Error = Theme.ErrorColor,
                Success = Theme.SuccessColor,
                Warning = Theme.WarningColor
            },
            Typography = new Typography
            {
                Default = new DefaultTypography
                {
                    FontFamily = [Theme.FontFamily],
                    FontSize = Theme.BaseFontSize
                }
            }
        };
    }
    private void ToggleDrawer()
        => drawerOpen = !drawerOpen;
}