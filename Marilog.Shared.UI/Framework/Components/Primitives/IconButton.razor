@namespace Marilog.Shared.UI.Framework.Components.Primitives
@inherits CommandElementBase

<button type="button"
        class="@BuildBaseClass()"
        style="@GetCachedStyle()"
        disabled="@IsDisabled()"
        title="@Tooltip"
        @onclick="HandleClick">

    <span class="@BuildIconClass()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (!string.IsNullOrWhiteSpace(Icon))
        {
            <i class="@Icon"></i>
        }
    </span>

</button>

@code {

    // =========================
    // PARAMETERS
    // =========================

    [Parameter] public string? Icon { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    //[Parameter] public EventCallback<MouseEventArgs> Click { get; set; }

    //[Parameter] public ICommand? Command { get; set; }
    //[Parameter] public object? CommandParameter { get; set; }

    [Parameter] public string? Tooltip { get; set; }

    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Ghost;
    [Parameter] public ThemeColor ThemeColor { get; set; } = ThemeColor.Primary;
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Medium;

    [Parameter] public bool IsToggled { get; set; }

    // =========================
    // COMMAND CACHE
    // =========================

    private bool _canExecute = true;

    protected override void OnParametersSet()
    {
        if (Command != null)
            _canExecute = Command.CanExecute(CommandParameter);

        base.OnParametersSet();
    }

    

    // =========================
    // CLICK HANDLING
    // =========================

    

    // =========================
    // CLASS SYSTEM
    // =========================

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(

            // layout
            "inline-flex items-center justify-center",

            // shape + size
            GetSizeClass(),
            "rounded-md",

            // cursor
            IsDisabled()
                ? "cursor-not-allowed opacity-50"
                : "cursor-pointer transition-colors duration-150",

            // variant styling
            GetVariantClass(),

            // active state (toggle behavior)
            IsToggled
                ? "ring-2 ring-offset-1 ring-blue-500"
                : null,

            base.BuildBaseClass()
        );
    }

    private string BuildIconClass()
    {
        return TailwindHelper.Classes(
            GetIconSizeClass(),
            "leading-none"
        );
    }

    // =========================
    // VARIANTS
    // =========================

    private string GetVariantClass()
    {
        return Variant switch
        {
            ButtonVariant.Ghost =>
                "bg-transparent hover:bg-slate-100 text-slate-700",

            ButtonVariant.Filled =>
                TailwindHelper.ButtonClass(ButtonVariant.Filled, ThemeColor),

            ButtonVariant.Outlined =>
                "border border-slate-300 hover:bg-slate-50",

            ButtonVariant.Subtle =>
                "bg-slate-50 hover:bg-slate-100",

            _ => "bg-transparent"
        };
    }

    // =========================
    // SIZE SYSTEM
    // =========================

    private string GetSizeClass()
    {
        return Size switch
        {
            ButtonSize.Small => "w-8 h-8",
            ButtonSize.Medium => "w-10 h-10",
            ButtonSize.Large => "w-12 h-12",
            _ => "w-10 h-10"
        };
    }

    private string GetIconSizeClass()
    {
        return Size switch
        {
            ButtonSize.Small => "text-sm",
            ButtonSize.Medium => "text-base",
            ButtonSize.Large => "text-lg",
            _ => "text-base"
        };
    }
}