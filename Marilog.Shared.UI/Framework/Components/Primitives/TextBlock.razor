@namespace Marilog.Shared.UI.Framework.Components.Primitives
@inherits CommandElementBase

@if (!string.IsNullOrEmpty(Text) || ChildContent is not null)
{
    <span class="@GetCachedClass()"
          style="@GetCachedStyle()">

        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @Text
        }

    </span>
}
@code {

    [Parameter] public string? Text { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public FontSize FontSize { get; set; } = FontSize.Regular;
    [Parameter] public bool Bold { get; set; }
    [Parameter] public bool Italic { get; set; }
    [Parameter] public bool Underline { get; set; }

    [Parameter] public ThemeColor Foreground { get; set; } = ThemeColor.Default;

    [Parameter] public WrapMode TextWrapping { get; set; } = WrapMode.Wrap;

    [Parameter] public HAlign TextAlignment { get; set; } = HAlign.Left;
    private string ResolveWeight()
    {
        return Bold ? "font-bold" : "font-normal";
    }
    private string ResolveAlignment()
    {
        return TextAlignment switch
        {
            HAlign.Left => "text-left",
            HAlign.Center => "text-center",
            HAlign.Right => "text-right",
            HAlign.Stretch => "text-justify",
            _ => "text-left"
        };
    }
    private string ResolveWrap()
    {
        return TextWrapping switch
        {
            WrapMode.NoWrap => "whitespace-nowrap",
            WrapMode.WrapWithOverflow => "break-words",
            _ => "whitespace-normal"
        };
    }
    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(

            // Font size
            TailwindHelper.FontSizeClass(FontSize),

            // Weight
            Bold ? "font-bold" : "font-normal",

            // Italic
            Italic ? "italic" : null,

            // Underline
            Underline ? "underline" : null,

            // Alignment
            ResolveAlignment(),

            // Wrap
            ResolveWrap(),

            // Color via Tailwind when possible
            Foreground != ThemeColor.Default
                ? TailwindHelper.TextColorClass(Foreground)
                : null,

            base.BuildBaseClass()
        );
    }
    protected override string BuildBaseStyle()
    {
        var baseStyle = base.BuildBaseStyle();

        return string.Concat(

            baseStyle,

            // Hex override only (not expressible via Tailwind)
            !string.IsNullOrWhiteSpace(ColorHex)
                ? $"color:{ColorHex};"
                : null
        );
    }

    private string ResolveColorClassAsStyle()
    {
        return Foreground switch
        {
            ThemeColor.Primary => "color:#2563eb;",
            ThemeColor.Secondary => "color:#64748b;",
            ThemeColor.Success => "color:#059669;",
            ThemeColor.Warning => "color:#d97706;",
            ThemeColor.Error => "color:#dc2626;",
            _ => ""
        };
    }
}