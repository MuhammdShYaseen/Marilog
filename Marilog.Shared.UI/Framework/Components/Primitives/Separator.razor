@namespace Marilog.Shared.UI.Framework.Components.Primitives
@inherits CommandElementBase

<hr class="@BuildClass()"
    style="@GetCachedStyle()"
    @attributes="GetDataAttributes()" />
@code {

    [Parameter] public bool Vertical { get; set; }
    [Parameter] public bool Inset { get; set; }

    private string BuildClass()
    {
        return TailwindHelper.Classes(
            Vertical ? "w-px h-full" : "h-px w-full",
            "bg-slate-200",
            Inset ? "ml-4" : null,
            GetCachedClass()
        );
    }

    protected override Dictionary<string, object> GetDataAttributes()
    {
        return new()
        {
            ["data-control"] = GetType().Name,
            ["data-enabled"] = IsEnabled
        };
    }
}