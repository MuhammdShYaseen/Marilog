@namespace Marilog.Shared.UI.Framework.Components.Primitives
@inherits FrameworkElement

<button type="button"
        class="@GetCachedClass()"
        style="@GetCachedStyle()"
        disabled="@IsDisabled()"
        @onclick="HandleClick">

    @if (!string.IsNullOrWhiteSpace(StartIcon))
    {
        <span class="inline-flex items-center mr-2">
            <i class="@StartIcon"></i>
        </span>
    }

    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else if (!string.IsNullOrWhiteSpace(Content))
    {
        <span class="@TailwindHelper.FontSizeClass(Size)">
            @Content
        </span>
    }

    @if (!string.IsNullOrWhiteSpace(EndIcon))
    {
        <span class="inline-flex items-center ml-2">
            <i class="@EndIcon"></i>
        </span>
    }

</button>

@code {

    [Parameter] public string? Content { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public ICommand? Command { get; set; }
    [Parameter] public object? CommandParameter { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> Click { get; set; }

    [Parameter] public ButtonVariant ButtonVariant { get; set; } = ButtonVariant.Filled;
    [Parameter] public ThemeColor ThemeColor { get; set; } = ThemeColor.Primary;
    [Parameter] public FontSize Size { get; set; } = FontSize.Regular;
    [Parameter] public ButtonSize ButtonSize { get; set; } = ButtonSize.Medium;

    [Parameter] public string? StartIcon { get; set; }
    [Parameter] public string? EndIcon { get; set; }

    // =========================
    // COMMAND STATE
    // =========================

    private bool _canExecuteCache = true;

    protected override void OnParametersSet()
    {
        if (Command != null)
        {
            _canExecuteCache =
                Command.CanExecute(CommandParameter);
        }

        base.OnParametersSet();
    }

    private bool IsDisabled()
        => !IsEnabled ||
           (Command != null && !_canExecuteCache);

    // =========================
    // CLICK
    // =========================

    private async Task HandleClick(MouseEventArgs args)
    {
        if (IsDisabled())
            return;

        if (Command?.CanExecute(CommandParameter) == true)
            Command.Execute(CommandParameter);

        if (Click.HasDelegate)
            await Click.InvokeAsync(args);
    }

    // =========================
    // CLASS SYSTEM (CORRECT)
    // =========================

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(

            // layout
            "inline-flex items-center justify-center",

            // spacing
            TailwindHelper.ButtonSizeClass(ButtonSize),

            // typography
            TailwindHelper.FontSizeClass(Size),

            // variant
            TailwindHelper.ButtonClass(
                ButtonVariant,
                ThemeColor
            ),

            // state
            IsDisabled()
                ? "opacity-50 cursor-not-allowed"
                : "cursor-pointer",

            base.BuildBaseClass()
        );
    }

    protected override string BuildBaseStyle()
    {
        var sb = new System.Text.StringBuilder();

        // base style (Width / Height / Margin / etc)
        sb.Append(base.BuildBaseStyle());

        // Minimum button width (WPF-like behavior)
        if (!Width.HasValue)
            sb.Append("min-width:64px;");

        return sb.ToString();
    }

}