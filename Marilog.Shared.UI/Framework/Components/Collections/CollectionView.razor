@inherits Marilog.Shared.UI.Framework.Abstractions.FrameworkElement
@typeparam TItem

@*
    CollectionView<TItem> — mirrors Xamarin.Forms CollectionView / WPF ItemsControl.
    Pure HTML + Tailwind. Zero MudBlazor.
*@

<div class="@GetCachedClass()" style="@GetCachedStyle()">

    @* ── Loading state ───────────────────────────────────────────────── *@
    @if (IsLoading)
    {
        @if (LoadingTemplate is not null)
        {
            @LoadingTemplate
        }
        else
        {
            <div class="flex items-center justify-center py-10 gap-3 text-slate-400">
                <svg class="animate-spin h-5 w-5 text-blue-500"
                     xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10"
                            stroke="currentColor" stroke-width="4" />
                    <path class="opacity-75" fill="currentColor"
                          d="M4 12a8 8 0 018-8v8z" />
                </svg>
                <span class="text-sm">Loading...</span>
            </div>
        }
    }

    @* ── Empty state ─────────────────────────────────────────────────── *@
    else if (Items is null || !Items.Any())
    {
        @if (EmptyTemplate is not null)
        {
            @EmptyTemplate
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-12 gap-2 text-slate-400">
                <svg class="h-10 w-10 opacity-40"
                     xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3.75 9.75h16.5m-16.5 4.5h16.5" />
                </svg>
                <span class="text-sm">No items to display.</span>
            </div>
        }
    }

    @* ── Items list ──────────────────────────────────────────────────── *@
    else
    {
        <div class="@BuildListClass()">
            @foreach (var item in Items)
            {
                <div class="@BuildItemClass(item)"
                     @onclick="() => HandleItemClick(item)">
                    @DataTemplate?.Invoke(item)
                </div>
            }
        </div>
    }

</div>

@code {

    // ── Data ─────────────────────────────────────────────────────────────

    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public RenderFragment<TItem>? DataTemplate { get; set; }
    [Parameter] public RenderFragment? EmptyTemplate { get; set; }
    [Parameter] public RenderFragment? LoadingTemplate { get; set; }

    // ── Layout ───────────────────────────────────────────────────────────

    private Orientation _orientation = Orientation.Vertical;

    [Parameter]
    public Orientation Orientation
    {
        get => _orientation;
        set => _orientation = value;
    }

    /// <summary>Gap between items in pixels — mapped to nearest Tailwind gap class.</summary>
    [Parameter] public int ItemSpacing { get; set; } = 8;

    /// <summary>
    /// When > 0 renders a CSS grid with N columns.
    /// When 0 renders a flex list (vertical or horizontal per Orientation).
    /// </summary>
    [Parameter] public int Columns { get; set; } = 0;

    // ── State ─────────────────────────────────────────────────────────────

    [Parameter] public bool IsLoading { get; set; } = false;

    // ── Selection ─────────────────────────────────────────────────────────

    private SelectionMode _selectionMode = SelectionMode.None;

    [Parameter]
    public SelectionMode SelectionMode
    {
        get => _selectionMode;
        set => _selectionMode = value;
    }

    [Parameter] public TItem? SelectedItem { get; set; }
    [Parameter] public EventCallback<TItem> SelectedItemChanged { get; set; }
    [Parameter] public IList<TItem>? SelectedItems { get; set; }
    [Parameter] public EventCallback<IList<TItem>> SelectedItemsChanged { get; set; }

    // ── Class builders ────────────────────────────────────────────────────

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(
            "w-full",
            base.BuildBaseClass()
        );
    }

    private string BuildListClass()
    {
        // Grid mode
        if (Columns > 0)
            return TailwindHelper.Classes(
                "grid",
                $"grid-cols-{Columns}",
                TailwindHelper.GapClass(ItemSpacing)
            );

        // Flex list mode
        return TailwindHelper.Classes(
            "flex",
            _orientation == Orientation.Horizontal ? "flex-row flex-wrap" : "flex-col",
            TailwindHelper.GapClass(ItemSpacing)
        );
    }

    private string BuildItemClass(TItem item)
    {
        var isSelected = IsSelected(item);
        var isClickable = _selectionMode != SelectionMode.None;

        return TailwindHelper.Classes(
            "w-full",
            isClickable ? "cursor-pointer" : null,
            isClickable ? "transition-colors duration-150" : null,
            isSelected ? "ring-2 ring-blue-500 ring-inset rounded-lg" : null,
            isSelected ? "bg-blue-50" : null,
            isClickable && !isSelected ? "hover:bg-slate-50 rounded-lg" : null
        );
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    private bool IsSelected(TItem item)
    {
        return _selectionMode switch
        {
            SelectionMode.Single => EqualityComparer<TItem>.Default.Equals(item, SelectedItem),
            SelectionMode.Multiple => SelectedItems?.Contains(item) == true,
            _ => false
        };
    }

    private async Task HandleItemClick(TItem item)
    {
        if (_selectionMode == SelectionMode.None) return;

        if (_selectionMode == SelectionMode.Single)
        {
            SelectedItem = item;
            await SelectedItemChanged.InvokeAsync(item);
        }
        else
        {
            SelectedItems ??= new List<TItem>();

            if (SelectedItems.Contains(item))
                SelectedItems.Remove(item);
            else
                SelectedItems.Add(item);

            await SelectedItemsChanged.InvokeAsync(SelectedItems);
        }
    }
}
