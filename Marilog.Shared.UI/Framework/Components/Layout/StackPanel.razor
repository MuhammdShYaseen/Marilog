@namespace Marilog.Shared.UI.Framework.Components.Layout
@inherits Marilog.Shared.UI.Framework.Abstractions.FrameworkElement

@*
    StackPanel — mirrors WPF StackPanel.
    Pure HTML div + Tailwind flex. Zero MudBlazor.
*@

<div class="@GetCachedClass()" style="@GetCachedStyle()">
    @ChildContent
</div>

@code {

    // ── Backing fields ────────────────────────────────────────────────────
    // Required to avoid "field initializer cannot reference non-static member"
    // when property name matches type name (Orientation Orientation).

    private Orientation _orientation = Orientation.Vertical;
    private int _spacing = 8;

    // ── Parameters ────────────────────────────────────────────────────────

    [Parameter]
    public Orientation Orientation
    {
        get => _orientation;
        set
        {
            if (_orientation == value) return;
            _orientation = value;
            InvalidateVisual();
        }
    }

    [Parameter]
    public int Spacing
    {
        get => _spacing;
        set
        {
            if (_spacing == value) return;
            _spacing = value;
            InvalidateVisual();
        }
    }

    [Parameter] public bool WrapContent { get; set; } = false;
    [Parameter] public HAlign ChildAlignment { get; set; } = HAlign.Stretch;
    [Parameter] public HAlign ChildJustify { get; set; } = HAlign.Left;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // ── OnParametersSet ───────────────────────────────────────────────────
    // Must call base — FrameworkElement.OnParametersSet() handles its own
    // dirty tracking for Margin, Padding, Width, Height, Visibility, IsEnabled.

    protected override void OnParametersSet()
    {
        base.OnParametersSet(); // ← required
    }

    // ── Class builder ─────────────────────────────────────────────────────

    protected override string BuildBaseClass()
    {
        var isHorizontal = _orientation == Orientation.Horizontal;

        return TailwindHelper.Classes(
            "flex",
            isHorizontal ? "flex-row" : "flex-col",
            WrapContent ? "flex-wrap" : "flex-nowrap",
            TailwindHelper.GapClass(_spacing),
            ResolveAlignItems(),
            TailwindHelper.JustifyClass(ChildJustify),
            "w-full min-w-0 min-h-0 box-border",
            base.BuildBaseClass()
        );
    }

    // ── Style builder ─────────────────────────────────────────────────────

    protected override string BuildBaseStyle()
    {
        // base already handles Margin, Padding, Visibility, ZIndex, ColorHex
        // We only add explicit px overrides that Tailwind cannot express
        var sb = new System.Text.StringBuilder(base.BuildBaseStyle());
        if (Width.HasValue) sb.Append($"width:{Width}px;");
        if (Height.HasValue) sb.Append($"height:{Height}px;");
        return sb.ToString();
    }

    // ── Alignment helper ──────────────────────────────────────────────────

    private string ResolveAlignItems()
    {
        if (_orientation == Orientation.Horizontal)
        {
            // Horizontal: Stretch = children fill height (cross axis = vertical)
            return ChildAlignment == HAlign.Stretch
                ? "items-stretch"
                : TailwindHelper.HAlignItemsClass(ChildAlignment);
        }
        else
        {
            // Vertical: Stretch = children fill width
            // items-stretch alone is enough — w-full on children is their own responsibility
            return TailwindHelper.HAlignItemsClass(ChildAlignment);
        }
    }
}
