@inherits Marilog.Shared.UI.Framework.Abstractions.FrameworkElement

@*
    StackPanel — mirrors WPF StackPanel.
    Pure HTML div + Tailwind flex. Zero MudBlazor.

    Orientation.Vertical  → flex-col  (default)
    Orientation.Horizontal → flex-row
    WrapContent=true       → flex-wrap (mimics WPF WrapPanel)
*@

<div class="@GetCachedClass()"
     style="@GetCachedStyle()">
    @ChildContent
</div>

@code {

    // ── Layout ───────────────────────────────────────────────────────────

    private Orientation _orientation = Orientation.Vertical;
    private Orientation _lastOrientation;
    private int _lastSpacing;
    [Parameter] public Orientation Orientation { get; set; }

    private int _spacing = 8;

    /// <summary>Gap between children in pixels.</summary>
    [Parameter] public int Spacing { get; set; } = 8;

    /// <summary>Allow children to wrap — mimics WPF WrapPanel.</summary>
    [Parameter] public bool WrapContent { get; set; } = false;

    // ── Alignment ─────────────────────────────────────────────────────────

    /// <summary>
    /// Cross-axis alignment of children.
    /// On Vertical stack   → controls horizontal alignment (items-*)
    /// On Horizontal stack → controls vertical alignment   (items-*)
    /// </summary>
    [Parameter] public HAlign ChildAlignment { get; set; } = HAlign.Stretch;

    /// <summary>Main-axis justification — mirrors WPF HorizontalAlignment on the panel.</summary>
    [Parameter] public HAlign ChildJustify { get; set; } = HAlign.Left;

    // ── Content ───────────────────────────────────────────────────────────

    [Parameter] public RenderFragment? ChildContent { get; set; }

    // ── Class builder ─────────────────────────────────────────────────────

    protected override string BuildBaseClass()
    {
        var isHorizontal = _orientation == Orientation.Horizontal;

        return TailwindHelper.Classes(
            // flex direction
            "flex",
            isHorizontal ? "flex-row" : "flex-col",

            // wrap
            WrapContent ? "flex-wrap" : "flex-nowrap",

            // gap
            TailwindHelper.GapClass(_spacing),

            // cross-axis alignment
            ResolveAlignItems(),

            // main-axis justification
            TailwindHelper.JustifyClass(ChildJustify),

            // sizing — important inside nested Grid / Flex
            "w-full min-w-0 min-h-0 box-border",

            // base (Margin, Visibility, custom Class, etc.)
            base.BuildBaseClass()
        );
    }

    // ── Style builder ─────────────────────────────────────────────────────

    protected override string BuildBaseStyle()
    {
        var sb = new System.Text.StringBuilder(base.BuildBaseStyle());

        // Only add explicit pixel sizes when set — Tailwind handles the rest
        if (Width.HasValue) sb.Append($"width:{Width}px;");
        if (Height.HasValue) sb.Append($"height:{Height}px;");

        return sb.ToString();
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    private string ResolveAlignItems()
    {
        // Stretch on a horizontal stack centres children vertically,
        // not stretches them — mirrors the MudBlazor/WPF behaviour.
        if (ChildAlignment == HAlign.Stretch && _orientation == Orientation.Horizontal)
            return "items-center";

        return TailwindHelper.HAlignItemsClass(ChildAlignment);
    }

    protected override void OnParametersSet()
    {
        if (_lastOrientation != Orientation ||
            _lastSpacing != Spacing)
        {
            _lastOrientation = Orientation;
            _lastSpacing = Spacing;

            InvalidateVisual(); // or mark dirty cache
        }
    }
}
