@inherits CommandElementBase
<CascadingValue Value="_context" IsFixed="false">
<nav class="@GetCachedClass()"
     style="@GetCachedStyle()">

    @ChildContent

</nav>
</CascadingValue>
@code {
    private readonly NavContext _context = new();
    // =========================
    // CONTENT
    // =========================

    [Parameter] public RenderFragment? ChildContent { get; set; }

    // =========================
    // LAYOUT
    // =========================

    [Parameter] public Orientation Orientation { get; set; } = Orientation.Vertical;

    [Parameter] public int Spacing { get; set; } = 4;

    [Parameter] public bool Compact { get; set; }

    [Parameter] public bool FillWidth { get; set; } = true;

    // =========================
    // CLASS BUILDING
    // =========================

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(
            "xf-nav-menu",
            "flex",

            // orientation
            Orientation == Orientation.Vertical
                ? "flex-col"
                : "flex-row flex-wrap",

            // spacing
            TailwindHelper.GapClass(Spacing),

            // sizing behavior
            FillWidth ? "w-full" : null,

            // typography density
            Compact ? "text-sm" : "text-base",

            // safe defaults
            "min-w-0 min-h-0",

            base.BuildBaseClass()
        );
    }

    // =========================
    // STYLE
    // =========================

    

    // =========================
    // LIFECYCLE
    // =========================

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        // NavMenu is purely structural → always safe to invalidate visual
        InvalidateVisual();
    }
}