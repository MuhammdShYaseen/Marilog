@*
    GridCell — Blazor equivalent of WPF Grid attached properties.
*@
@inherits FrameworkElement
<div class="xf-grid @GetCachedClass()"
     style="@BuildGridStyle()">

    @ChildContent

</div>
@code {

    [Parameter] public string ColumnDefinitions { get; set; } = "*";
    [Parameter] public string RowDefinitions { get; set; } = "Auto";

    [Parameter] public int ColumnGap { get; set; } = 8;
    [Parameter] public int RowGap { get; set; } = 8;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string? _cachedStyle;
    private string? _lastSignature;

    protected override void OnParametersSet()
    {
        var signature = $"{ColumnDefinitions}|{RowDefinitions}|{ColumnGap}|{RowGap}|{GetCachedStyle()}";

        if (signature != _lastSignature)
        {
            _lastSignature = signature;
            _cachedStyle = BuildGridStyleInternal();
        }
    }

    private string BuildGridStyle()
    {
        return _cachedStyle ?? BuildGridStyleInternal();
    }

    private string BuildGridStyleInternal()
    {
        return string.Concat(
            GetCachedStyle(),
            "display:grid;",
            $"grid-template-columns:{ParseTracks(ColumnDefinitions)};",
            $"grid-template-rows:{ParseTracks(RowDefinitions)};",
            ColumnGap > 0 ? $"column-gap:{ColumnGap}px;" : null,
            RowGap > 0 ? $"row-gap:{RowGap}px;" : null
        );
    }

    private static string ParseTracks(string? definitions)
    {
        if (string.IsNullOrWhiteSpace(definitions))
            return "auto";

        return string.Join(' ',
            definitions
                .Trim()
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Select(ParseTrack));
    }

    private static string ParseTrack(string t)
    {
        return GridLength.TryParse(t, out var gl)
            ? gl.ToCss()
            : "auto";
    }
}
