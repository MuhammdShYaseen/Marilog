@*
    GridCell — Blazor equivalent of WPF Grid attached properties.
*@

<div style="@GetCachedStyle()" class="xf-grid-cell @Class">
    @ChildContent
</div>

@code {

    [Parameter] public int Column { get; set; } = 0;
    [Parameter] public int Row { get; set; } = 0;

    [Parameter] public int ColumnSpan { get; set; } = 1;
    [Parameter] public int RowSpan { get; set; } = 1;

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string? _cachedStyle;
    private int _lastColumn;
    private int _lastRow;
    private int _lastColumnSpan;
    private int _lastRowSpan;

    private string GetCachedStyle()
    {
        if (_cachedStyle is null ||
            _lastColumn != Column ||
            _lastRow != Row ||
            _lastColumnSpan != ColumnSpan ||
            _lastRowSpan != RowSpan)
        {
            _lastColumn = Column;
            _lastRow = Row;
            _lastColumnSpan = ColumnSpan;
            _lastRowSpan = RowSpan;

            _cachedStyle = BuildCellStyle();
        }

        return _cachedStyle;
    }

    private string BuildCellStyle()
    {
        // CSS Grid uses 1-based indices
        var colStart = Math.Max(1, Column + 1);
        var rowStart = Math.Max(1, Row + 1);

        var colEnd = colStart + Math.Max(1, ColumnSpan);
        var rowEnd = rowStart + Math.Max(1, RowSpan);

        return
            $"grid-column:{colStart}/{colEnd};" +
            $"grid-row:{rowStart}/{rowEnd};" +
            "min-width:0;" +
            "min-height:0;";
    }
}