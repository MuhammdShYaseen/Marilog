@inherits FrameworkElement

<div class="@GetCachedClass()"
     style="@GetCachedStyle()"
     @onclick="HandleClick">

    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <span class="xf-nav-icon">
            <i class="@Icon"></i>
        </span>
    }

    <span class="xf-nav-text">
        @Text
    </span>

</div>

@code {

    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Icon { get; set; }

    [Parameter] public string? Key { get; set; }

    [CascadingParameter] public NavContext? NavContext { get; set; }

    private bool IsActive =>
        NavContext?.IsActive(Key) == true;

    private async Task HandleClick(MouseEventArgs args)
    {
        if (!IsEnabled)
            return;

        if (!string.IsNullOrWhiteSpace(Key))
        {
            NavContext?.SetActive(Key);
        }
    }

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(
            "xf-nav-item",
            "flex items-center gap-2",
            "px-3 py-2 rounded-md",
            "cursor-pointer select-none",

            IsEnabled
                ? "hover:bg-slate-100"
                : "opacity-50 cursor-not-allowed",

            IsActive
                ? "bg-slate-200 font-semibold"
                : "text-slate-700",

            base.BuildBaseClass()
        );
    }

    protected override string BuildBaseStyle()
        => base.BuildBaseStyle();
}