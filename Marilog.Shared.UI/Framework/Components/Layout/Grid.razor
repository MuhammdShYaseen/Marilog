@inherits FrameworkElement

<div class="@GetCachedClass()"
     style="@GetCachedStyle()">

    @ChildContent

</div>

@code {

    [Parameter] public string ColumnDefinitions { get; set; } = "*";

    [Parameter] public string RowDefinitions { get; set; } = "Auto";

    [Parameter] public int ColumnGap { get; set; } = 8;

    [Parameter] public int RowGap { get; set; } = 8;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    // =========================
    // CLASS BUILDING
    // =========================

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(
            "xf-grid",
            "grid",

            TailwindHelper.GapClass(ColumnGap),

            base.BuildBaseClass()
        );
    }

    // =========================
    // STYLE BUILDING
    // =========================

    protected override string BuildBaseStyle()
    {
        var sb = new System.Text.StringBuilder(
            base.BuildBaseStyle()
        );

        sb.Append($"grid-template-columns:{ParseTracks(ColumnDefinitions)};");
        sb.Append($"grid-template-rows:{ParseTracks(RowDefinitions)};");

        if (RowGap != ColumnGap)
            sb.Append($"row-gap:{RowGap}px;");

        return sb.ToString();
    }

    // =========================
    // TRACK PARSER (WPF style)
    // =========================

    private static string ParseTracks(string? definitions)
    {
        if (string.IsNullOrWhiteSpace(definitions))
            return "auto";

        var tracks = definitions
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        var result = new List<string>(tracks.Length);

        foreach (var t in tracks)
        {
            if (GridLength.TryParse(t, out var gl))
            {
                result.Add(gl.ToCss());
            }
            else
            {
                result.Add("auto");
            }
        }

        return string.Join(' ', result);
    }

}