@namespace Marilog.Shared.UI.Framework.Components.Layout
@inherits Marilog.Shared.UI.Framework.Abstractions.FrameworkElement

@*
    Grid — mirrors WPF Grid.
    CSS Grid under the hood. Columns/rows defined with XAML-style strings.
    Zero MudBlazor.

    Usage:
    <Grid ColumnDefinitions="* 2* Auto" RowDefinitions="Auto * 60">
        <GridCell Column="0" Row="0"> ... </GridCell>
        <GridCell Column="1" Row="0" ColumnSpan="2"> ... </GridCell>
    </Grid>
*@

<div class="@GetCachedClass()" style="@GetCachedStyle()">
    @ChildContent
</div>

@code {

    [Parameter] public string ColumnDefinitions { get; set; } = "*";
    [Parameter] public string RowDefinitions { get; set; } = "Auto";
    [Parameter] public int ColumnGap { get; set; } = 8;
    [Parameter] public int RowGap { get; set; } = 8;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // ── Class builder ─────────────────────────────────────────────────────

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(
            "grid",
            "w-full min-w-0",
            base.BuildBaseClass()
        );

        // NOTE: gap is intentionally NOT added here.
        // ColumnGap and RowGap may differ, so both are handled in BuildBaseStyle()
        // as column-gap / row-gap inline CSS — Tailwind's gap-* sets both equally.
    }

    // ── Style builder ─────────────────────────────────────────────────────

    protected override string BuildBaseStyle()
    {
        var sb = new System.Text.StringBuilder(base.BuildBaseStyle());

        sb.Append($"grid-template-columns:{ParseTracks(ColumnDefinitions)};");
        sb.Append($"grid-template-rows:{ParseTracks(RowDefinitions)};");

        // Always write both gaps explicitly — avoids Tailwind gap-* overriding one of them
        sb.Append(FormattableString.Invariant(
            $"column-gap:{ColumnGap}px;row-gap:{RowGap}px;"));

        return sb.ToString();
    }

    // ── Track parser ──────────────────────────────────────────────────────

    private static string ParseTracks(string? definitions)
    {
        if (string.IsNullOrWhiteSpace(definitions))
            return "auto";

        var tokens = definitions
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        var result = new System.Text.StringBuilder();

        foreach (var token in tokens)
        {
            if (result.Length > 0) result.Append(' ');

            result.Append(
                GridLength.TryParse(token, out var gl)
                    ? gl.ToCss()
                    : "auto"          // graceful fallback for unrecognised tokens
            );
        }

        return result.ToString();
    }
}
