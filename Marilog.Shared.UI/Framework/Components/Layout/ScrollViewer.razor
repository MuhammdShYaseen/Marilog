@namespace Marilog.Shared.UI.Framework.Components.Layout
@inherits Marilog.Shared.UI.Framework.Abstractions.FrameworkElement

<div class="@GetCachedClass()"
     style="@GetCachedStyle()">

    @ChildContent

</div>

@code {

    [Parameter] public bool HorizontalScroll { get; set; }

    [Parameter] public bool VerticalScroll { get; set; } = true;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    // =========================
    // CLASS BUILDING
    // =========================

    protected override string BuildBaseClass()
    {
        return TailwindHelper.Classes(
            "xf-scrollviewer",
            "block",

            // Always prevent flex/grid overflow bugs
            "min-w-0",
            "min-h-0",

            base.BuildBaseClass()
        );
    }

    // =========================
    // STYLE BUILDING
    // =========================

    protected override string BuildBaseStyle()
    {
        var sb = new System.Text.StringBuilder(
            base.BuildBaseStyle()
        );

        sb.Append($"overflow-x:{(HorizontalScroll ? "auto" : "hidden")};");
        sb.Append($"overflow-y:{(VerticalScroll ? "auto" : "hidden")};");

        return sb.ToString();
    }

}