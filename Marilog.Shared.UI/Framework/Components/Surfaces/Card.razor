@namespace Marilog.Shared.UI.Framework.Components.Surfaces
@inherits CommandElementBase

<div class="@BuildClass()"
     style="@BuildCardStyle()">

    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Subtitle))
    {
        <div class="xf-card-header">

            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <div class="@TailwindHelper.Classes("text-lg font-semibold")">
                    @Title
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <div class="@TailwindHelper.Classes("text-sm text-slate-500")">
                    @Subtitle
                </div>
            }

            @if (HeaderActions is not null)
            {
                <div class="xf-card-header-actions">
                    @HeaderActions
                </div>
            }

        </div>
    }

    <div class="xf-card-content @GetContentClass()">
        @ChildContent
    </div>

    @if (Actions is not null)
    {
        <div class="xf-card-actions">
            @Actions
        </div>
    }

</div>

@code {

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }

    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    [Parameter] public ElevationLevel Elevation { get; set; } = ElevationLevel.Low;
    [Parameter] public bool Outlined { get; set; }

    private string BuildCardStyle()
    {
        return GetCachedStyle();
    }

    private string? _cachedPadding;
    private Thickness _lastPadding;

    private string? GetContentPadding()
    {
        if (_cachedPadding is null || !_lastPadding.Equals(Padding))
        {
            _lastPadding = Padding;

            _cachedPadding = Padding != Thickness.Zero
                ? $"padding:{Padding.ToCss()};"
                : null;
        }

        return _cachedPadding;
    }

    private string BuildClass()
    {
        return TailwindHelper.Classes(
            "rounded-lg",
            "bg-white",
            "min-w-0",
            "min-h-0",

            TailwindHelper.ElevationClass(Elevation),

            Outlined
                ? "border border-slate-200"
                : "border border-transparent",

            GetCachedClass()
        );
    }

    private string GetContentClass()
    {
        if (Padding.Equals(Thickness.Zero))
            return "p-0";

        return "p-4";
    }
}